<script>
    async function CalculateAll() {
        const $newRows = $("tr.NewRow");
        const $inNewRows = $("tr.InNewRow");
        const $iInxNewRows = $("tr.IInNewRow");
        const cluster = $("#SIH_TCT_Number").val() || $("#SIH_HIDE_TCT_Number").val();
        const invoiceDate = $("#SIH_InvoiceDate").val();
        const whNumber = $("#SIH_WHT_Number").val();

        // Pre-calculate values that don't change during iteration
        const whTax = whNumber ? $("#SIH_WHT_Tax").val() : "1";
        const whPercent = whNumber ? $("#SIH_WHT_Percent").val() : 0;

        // Process items and Incomes in parallel
        const [itemResults, headerIncomeResults] = await Promise.all([
            processItems($newRows, $iInxNewRows, cluster, invoiceDate, whTax, whPercent),
            processHeaderIncomes($inNewRows, $newRows, cluster, invoiceDate, whTax, whPercent)
        ]);

        // Calculate footer with all results
        await calculateFooter(itemResults, headerIncomeResults);
    }

    // Function to generate unique item key
    function generateItemKey(SII_Number, SII_ITM_Number, SII_Index) {
        // Priority 1: Use SII_Number if available and valid
        if (SII_Number && parseInt(SII_Number) > 0) {
            return `SII_${SII_Number}`;
        }
        // Priority 2: Use combination of ITM_Number and ITM_Index
        else if (SII_ITM_Number && SII_Index) {
            return `ITM_${SII_ITM_Number}_${SII_Index}`;
        }
        // Fallback: Generate random key for new items
        return `NEW_${Math.random().toString(36).substr(2, 9)}`;
    }

    async function processItems($newRows, $iInxNewRows, cluster, invoiceDate, whTax, whPercent) {
        const itemPromises = [];
        const itemIncomeMap = new Map();

        // Pre-calculate item Incomes with dual identification
        $iInxNewRows.each(function() {
            const $row = $(this);
            // ParseInt and compare to 1
            if (parseInt($row.find("input.SII_INC_IsDeleted").val()) === 1) return;

            // Get both identification methods - FIXED FIELD NAMES
            const SII_Number = $row.find("input.SII_INC_SII_Number").val();
            const SII_ITM_Number = $row.find("input.SII_INC_ITM_Number").val(); // FIXED
            const SII_Index = $row.find("input.SII_INC_ITM_Index").val(); // FIXED

            // Create unique key based on available identifiers
            const key = generateItemKey(SII_Number, SII_ITM_Number, SII_Index);
            console.log("key",key);
            console.log("itemIncomeMap",itemIncomeMap.has(key));

            if (!itemIncomeMap.has(key)) {
                itemIncomeMap.set(key, []);
            }

            itemIncomeMap.get(key).push({
                IncomeBase: parseFloat(removeCommas($row.find("input.SII_INC_IncomeBase").val())) || 0,
                charge: $row.find("select.SII_INC_CM_Number").val(),
                row: $row
            });
        });

        // Process each item row
        $newRows.each(function() {
            const $row = $(this);
            // ParseInt and compare to 1
            if (parseInt($row.find('input.SII_IsDeleted').val()) === 1) return;

            const promise = processSingleItem($row, itemIncomeMap, cluster, invoiceDate, whTax, whPercent);
            itemPromises.push(promise);
        });

        return Promise.all(itemPromises);
    }

    async function processSingleItem($row, itemIncomeMap, cluster, invoiceDate, whTax, whPercent) {
        // Get both identification methods for the current item
        const SII_Number = $row.find('input.SII_Number').val();
        const SII_ITM_Number = $row.find('input.SII_ITM_Number').val();
        const SII_Index = $row.find('input.SII_Index').val();

        // Generate the key to find matching incomes
        const key = generateItemKey(SII_Number, SII_ITM_Number, SII_Index);
        console.log("key1",key);
        const hsnNumber = $row.find('.SII_HSN_Number').val();

        const qty = parseFloat(removeCommas($row.find('input.SII_Qty').val())) || 0;
        const unitPrice = parseFloat(removeCommas($row.find('input.SII_UnitPrice').val())) || 0;
        const materialValue = qty * unitPrice;

        // Calculate amount
        $row.find("input.SII_Amount").val(DecimalIndianRupees(materialValue));

        // Process item Incomes
        let IncomeTotal = 0;
        const itemIncomes = itemIncomeMap.get(key) || [];

        for (const Income of itemIncomes) {
            let IncomeValue = 0;

            switch (Income.charge) {
                case "1":
                    IncomeValue = Income.IncomeBase;
                    break;
                case "2":
                    IncomeValue = qty * Income.IncomeBase;
                    break;
                case "3":
                    IncomeValue = materialValue * Income.IncomeBase / 100;
                    break;
            }
            IncomeValue = parseFloat(parseFloat(IncomeValue).toFixed(2));

            Income.row.find("input.SII_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
            IncomeTotal += parseFloat(IncomeValue);
        }
        console.log("SII_IncomeValue",IncomeTotal);

        $row.find("input.SII_IncomeValue").val(DecimalIndianRupees(IncomeTotal));

        // Calculate GST and WHT
        const baseAmount = materialValue + IncomeTotal;
        let gstAmount = 0;
        let whtAmount = 0;

        if (cluster) {
            gstAmount = await GetClusterAmount(cluster, invoiceDate, hsnNumber, baseAmount);
            gstAmount = parseFloat(parseFloat(gstAmount).toFixed(2));
            $row.find("input.SII_GST_Amount").val(DecimalIndianRupees(gstAmount));

            const totalAmount = whTax === "1" ? baseAmount + gstAmount : baseAmount;
            whtAmount = -(totalAmount * whPercent / 100);
            whtAmount = parseFloat(parseFloat(whtAmount).toFixed(2));

            $row.find("input.SII_WHT_Percent").val(DecimalIndianRupees(whPercent));
            $row.find("input.SII_WHT_Amount").val(DecimalIndianRupees(whtAmount));
        }

        return {
            qty: qty,
            amount: materialValue,
            Income: IncomeTotal,
            gst: gstAmount,
            wht: whtAmount
        };
    }

    async function processHeaderIncomes($inNewRows, $newRows, cluster, invoiceDate, whTax, whPercent) {
        const promises = [];

        $inNewRows.each(function() {
            const $row = $(this);
            // ParseInt and compare to 1
            if (parseInt($row.find("input.SIH_INC_IsDeleted").val()) === 1) return;

            promises.push(processHeaderIncome($row, $newRows, cluster, invoiceDate, whTax, whPercent));
        });

        return Promise.all(promises);
    }

    async function processHeaderIncome($row, $newRows, cluster, invoiceDate, whTax, whPercent) {
        const charge = $row.find("select.SIH_INC_CM_Number").val();
        const isGst = $row.find("select.SIH_INC_CalculateGST").val();
        const IncomeBase = parseFloat(removeCommas($row.find("input.SIH_INC_IncomeBase").val())) || 0;

        const items = $newRows.map(function() {
            const $irow = $(this);
            if (parseInt($irow.find("input.SII_IsDeleted").val()) !== 1) {
                return {
                    qty: parseFloat(removeCommas($irow.find(".SII_Qty").val())) || 0,
                    amount: parseFloat(removeCommas($irow.find(".SII_Amount").val())) || 0
                };
            }
            return null;
        }).get().reduce((acc, item) => {
            if (item) {
                return {
                    itemQty: acc.itemQty + item.qty,
                    itemAmount: acc.itemAmount + item.amount
                };
            }
            return acc;
        }, { itemQty: 0, itemAmount: 0 });

        let IncomeValue = 0;
        switch (charge) {
            case "1":
                IncomeValue = IncomeBase;
                break;
            case "2":
                IncomeValue = items.itemQty * IncomeBase;
                break;
            case "3":
                IncomeValue = items.itemAmount * IncomeBase / 100;
                break;
        }

        IncomeValue = parseFloat(parseFloat(IncomeValue).toFixed(2));
        $row.find("input.SIH_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
        
        let taxValue = 0;
        if (isGst === "2" && cluster) {
            const sacNumber = $row.find("input.SIH_INC_SAC_Number").val();
            taxValue = await GetClusterIncomeAmount(cluster, invoiceDate, sacNumber, IncomeValue);
        }
        const totalAmount = whTax === "1" ? IncomeValue + taxValue : IncomeValue;
        whtAmount = -(totalAmount * whPercent / 100);
        whtAmount = parseFloat(parseFloat(whtAmount).toFixed(2));

        $row.find("input.SIH_INC_WHT_Percent").val(DecimalIndianRupees(whPercent));
        $row.find("input.SIH_INC_WHT_Amount").val(DecimalIndianRupees(whtAmount));

        taxValue = parseFloat(parseFloat(taxValue).toFixed(2));
        $row.find("input.SIH_INC_GST_Amount").val(DecimalIndianRupees(taxValue));

        return { IncomeValue, taxValue, whtAmount };
    }

    // Utility function for safe number operations
    function safeNumber(value, defaultValue = 0) {
        const num = parseFloat(value);
        return isNaN(num) ? defaultValue : num;
    }

    async function calculateFooter(itemResults, headerIncomeResults) {
        // Use safe number handling
        const itemTotals = itemResults.reduce((acc, item) => ({
            totalQty: acc.totalQty + safeNumber(item.qty),
            totalAmount: acc.totalAmount + safeNumber(item.amount),
            totalIncome: acc.totalIncome + safeNumber(item.Income),
            totalGst: acc.totalGst + safeNumber(item.gst),
            totalWHT: acc.totalWHT + safeNumber(item.wht)
        }), { totalQty: 0, totalAmount: 0, totalIncome: 0, totalGst: 0, totalWHT: 0 });

        const headerIncomeTotals = headerIncomeResults.reduce((acc, Income) => ({
            headerTotal: acc.headerTotal + safeNumber(Income.IncomeValue),
            headerGst: acc.headerGst + safeNumber(Income.taxValue),
            headerWHT: acc.headerWHT + safeNumber(Income.whtAmount)
        }), { headerTotal: 0, headerGst: 0, headerWHT:0 });

        const totalGst = parseFloat((safeNumber(itemTotals.totalGst) + safeNumber(headerIncomeTotals.headerGst)).toFixed(2));
        const totalAmount = parseFloat(safeNumber(itemTotals.totalAmount).toFixed(2));
        const totalIncome = parseFloat(safeNumber(itemTotals.totalIncome).toFixed(2));
        const headerTotal = parseFloat(safeNumber(headerIncomeTotals.headerTotal).toFixed(2));
        const totalWHT = parseFloat(safeNumber(itemTotals.totalWHT).toFixed(2));

        $("#TotalQty").val(FormatNumber(parseFloat(itemTotals.totalQty).toPrecision(15)));
        $("#TotalAmount").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#TotalIncomeValue").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        $("#TotalGST").val(DecimalIndianRupees(safeNumber(itemTotals.totalGst).toFixed(2)));
        $("#TotalWHT").val(DecimalIndianRupees(totalWHT.toFixed(2)));

        const invoiceAmount = parseFloat((totalAmount + totalIncome + headerTotal + totalGst).toFixed(2));
        const WHtAmount = parseFloat((totalWHT + safeNumber(headerIncomeTotals.headerWHT)).toFixed(2));
        const total = parseFloat((invoiceAmount + WHtAmount).toFixed(2));
        const roundedValue = customRound(total);
        const rounded = parseFloat((roundedValue - total).toFixed(2));

        $("#SIH_MaterialCost").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#SIH_ItemMiscIncome").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        $("#SIH_HeaderMiscIncome").val(DecimalIndianRupees(headerTotal.toFixed(2)));
        $("#SIH_GST_Amount").val(DecimalIndianRupees(totalGst.toFixed(2)));
        $("#SIH_InvoiceAmount").val(DecimalIndianRupees(invoiceAmount.toFixed(2)));
        $("#SIH_WHT_Amount").val(DecimalIndianRupees(WHtAmount.toFixed(2)));
        $("#SIH_RoundOff").val(rounded.toFixed(2));
        $("#SIH_BuyerReceivable").val(DecimalIndianRupees(roundedValue.toFixed(2)));
    }

    // Main entry point
    async function CalculateAllIncomes() {
        try {
            await CalculateAll();
        } catch (error) {
            console.error("Error in calculation:", error);
        }
    }
    window.onload = CalculateAllIncomes();
</script>

