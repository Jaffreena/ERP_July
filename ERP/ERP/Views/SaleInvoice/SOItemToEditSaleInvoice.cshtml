                                    $ExistingRow.show();
                                }
                                else {
                                    IIncAddRow(SO);
                                }
                            }
                            else {
                                if (DeletedEx && !IIncAlreadyExists) {
                                    IIncAddRow(SO);
                                }
                                else if (DeletedEx && IIncAlreadyExists) {
                                    $ExistingRow.find("input.SII_INC_IsDeleted").val(0);
                                    $ExistingRow.show();
                                }
                            }
                            int++;
                        });
                    }
                    (async () => {
                        await CalculateAllIncomes();
                    })();
                    UnChecked();
                },
                error: function () {
                    (async () => {
                        await CalculateAllIncomes();
                    })();
                }
            });
        }

    }

