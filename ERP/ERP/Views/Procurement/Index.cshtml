<!-- Custom Context Menu -->
<div id="contextMenu" class="context-menu">
    <ul>
        <li data-action="view">View Details</li>
        <li data-action="edit">Edit Row</li>
        <li data-action="delete">Delete Row</li>
        <hr>
        <li data-action="copyCell">Copy Cell Text</li>
        <li data-action="copyRow">Copy Row Data</li>
    </ul>
</div>
<style>
    body {
        font-family: sans-serif;
        margin: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #f2f2f2;
    }

    tr:hover {
        background-color: #f9f9f9;
    }

    .action-btn {
        padding: 5px 10px;
        cursor: pointer;
    }

    /* Context Menu Styling */
    .context-menu {
        display: none; /* Hidden by default */
        position: absolute; /* Positioned relative to the viewport */
        background-color: #fff;
        border: 1px solid #ccc;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.15);
        min-width: 150px;
        z-index: 1000; /* Ensure it's on top */
        border-radius: 4px;
    }

        .context-menu ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

            .context-menu ul li {
                padding: 8px 12px;
                cursor: pointer;
                font-size: 14px;
            }

                .context-menu ul li:hover {
                    background-color: #f0f0f0;
                }

            .context-menu ul hr {
                margin: 4px 0;
                border: 0;
                border-top: 1px solid #eee;
            }
</style>
                    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const table = document.getElementById('myTable');
        const contextMenu = document.getElementById('contextMenu');
        let currentRow = null; // To store the row that was right-clicked
        let currentCell = null; // To store the cell that was right-clicked

        // --- Show Context Menu ---
        table.addEventListener('contextmenu', (event) => {
            event.preventDefault(); // Prevent default browser context menu

            const target = event.target; // The element that was clicked (td, th, button, etc.)

            // Find the closest <tr> and <td> if the click was on one
            const tr = target.closest('tr');
            const td = target.closest('td');

            if (!tr) return; // If not clicked inside a row, do nothing

            currentRow = tr;
            currentCell = td;

            // Position the menu
            // Adjust if menu would go off-screen
            const menuWidth = contextMenu.offsetWidth;
            const menuHeight = contextMenu.offsetHeight;
            const windowWidth = window.innerWidth;
            const windowHeight = window.innerHeight;

            let x = event.clientX;
            let y = event.clientY;

            if (x + menuWidth > windowWidth) {
                x = windowWidth - menuWidth - 5; // 5px buffer
            }
            if (y + menuHeight > windowHeight) {
                y = windowHeight - menuHeight - 5; // 5px buffer
            }

            contextMenu.style.top = `${y}px`;
            contextMenu.style.left = `${x}px`;
            contextMenu.style.display = 'block';
        });

        // --- Hide Context Menu ---
        // Hide when clicking anywhere else on the document
        document.addEventListener('click', (event) => {
            // Hide if the click is outside the context menu
            if (contextMenu.style.display === 'block' && !contextMenu.contains(event.target)) {
                contextMenu.style.display = 'none';
                currentRow = null;
                currentCell = null;
            }
        });

        // Hide on 'Escape' key press
        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape' && contextMenu.style.display === 'block') {
                contextMenu.style.display = 'none';
                currentRow = null;
                currentCell = null;
            }
        });


        // --- Handle Context Menu Item Clicks ---
        contextMenu.addEventListener('click', (event) => {
            const action = event.target.dataset.action;

            if (action && currentRow) {
                const rowId = currentRow.dataset.id;
                const cells = Array.from(currentRow.cells).map(cell => cell.textContent.trim());

                switch (action) {
                    case 'view':
                        alert(`Viewing details for Row ID: ${rowId}\nName: ${cells[1]}\nEmail: ${cells[2]}`);
                        break;
                    case 'edit':
                        alert(`Editing Row ID: ${rowId}. Implement your edit logic here.`);
                        // Example: You could make cells editable or open a modal
                        break;
                    case 'delete':
                        if (confirm(`Are you sure you want to delete Row ID: ${rowId}?`)) {
                            currentRow.remove(); // Remove the row from the DOM
                            alert(`Row ID: ${rowId} deleted.`);
                            // You might also want to make an API call here to delete from the server
                        }
                        break;
                    case 'copyCell':
                        if (currentCell) {
                            navigator.clipboard.writeText(currentCell.textContent.trim())
                                .then(() => alert(`Cell text copied: "${currentCell.textContent.trim()}"`))
                                .catch(err => console.error('Failed to copy cell text: ', err));
                        } else {
                            alert("No specific cell was targeted for copy.");
                        }
                        break;
                    case 'copyRow':
                        const rowData = cells.join('\t'); // Tab-separated for easy pasting into spreadsheets
                        navigator.clipboard.writeText(rowData)
                            .then(() => alert(`Row data copied:\n${rowData}`))
                            .catch(err => console.error('Failed to copy row data: ', err));
                        break;
                    default:
                        console.warn('Unknown action:', action);
                }
                contextMenu.style.display = 'none'; // Hide menu after action
                currentRow = null;
                currentCell = null;
            }
        });

        // Optional: Handle clicks on regular action buttons in the table
        table.addEventListener('click', (event) => {
            if (event.target.classList.contains('action-btn')) {
                const tr = event.target.closest('tr');
                if (tr) {
                    const rowId = tr.dataset.id;
                    alert(`Regular button clicked for Row ID: ${rowId}`);
                }
            }
        });
    });
