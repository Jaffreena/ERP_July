        </table>
    </div>

    <!-- 2. Load the colResizable jQuery plugin -->
    <script src="https://cdn.jsdelivr.net/npm/colresizable@1.6.0/colResizable-1.6.min.js"></script>

    <!-- 3. Initialize the plugin on your table -->
    <script>
        $(document).ready(function () {
            $(".resizable-table").colResizable({
                liveDrag: true,
                gripInnerHtml: "<div class='grip-handle'></div>",
                minWidth: 50
            });
        });
    </script>
