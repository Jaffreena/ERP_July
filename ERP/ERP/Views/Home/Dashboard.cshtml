    <!-- --- THIS IS THE CRITICAL CSS FIX --- -->
    <style>
        /* Style the main grip container created by the library */
        .JCLRgrip {
            /* Give it a height and position it correctly */
            height: 100%;
            top: 0;
            z-index: 10; /* Ensure it's on top of the header content */
        }

        /* Style the custom inner handle that you defined */
        .grip-handle {
            /* This is what you will SEE and DRAG */
            width: 8px; /* Make it thick enough to grab */
            height: 50%; /* Make it shorter than the full header height */
            background-color: #0d6efd; /* A visible color, like Bootstrap blue */
            border-left: 1px solid #0a58ca;
            border-right: 1px solid #0a58ca;
            margin-top: 25%; /* Vertically center the handle within the header */
        }

        /* Optional: Change the mouse cursor when hovering over the grip */
        .JCLRgrip:hover {
            cursor: col-resize;
        }
    </style>

    <div class="container mt-4">

        <table class="table table-bordered resizable-table" id="resizable-table">
            <thead>
