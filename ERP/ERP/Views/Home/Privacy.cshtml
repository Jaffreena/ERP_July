<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Expandable Table Input</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            color: #333;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }

        .container {
            width: 100%;
            max-width: 1000px;
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            padding: 30px;
            margin-top: 20px;
        }

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 10px;
            font-size: 2.5rem;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }

        .subtitle {
            text-align: center;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 30px;
            font-size: 1.1rem;
        }

        .description {
            margin-bottom: 25px;
            line-height: 1.6;
            color: #555;
            text-align: center;
        }

        .table-container {
            overflow-x: auto;
            margin-bottom: 30px;
            border-radius: 8px;
            border: 1px solid #e0e0e0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        th {
            background-color: #4a90e2;
            color: white;
            padding: 15px;
            text-align: left;
            font-weight: 600;
        }

        tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        tr:hover {
            background-color: #f0f7ff;
        }

        td {
            padding: 12px 15px;
            border-bottom: 1px solid #e0e0e0;
        }

        .expandable-input {
            width: 100%;
            min-width: 120px;
            max-width: 400px;
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 16px;
            transition: all 0.3s ease;
        }

            .expandable-input:focus {
                border-color: #4a90e2;
                box-shadow: 0 0 0 2px rgba(74, 144, 226, 0.2);
                outline: none;
            }

        .expanded {
            width: auto;
        }

        .character-count {
            font-size: 12px;
            color: #888;
            margin-top: 5px;
        }

        .controls {
            display: flex;
            justify-content: space-between;
            margin-top: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        button {
            padding: 12px 25px;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-primary {
            background-color: #4a90e2;
            color: white;
        }

            .btn-primary:hover {
                background-color: #3a7bc8;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            }

        .btn-secondary {
            background-color: #f5f5f5;
            color: #555;
        }

            .btn-secondary:hover {
                background-color: #e0e0e0;
            }

        .example {
            margin-top: 40px;
            padding: 20px;
            background-color: #f9f9f9;
            border-radius: 8px;
            border-left: 4px solid #4a90e2;
        }

            .example h3 {
                margin-bottom: 10px;
                color: #333;
            }

            .example p {
                margin-bottom: 15px;
                line-height: 1.5;
            }

       
    </style>
</head>
<body>
    <h1>Expandable Table Input</h1>
    <p class="subtitle">Table inputs that expand based on content length</p>

    <div class="container">
        <p class="description">
            This demo shows a table with text inputs that automatically expand in width as you type more content.
            Try typing in any field to see how it dynamically adjusts to fit your text.
        </p>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>001</td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter name" value="John Smith">
                            <div class="character-count">10/50</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter email" value="john.smith@example.com">
                            <div class="character-count">24/100</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter department" value="Engineering">
                            <div class="character-count">11/30</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter notes" value="Team lead for Project X">
                            <div class="character-count">24/200</div>
                        </td>
                    </tr>
                    <tr>
                        <td>002</td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter name" value="Sarah Johnson">
                            <div class="character-count">13/50</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter email" value="sarah.j@company.org">
                            <div class="character-count">22/100</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter department" value="Marketing">
                            <div class="character-count">9/30</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter notes" value="Working on Q4 campaign">
                            <div class="character-count">24/200</div>
                        </td>
                    </tr>
                    <tr>
                        <td>003</td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter name">
                            <div class="character-count">0/50</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter email">
                            <div class="character-count">0/100</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter department">
                            <div class="character-count">0/30</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter notes">
                            <div class="character-count">0/200</div>
                        </td>
                    </tr>
                    <tr>
                        <td>004</td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter name">
                            <div class="character-count">0/50</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter email">
                            <div class="character-count">0/100</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter department">
                            <div class="character-count">0/30</div>
                        </td>
                        <td>
                            <input type="text" class="expandable-input" placeholder="Enter notes">
                            <div class="character-count">0/200</div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="controls">
            <button class="btn-secondary" id="resetBtn">Reset All Fields</button>
            <button class="btn-primary" id="submitBtn">Save Data</button>
            <button class="btn-secondary" id="addRowBtn">Add New Row</button>
        </div>

        <div class="example">
            <h3>How It Works</h3>
            <p>Each input field in the table will expand horizontally when:</p>
            <ul>
                <li>You type content that exceeds the initial width</li>
                <li>The input automatically adjusts its width based on content length</li>
                <li>There's a maximum width limit to prevent over-expansion</li>
            </ul>
            <p>This provides a better user experience for table-based data entry with variable-length content.</p>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('.expandable-input');
            const resetBtn = document.getElementById('resetBtn');
            const submitBtn = document.getElementById('submitBtn');
            const addRowBtn = document.getElementById('addRowBtn');
            const tableBody = document.querySelector('tbody');
            let rowCount = 4;

            // Function to update input width based on content
            function updateInputWidth(input) {
                // Create a temporary span to measure text width
                const tempSpan = document.createElement('span');
                tempSpan.style.visibility = 'hidden';
                tempSpan.style.whiteSpace = 'pre';
                tempSpan.style.font = window.getComputedStyle(input).font;
                tempSpan.textContent = input.value || input.placeholder;

                document.body.appendChild(tempSpan);
                const textWidth = tempSpan.offsetWidth;
                document.body.removeChild(tempSpan);

                // Set input width (with min and max constraints)
                const newWidth = Math.max(120, Math.min(400, textWidth + 30));
                input.style.width = newWidth + 'px';

                // Update character count
                const charCount = input.nextElementSibling;
                const maxLength = getMaxLength(input);
                charCount.textContent = `${input.value.length}/${maxLength}`;

                // Change color when approaching limit
                if (input.value.length > maxLength * 0.8) {
                    charCount.style.color = '#e74c3c';
                } else {
                    charCount.style.color = '#888';
                }
            }

            // Function to get max length based on input position
            function getMaxLength(input) {
                const cellIndex = input.closest('td').cellIndex;
                switch(cellIndex) {
                    case 1: return 50;   // Name
                    case 2: return 100;  // Email
                    case 3: return 30;   // Department
                    case 4: return 200;  // Notes
                    default: return 100;
                }
            }

            // Initialize all inputs
            inputs.forEach(input => {
                updateInputWidth(input);

                // Update on input
                input.addEventListener('input', function() {
                    updateInputWidth(this);
                });

                // Add focus effect
                input.addEventListener('focus', function() {
                    this.style.borderColor = '#4a90e2';
                    this.style.boxShadow = '0 0 0 2px rgba(74, 144, 226, 0.2)';
                });

                input.addEventListener('blur', function() {
                    this.style.borderColor = '#ddd';
                    this.style.boxShadow = 'none';
                });
            });

            // Reset button functionality
            resetBtn.addEventListener('click', function() {
                inputs.forEach(input => {
                    input.value = '';
                    updateInputWidth(input);
                });
            });

            // Submit button functionality
            submitBtn.addEventListener('click', function() {
                let isValid = true;

                inputs.forEach(input => {
                    if (input.value.trim() === '') {
                        input.style.borderColor = '#e74c3c';
                        isValid = false;
                    } else {
                        input.style.borderColor = '#2ecc71';
                    }
                });

                if (isValid) {
                    alert('Data saved successfully!');
                } else {
                    alert('Please fill in all fields.');
                }
            });

            // Add row button functionality
            addRowBtn.addEventListener('click', function() {
                rowCount++;
                const newRow = document.createElement('tr');

                newRow.innerHTML = `
                    <td>${String(rowCount).padStart(3, '0')}</td>
                    <td>
                        <input type="text" class="expandable-input" placeholder="Enter name">
                        <div class="character-count">0/50</div>
                    </td>
                    <td>
                        <input type="text" class="expandable-input" placeholder="Enter email">
                        <div class="character-count">0/100</div>
                    </td>
                    <td>
                        <input type="text" class="expandable-input" placeholder="Enter department">
                        <div class="character-count">0/30</div>
                    </td>
                    <td>
                        <input type="text" class="expandable-input" placeholder="Enter notes">
                        <div class="character-count">0/200</div>
                    </td>
                `;

                tableBody.appendChild(newRow);

                // Add event listeners to new inputs
                const newInputs = newRow.querySelectorAll('.expandable-input');
                newInputs.forEach(input => {
                    updateInputWidth(input);

                    input.addEventListener('input', function() {
                        updateInputWidth(this);
                    });

                    input.addEventListener('focus', function() {
                        this.style.borderColor = '#4a90e2';
                        this.style.boxShadow = '0 0 0 2px rgba(74, 144, 226, 0.2)';
                    });

                    input.addEventListener('blur', function() {
                        this.style.borderColor = '#ddd';
                        this.style.boxShadow = 'none';
                    });
                });
            });
        });
    </script>
</body>
</html>