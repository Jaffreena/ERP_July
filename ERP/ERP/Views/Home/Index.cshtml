@model ERP_DTO.UserLog_DTO

<div class="row">
    <div class="col-12 col-md-6 offset-md-3 col-lg-4 offset-lg-4 pt-5">
        <div class="row">
            <div class="col-12 col-xxl-10 offset-xxl-1">
                <div class="card w-100 overflow-hidden shadow">
                    <div class="card-body position-relative p-5">
                        <div class="row">
                            <div class="col-12 text-center">
                                <img src="~/img/logo.png" class="img-fluid" alt="logo" style="max-height:40px;">
                                @*                         <h1 class="h3 lh-1 pt-3">Get Started Now</h1>
                                <p class="mb-0 fw-semibold">Enter your credentials to login your account</p>
                                *@
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 pt-4">
                                <form asp-action="Index">
                                    <div class="mb-3">
                                        <label asp-for="Username" class="control-label pb-1"></label>
                                        <input asp-for="Username" class="form-control" />
                                        <span asp-validation-for="Username" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <label asp-for="Password" class="control-label pb-1"></label>
                                        <input asp-for="Password" class="form-control" />
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                    <div class="mb-3">
                                        <button type="submit" class="btn btn-primary w-100">Login</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
