    async function CalculateAll() {
        const $newRows = $("tr.NewRow");
        const $exNewRows = $("tr.ExNewRow");
        const $iExNewRows = $("tr.IExNewRow");
        const cluster = $("#PIH_TaxCluster_Number").val() || $("#PIH_TaxClusterNumber").val();
        const grnDate = $("#PIH_InvoiceDate").val();
        const whNumber = $("#PIH_WHT_Number").val();

        // Pre-calculate values that don't change during iteration
        const whTax = whNumber ? $("#PIH_WHT_Tax").val() : "1";
        const whPercent = whNumber ? $("#PIH_WHT_Percent").val() : 0;

        // Process items and expenses in parallel
        const [itemResults, headerExpenseResults] = await Promise.all([
            processItems($newRows, $iExNewRows, cluster, grnDate, whTax, whPercent),
            processHeaderExpenses($exNewRows, $newRows, cluster, grnDate)
        ]);

        // Calculate footer with all results
        await calculateFooter(itemResults, headerExpenseResults);
    }

    async function processItems($newRows, $iExNewRows, cluster, grnDate, whTax, whPercent) {
        const itemPromises = [];
        const itemExpenseMap = new Map();

        // Pre-calculate item expenses
        $iExNewRows.each(function() {
            const $row = $(this);
            if ($row.find("input.PII_EXP_IsDeleted").val() === 'true') return;

            const poiNumber = $row.find("input.PII_EXP_POI_Number").val();
            const pohNumber = $row.find("input.PII_EXP_POH_Number").val();
            const key = `${pohNumber}-${poiNumber}`;

            if (!itemExpenseMap.has(key)) {
                itemExpenseMap.set(key, []);
            }

            itemExpenseMap.get(key).push({
                expenseBase: parseFloat(removeCommas($row.find("input.PII_EXP_ExpenseBase").val())) || 0,
                charge: $row.find("select.PII_EXP_CM_Number").val(),
                row: $row
            });
        });

        // Process each item row
        $newRows.each(function() {
            const $row = $(this);
            if ($row.find('input.PII_IsDeleted').val() === "true") return;

            const promise = processSingleItem($row, itemExpenseMap, cluster, grnDate, whTax, whPercent);
            itemPromises.push(promise);
        });

        return Promise.all(itemPromises);
    }

    async function processSingleItem($row, itemExpenseMap, cluster, grnDate, whTax, whPercent) {
        const pohNumber = $row.find('input.PII_POH_Number').val();
        const poiNumber = $row.find('input.PII_POI_Number').val();
        const key = `${pohNumber}-${poiNumber}`;
        const hsnNumber = $row.find('.PII_HSN_Number').val();

        const qty = parseFloat(removeCommas($row.find('input.PII_Qty').val())) || 0;
        const unitPrice = parseFloat(removeCommas($row.find('input.PII_UnitPrice').val())) || 0;
        const materialValue = qty * unitPrice;

        // Calculate amount
        $row.find("input.PII_Amount").val(DecimalIndianRupees(materialValue));

        // Process item expenses
        let expenseTotal = 0;
        const itemExpenses = itemExpenseMap.get(key) || [];

        for (const expense of itemExpenses) {
            let expenseValue = 0;

            switch (expense.charge) {
                case "1":
                    expenseValue = expense.expenseBase;
                    break;
                case "2":
                    expenseValue = qty * expense.expenseBase;
                    break;
                case "3":
                    expenseValue = materialValue * expense.expenseBase / 100;
                    break;
            }
            expenseValue = parseFloat(parseFloat(expenseValue).toFixed(2));
            expense.row.find("input.PII_EXP_ExpenseValue").val(DecimalIndianRupees(expenseValue));
            expenseTotal += parseFloat(expenseValue);
        }

        $row.find("input.PII_ExpenseValue").val(DecimalIndianRupees(expenseTotal));

        // Calculate GST and WHT
        const baseAmount = materialValue + expenseTotal;
        let gstAmount = 0;
        let whtAmount = 0;

        if (cluster) {
            gstAmount = await GetClusterAmount(cluster, grnDate, hsnNumber, baseAmount);
            gstAmount = parseFloat(parseFloat(gstAmount).toFixed(2));
            $row.find("input.PII_GST_Amount").val(DecimalIndianRupees(gstAmount));

            const totalAmount = whTax === "1" ? baseAmount + gstAmount : baseAmount;
            whtAmount = -(totalAmount * whPercent / 100);
            whtAmount = parseFloat(parseFloat(whtAmount).toFixed(2));

            $row.find("input.PII_WHT_Percent").val(DecimalIndianRupees(whPercent));
            $row.find("input.PII_WHT_Amount").val(DecimalIndianRupees(whtAmount));
        }

        // Process batches if needed
        await CalculateIBatch($row);

        return {
            poQty: parseFloat(removeCommas($row.find('.PII_POQty').val())) || 0,
            qty: qty,
            amount: materialValue,
            expense: expenseTotal,
            gst: gstAmount,
            wht: whtAmount
        };
    }

    async function processHeaderExpenses($exNewRows, $newRows, cluster, grnDate) {
        const promises = [];

        $exNewRows.each(function() {
            const $row = $(this);
            if ($row.find("input.PIH_EXP_IsDeleted").val() === "true") return;

            promises.push(processHeaderExpense($row, $newRows, cluster, grnDate));
        });

        return Promise.all(promises);
    }

    async function processHeaderExpense($row, $newRows, cluster, grnDate) {
        const pohNumber = $row.find("input.PIH_EXP_POH_Number").val();
        const charge = $row.find("select.PIH_EXP_CM_Number").val();
        const isGst = $row.find("select.PIH_EXP_TaxCalculate").val();
        const expenseBase = parseFloat(removeCommas($row.find("input.PIH_EXP_ExpenseBase").val())) || 0;

        const items = $newRows.map(function() {
            const $irow = $(this);
            if ($irow.find(".PII_POH_Number").val() === pohNumber &&
                $irow.find("input.PII_IsDeleted").val() !== 'true') {
                return {
                    qty: parseFloat(removeCommas($irow.find(".PII_Qty").val())) || 0,
                    amount: parseFloat(removeCommas($irow.find(".PII_Amount").val())) || 0
                };
            }
            return null;
        }).get().reduce((acc, item) => ({
            itemQty: acc.itemQty + item.qty,
            itemAmount: acc.itemAmount + item.amount
        }), { itemQty: 0, itemAmount: 0 });

        let expenseValue = 0;
        switch (charge) {
            case "1": expenseValue = expenseBase; break;
            case "2": expenseValue = items.itemQty * expenseBase; break;
            case "3": expenseValue = items.itemAmount * expenseBase / 100; break;
        }
        expenseValue = parseFloat(parseFloat(expenseValue).toFixed(2));
        $row.find("input.PIH_EXP_ExpenseValue").val(DecimalIndianRupees(expenseValue));

        let taxValue = 0;
        if (isGst === "2" && cluster) {
            const sacNumber = $row.find("input.PIH_EXP_SAC_Number").val();
            taxValue = await GetClusterExpenseAmount(cluster, grnDate, sacNumber, expenseValue);
        }
        taxValue = parseFloat(parseFloat(taxValue).toFixed(2));
        $row.find("input.PIH_EXP_TaxValue").val(DecimalIndianRupees(taxValue));

        return { expenseValue, taxValue };
    }

        // Utility function for safe number operations
    function safeNumber(value, defaultValue = 0) {
        const num = parseFloat(value);
        return isNaN(num) ? defaultValue : num;
    }

    async function calculateFooter(itemResults, headerExpenseResults) {
        // Use safe number handling
        const itemTotals = itemResults.reduce((acc, item) => ({
            totalPOQty: acc.totalPOQty + safeNumber(item.poQty),
            totalQty: acc.totalQty + safeNumber(item.qty),
            totalAmount: acc.totalAmount + safeNumber(item.amount),
            totalExpense: acc.totalExpense + safeNumber(item.expense),
            totalGst: acc.totalGst + safeNumber(item.gst),
            totalWHT: acc.totalWHT + safeNumber(item.wht)
        }), { totalPOQty: 0, totalQty: 0, totalAmount: 0, totalExpense: 0, totalGst: 0, totalWHT: 0 });

        const headerExpenseTotals = headerExpenseResults.reduce((acc, expense) => ({
            headerTotal: acc.headerTotal + safeNumber(expense.expenseValue),
            headerGst: acc.headerGst + safeNumber(expense.taxValue)
        }), { headerTotal: 0, headerGst: 0 });

        const totalGst = parseFloat((safeNumber(itemTotals.totalGst) + safeNumber(headerExpenseTotals.headerGst)).toFixed(2));
        const totalAmount = parseFloat(safeNumber(itemTotals.totalAmount).toFixed(2));
        const totalExpense = parseFloat(safeNumber(itemTotals.totalExpense).toFixed(2));
        const headerTotal = parseFloat(safeNumber(headerExpenseTotals.headerTotal).toFixed(2));
        const totalWHT = parseFloat(safeNumber(itemTotals.totalWHT).toFixed(2));

        $("#TotalPOQty").val(FormatNumber(parseFloat(itemTotals.totalPOQty).toFixed(2)));
        $("#TotalQty").val(FormatNumber(parseFloat(itemTotals.totalQty).toPrecision(15)));
        $("#TotalAmount").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#TotalExpenseValue").val(DecimalIndianRupees(totalExpense.toFixed(2)));
        $("#TotalGST").val(DecimalIndianRupees(totalGst.toFixed(2)));
        $("#TotalWHT").val(DecimalIndianRupees(totalWHT.toFixed(2)));

        const invoiceAmount = parseFloat((totalAmount + totalExpense + headerTotal + totalGst).toFixed(2));
        const total = parseFloat((invoiceAmount + totalWHT).toFixed(2));
        const roundedValue = customRound(total);
        const rounded = parseFloat((roundedValue - total).toFixed(2));

        $("#PIH_MaterialCost").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#PIH_ItemMiscExpense").val(DecimalIndianRupees(totalExpense.toFixed(2)));
        $("#PIH_HeaderMiscExpense").val(DecimalIndianRupees(headerTotal.toFixed(2)));
        $("#PIH_GST_Amount").val(DecimalIndianRupees(totalGst.toFixed(2)));
        $("#PIH_InvoiceAmount").val(DecimalIndianRupees(invoiceAmount.toFixed(2)));
        $("#PIH_WHT_Amount").val(DecimalIndianRupees(totalWHT.toFixed(2)));
        $("#PIH_RoundOff").val(rounded.toFixed(2));
        $("#PIH_VendorPayable").val(DecimalIndianRupees(roundedValue.toFixed(2)));
    }

    // Main entry point - call this instead of all individual functions
    async function CalculateAllExpenses() {
        try {
            await CalculateAll();
        } catch (error) {
            console.error("Error in calculation:", error);
        }
    }
