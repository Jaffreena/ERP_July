                    DisplayedPO.push(PONumberInRow);
                }
            }
        });

        const UniqueDisplayedPO = [...new Set(DisplayedPO)];

        let DisplayedExPO = [];
        $("tr.ExNewRow").each(function () {
            const PONumberInRow = $(this).find(".PIH_EXP_POH_Number").val();
            if (PONumberInRow) {
                DisplayedExPO.push(PONumberInRow);
            }
        });

        const ExPOToRemove = DisplayedExPO.filter(PO => !UniqueDisplayedPO.includes(PO));
        const ExUniquePOToRemove = [...new Set(ExPOToRemove)];

        ExUniquePOToRemove.forEach(PONumberToRemove => {
            let $ExistingRow = $("tr.ExNewRow").filter(function () {
                return $(this).find(".PIH_EXP_POH_Number").val() === PONumberToRemove;
            });

            let EXAlreadyExists = $ExistingRow.length > 0;

            if (EXAlreadyExists) {
                $ExistingRow.find("input.PIH_EXP_IsDeleted").val("true");
                $ExistingRow.hide();
            }
        });



        let DisplayedIExPO = [];
        $("tr.IExNewRow").each(function () {
            const PONumberInRow = $(this).find(".PII_EXP_POH_Number").val();
            if (PONumberInRow) {
                DisplayedIExPO.push(PONumberInRow);
            }
        });

        const IExPOToRemove = DisplayedIExPO.filter(PO => !UniqueDisplayedPO.includes(PO));
        const IExUniquePOToRemove = [...new Set(IExPOToRemove)];

        IExUniquePOToRemove.forEach(PONumberToRemove => {
            let $ExistingRow = $("tr.IExNewRow").filter(function () {
                return $(this).find(".PII_EXP_POH_Number").val() === PONumberToRemove;
            });

            let EXAlreadyExists = $ExistingRow.length > 0;

            if (EXAlreadyExists) {
                $ExistingRow.find("input.PII_EXP_IsDeleted").val("true");
                $ExistingRow.hide();
            }
        });
    }

