    function POExRemove() {
        let DisplayedPO = [];
        $("tr.NewRow").each(function () {
            var PIDeleteInRow = $(this).find(".PII_IsDeleted").val();
            if (PIDeleteInRow == "false") {
                const PONumberInRow = $(this).find(".PII_POH_Number").val();
