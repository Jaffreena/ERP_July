<script>
    $('form').submit(function (event) {
        $("tr.ExNewRow").each(function () {
            var ExpenseCode = $(this).find("select.PIH_EXP_Expense_Number").val();
            var Occurrence = $(this).find("select.PIH_EXP_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.PIH_EXP_CM_Number").val();
            var ExpenseBase = removeCommas($(this).find("input.PIH_EXP_ExpenseBase").val());
            var Allocate = $(this).find("select.PIH_EXP_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.PIH_EXP_LA_Number").val();

            if (!ExpenseCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(ExpenseBase > 0)) {
                $(this).find("input.PIH_EXP_IsDeleted").val("true");
                $(this).hide();
            }
        });
        $("tr.IExNewRow").each(function () {
            var ExpenseCode = $(this).find("select.PII_EXP_Expense_Number").val();
            var Occurrence = $(this).find("select.PII_EXP_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.PII_EXP_CM_Number").val();
            var ExpenseBase = removeCommas($(this).find("input.PII_EXP_ExpenseBase").val());
            var Allocate = $(this).find("select.PII_EXP_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.PII_EXP_LA_Number").val();

            if (!ExpenseCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(ExpenseBase > 0)) {
                $(this).find("input.PII_EXP_IsDeleted").val("true");
                $(this).hide();
            }
        });

        $("tr.NewRow").each(function () {
            var ItemNumber = $(this).find("input.PII_Item_Number").val();
            var Qty = removeCommas($(this).find("input.PII_Qty").val());
            var UnitPrice = removeCommas($(this).find("input.PII_UnitPrice").val());
            var UoMNumber = $(this).find("select.PII_UoM_Number").val();

            if (!ItemNumber && !UoMNumber && !(Qty > 0) && !(UnitPrice > 0)) {
                $(this).find("input.IsDeleted").val("true");
                $(this).hide();
            }
        });

        $('select').prop('disabled', false);
    });

    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.PII_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(decimalPlaces)) decimalPlaces = 2;
        $(this).val(NumberToIndianRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.PII_DecimalPlaces").val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(NumberToIndianRupees(value, decimalPlaces));
        }
    });
    $(document).on("input", ".QtyNumbers", function () {
        var $this = $(this);
        var decimalPlaces = parseInt($this.closest("tr").find("input.PII_DecimalPlaces").val(), 10);
        if (isNaN(decimalPlaces)) decimalPlaces = 2;

        let clean = $this.val()
            .replace(/-/g, "")
            .replace(/[^0-9.]/g, "");

        const firstDot = clean.indexOf(".");
        if (firstDot !== -1) {
            clean =
                clean.substring(0, firstDot + 1) +
                clean.substring(firstDot + 1).replace(/\./g, "");
        }

        if (decimalPlaces > 0 && firstDot !== -1) {
            const parts = clean.split(".");
            if (parts[1].length > decimalPlaces) {
                parts[1] = parts[1].slice(0, decimalPlaces);
                clean = parts.join(".");
            }
        }

        $this.val(clean);
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });


    function OnVendorInput(inputElement) {
        SearchVendor(inputElement);
    }
    function OnVendorFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchVendor(inputElement);
        }
        else {
            $(this).select();
        }
    }
    async function SearchVendor(inputElement) {
        var vendor = inputElement.value;
        var GRNDate = $("#PIH_InvoiceDate").val();
        var resultsDiv = $(inputElement).next('.vendor-search-results');
        var isChecked = $("#PIH_ImportOrder").prop("checked");
        var Import;

        if (isChecked) {
            Import = true;
        } else {
            Import = false;
        }

        $.ajax({
            url: 'vendor',
            data: { Vendor: vendor, GRNDate: GRNDate, Import: Import },
            type: 'GET',
            success: function (data) {
                resultsDiv.empty();
                if (data && data.length > 0) {
                    resultsDiv.show();
                    var table = $('<div class="card-body modal-content"><table class="table table-bordered mb-0 table-hover"><thead><tr class="table-info"><th>Vendor Code</th><th>Vendor Name</th><th>Currency</th></tr></thead><tbody></tbody></table></div>');
                    data.forEach(function (ven) {
                        var row = $('<tr></tr>');
                        row.append('<td>' + ven.vendorCode + '</td>');
                        row.append('<td>' + ven.vendorName + '</td>');
                        row.append('<td>' + ven.currencyCode + '</td>');
                        table.find('tbody').append(row);

                        row.on('click', function () {
                            var vengo = 0;
                            var vendorna = ven.vendorName;
                            var vendor = $("#PIHVendor").val();
                            if (vendor == '') {
                                vengo = 1;
                            }
                            else if (vendor === vendorna) {
                                vengo = 1;
                            }
                            else {
                                let rowCount = $("tr.NewRow").length;
                                if (rowCount > 0) {
                                    if (confirm("Do you want to change the Vendor Name? This action will clear all existing items.")) {

                                        $("tr.NewRow").each(function () {
                                            $(this).remove();
                                        });
                                        $("tr.ExNewRow").each(function () {
                                            $(this).remove();
                                        });
                                        $("tr.IExNewRow").each(function () {
                                            $(this).remove();
                                        });

                                        vengo = 1;
                                    }
                                    else {
                                        $(inputElement).val(vendor);
                                    }
                                }
                                else { vengo = 1; }
                            }

                            if (vengo === 1) {
                                $(inputElement).val(ven.vendorName);
                                $("#PIHVendor").val(ven.vendorName);
                                $("#PIH_Vendor_Number").val(ven.vendorNumber);
                                $("#PIH_Currency").val(ven.currencyCode);
                                $("#PIH_Currency_Number").val(ven.currency);
                                $("#PIH_VendorLocation").val(ven.vendorLocation);
                                $("#PIH_WHT_Number").val(ven.withholdTax);
                                $("#PIH_CreditDays").val(ven.creditDays);
                                $("#PIH_PaymentBase").val(ven.paymentBase);

                                resultsDiv.hide();

                                SearchClustor(ven.vendorNumber, ven.taxNumber);
                                GetWHT(ven.vendorNumber, ven.withholdTax, GRNDate);

                                if (ven.paymentBase === 2) {
                                    var Date = $("#PIH_InvoiceDate").val();
                                    var Credit = $("#PIH_CreditDays").val();

                                    if (Date == '') { } else {
                                        var CurentDate = addDays(Date, Credit);
                                        $("#PIH_DueDate").val(CurentDate);
                                    }
                                }
                                else if (ven.paymentBase === 3) {
                                    var Date = $("#PIH_SupplierInvoiceDate").val();
                                    var Credit = $("#PIH_CreditDays").val();
                                    if (Date == '') { } else {
                                        var CurentDate = addDays(Date, Credit);
                                        $("#PIH_DueDate").val(CurentDate);
                                    }
                                }
                                else {
                                    $("#PIH_DueDate").val("");
                                }

                                SearchInvoice();
                            }
                            resultsDiv.hide();
                        });
                    });

                    var closeButton = $('<div class="card-header bg-primary py-1"><button type="button" class="p-0 float-end btn btn-sm btn-primary bg-opacity-10"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16"><path d = "M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"> </path></svg></button></div>');
                    closeButton.on('click', function () {
                        resultsDiv.hide();
                    });

                    resultsDiv.append(closeButton);
                    resultsDiv.append(table);
                } else {
                    resultsDiv.hide();
                    resultsDiv.append('<p>No results found</p>');
                }
            },
            error: function () {
                resultsDiv.text('Error loading data.');
                resultsDiv.show();
            }
        });
    }


    $(".decimal").each(function () {
        var value = $(this).val();
        $(this).val(DecimalIndianRupees(removeCommas(value)));
    });
    $(document).on("blur", ".decimal", function () {
        var value = $(this).val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0.00");
        } else {
            $(this).val(DecimalIndianRupees(removeCommas(value)));
        }
    });
    $(document).on("focus", ".decimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    $(document).on('change', "#PIH_SupplierInvoiceDate", function () {
        var paymentBase = $("#PIH_PaymentBase").val();

        if (paymentBase === "2") {
            var Date = $("#PIH_InvoiceDate").val();
            var Credit = $("#PIH_CreditDays").val();

            if (Date == '') { } else {
                var CurentDate = addDays(Date, Credit);
                $("#PIH_DueDate").val(CurentDate);
            }
        }
        else if (paymentBase === "3") {
            var Date = $("#PIH_SupplierInvoiceDate").val();
            var Credit = $("#PIH_CreditDays").val();

            if (Date == '') { } else {
                var CurentDate = addDays(Date, Credit);
                console.log("CurentDate", CurentDate);
                $("#PIH_DueDate").val(CurentDate);
            }
        }
        else {
            $("#PIH_DueDate").val("");
        }
    });


    function OnClustorInput(inputElement) {
        SearchClustor(inputElement);
    }
    function OnClustorFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchClustor(inputElement);
        }
        else {
            $(this).select();
        }
    }
    function SearchClustor(Vendor, taxNumber) {
        if (Vendor) {
            $.ajax({
                url: 'cluster',
                data: { Vendor: Vendor },
                type: 'GET',
                success: function (data) {
                    if (data && data.length > 0) {
                        var dropdown = document.getElementById("PIH_TaxCluster_Number");
                        dropdown.innerHTML = "";

                        var option = document.createElement("option");
                        option.value = "";
                        option.text = "";
                        dropdown.appendChild(option);

                        data.forEach(function (item) {
                            var option = document.createElement("option");
                            option.value = item.taxClusterNumber;
                            option.text = item.taxCluster;
                            dropdown.appendChild(option);
                        });

                        if (taxNumber) {
                            $("#PIH_TaxCluster_Number").val(taxNumber);
                        }
                        else {
                            AssignGST();
                        }
                    }
                },
                error: function () {
                    resultsDiv.text('Error loading data.');
                    resultsDiv.show();
                }
            });
        }
    }


    function addDays(date, days) {
        const dateAfterAddingDays = new Date(date);
        dateAfterAddingDays.setDate(dateAfterAddingDays.getDate() + parseInt(days));

        const day = dateAfterAddingDays.getDate().toString().padStart(2, '0');
        const year = dateAfterAddingDays.getFullYear();
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
            "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        const monthAbbr = monthNames[dateAfterAddingDays.getMonth()];

        const result = `${day}-${monthAbbr}-${year}`;
        return result;
    }

