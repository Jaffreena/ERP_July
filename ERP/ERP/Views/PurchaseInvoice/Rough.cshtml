@model List<ERP_DTO.PurchaseInvoiceBatch_DTO>

<!-- ========================================================= -->
<!-- 1. UI TABLE STRUCTURE -->
<!-- ========================================================= -->

<div class="w-100 table-responsive">
    <table class="table table-bordered table-hover align-middle table-grid mb-0">

        <!-- 1.1 TABLE HEADER -->
        <!-- Tamil: இது Table Header -->
        <!-- English: This defines table column headings -->
        <thead>
            <tr class="table-info">
                <th class="datetype text-center">@Html.DisplayNameFor(M => M.First().PII_BCH_Date)</th>
                <th>@Html.DisplayNameFor(M => M.First().PII_BCH_No)</th>
                <th class="table-width-xl text-end">@Html.DisplayNameFor(M => M.First().PII_BCH_Qty)</th>
                <th class="table-width-xl text-end">@Html.DisplayNameFor(M => M.First().PII_BCH_UnitPrice)</th>
                <th class="table-width-3xl text-end">@Html.DisplayNameFor(M => M.First().PII_BCH_Value)</th>
                <th class="action text-center">Action</th>
            </tr>
        </thead>

        <!-- ========================================================= -->
        <!-- 2. TABLE BODY -->
        <!-- ========================================================= -->

        <tbody id="IBatTableBody">

            <!-- 2.1 TEMPLATE ROW (CLONE PURPOSE) -->
            <!-- Tamil: இது Hidden template row (clone செய்ய பயன்படும்) -->
            <!-- English: Hidden row used as template for dynamic row creation -->
            <tr id="IBatTempRow" style="display: none;">

                <td class="datetype">
                    <!-- Hidden fields -->
                    <input id="PII_BCH_Item_Number" class="PII_BCH_Item_Number" type="hidden" />
                    <input id="PII_BCH_Item_Index" class="PII_BCH_Item_Index" type="hidden" />

                    <!-- Date input -->
                    <input id="PII_BCH_Date" class="form-control Key datepicker PII_BCH_Date text-center" />
                </td>

                <td>
                    <input id="PII_BCH_No" class="form-control PII_BCH_No" />
                </td>

                <td>
                    <input id="PII_BCH_Qty" class="form-control PII_BCH_Qty text-end decimal" />
                </td>

                <td>
                    <!-- readonly -->
                    <input id="PII_BCH_UnitPrice" class="form-control PII_BCH_UnitPrice decimal text-end" readonly />
                </td>

                <td>
                    <input id="PII_BCH_Value" class="form-control PII_BCH_Value decimal text-end" readonly />
                </td>

                <td class="text-center">
                    <!-- Delete flag -->
                    <input id="PII_BCH_IsDeleted" type="hidden" value="false" />

                    <!-- Delete button -->
                    <a class="IBatRowRemove text-danger">🗑</a>
                </td>
            </tr>

            <!-- ========================================================= -->
            <!-- 2.2 EXISTING DATA BINDING -->
            <!-- ========================================================= -->
            @if (Model != null)
            {
                @for (int i = 0; i < Model.Count; i++)
                {
                    <!-- Tamil: Database data load ஆகும் row -->
                    <!-- English: Row populated from server model -->
                    <tr class="IBatNewRow">

                        <td>
                            <input name="ItemBatch[@i].PII_BCH_Item_Number" value="@Model[i].PII_BCH_Item_Number" type="hidden" />
                            <input name="ItemBatch[@i].PII_BCH_Item_Index" value="@Model[i].PII_BCH_Item_Index" type="hidden" />
                            <input name="ItemBatch[@i].PII_BCH_Date" value="@Model[i].PII_BCH_Date" class="form-control" />
                        </td>

                        <td>
                            <input name="ItemBatch[@i].PII_BCH_No" value="@Model[i].PII_BCH_No" class="form-control" />
                        </td>

                        <td>
                            <input name="ItemBatch[@i].PII_BCH_Qty" value="@Model[i].PII_BCH_Qty" class="form-control" />
                        </td>

                        <td>
                            <input name="ItemBatch[@i].PII_BCH_UnitPrice" value="@Model[i].PII_BCH_UnitPrice" class="form-control" readonly />
                        </td>

                        <td>
                            <input name="ItemBatch[@i].PII_BCH_Value" value="@Model[i].PII_BCH_Value" class="form-control" readonly />
                        </td>

                        <td>
                            <input type="hidden" name="ItemBatch[@i].PII_BCH_IsDeleted" value="@Model[i].PII_BCH_IsDeleted" />
                            <a class="IBatRowRemove text-danger">🗑</a>
                        </td>

                    </tr>
                }
            }
        </tbody>

        <!-- ========================================================= -->
        <!-- 3. FOOTER TOTAL -->
        <!-- ========================================================= -->
        <tfoot>
            <tr class="table-info">
                <td colspan="2" class="text-end">Total</td>

                <!-- Total Qty -->
                <td>
                    <input id="BatchTotalQty" class="form-control text-end" readonly />
                </td>

                <td></td>

                <!-- Total Value -->
                <td>
                    <input id="BatchTotalValue" class="form-control text-end" readonly />
                </td>
            </tr>
        </tfoot>
    </table>
</div>

<!-- ========================================================= -->
<!-- 4. JAVASCRIPT LOGIC -->
<!-- ========================================================= -->

<script>

    // 4.1 DOCUMENT READY
    // Tamil: Page load ஆனதும் execute ஆகும்
    // English: Runs when page is loaded
    $(document).ready(function () {

        // 4.1.1 Row counter
        var browCount = @(Model != null ? Model.Count : 0);

        // 4.1.2 Prevent multiple row creation
        var isbAddingRow = false;

        // =========================================================
        // 5. ADD NEW ROW FUNCTION
        // =========================================================

        function IBatNewRow() {

            // 5.1 Clone template
            var row = $("#IBatTempRow").clone()
                .removeAttr("style")
                .removeAttr("id")
                .addClass("IBatNewRow");

            // 5.2 Assign dynamic names
            row.find(".PII_BCH_Item_Number")
                .attr("name", "ItemBatch[" + browCount + "].PII_BCH_Item_Number");

            // 5.3 Append row
            $("#IBatTableBody").append(row);

            // 5.4 Increase index
            browCount++;
        }

        // =========================================================
        // 6. OPEN MODAL (ITEM BATCH CLICK)
        // =========================================================

        $(document).on('click', '.ItemBatch', function () {

            // 6.1 Get selected checkbox row
            let row = $('.CheckItem:checked').closest('tr');

            // 6.2 Extract values
            var ItemNumber = row.find('.PII_Item_Number').val();

            // 6.3 If item exists
            if (ItemNumber) {

                // 6.4 Open modal
                new bootstrap.Modal($("#IBatch")).show();
            }
        });

        // =========================================================
        // 7. DELETE ROW
        // =========================================================

        $(document).on('click', '.IBatRowRemove', function () {

            // 7.1 Mark deleted
            $(this).closest('tr')
                .find(".PII_BCH_IsDeleted")
                .val("true");

            // 7.2 Hide row
            $(this).closest('tr').hide();

            // 7.3 Recalculate
            BatchCalculateFooter();
        });

        // =========================================================
        // 8. INPUT CALCULATION (QTY CHANGE)
        // =========================================================

        $(document).on('input', ".PII_BCH_Qty", function () {

            // 8.1 Get row
            var row = $(this).closest("tr");

            // 8.2 Get qty & price
            var qty = parseFloat(row.find(".PII_BCH_Qty").val()) || 0;
            var price = parseFloat(row.find(".PII_BCH_UnitPrice").val()) || 0;

            // 8.3 Calculate value
            var value = qty * price;

            // 8.4 Set value
            row.find(".PII_BCH_Value").val(value);

            // 8.5 Update footer
            BatchCalculateFooter();
        });

    });

    // =========================================================
    // 9. FOOTER CALCULATION
    // =========================================================

    function BatchCalculateFooter() {

        // 9.1 Init totals
        var totalQty = 0;
        var totalValue = 0;

        // 9.2 Loop rows
        $("tr.IBatNewRow:visible").each(function () {

            var row = $(this);

            // 9.3 Get values
            var qty = parseFloat(row.find(".PII_BCH_Qty").val()) || 0;
            var val = parseFloat(row.find(".PII_BCH_Value").val()) || 0;

            // 9.4 Add totals
            totalQty += qty;
            totalValue += val;
        });

        // 9.5 Update UI
        $("#BatchTotalQty").val(totalQty);
        $("#BatchTotalValue").val(totalValue);
    }

    // 9.6 Auto run on load
    window.onload = BatchCalculateFooter();

</script>

<!-- ========================================================= -->
<!-- 10. STYLE -->
<!-- ========================================================= -->
<style>
    /* 10.1 Search dropdown styling */
    .search-results {
        position: absolute;
        z-index: 1000;
        max-height: 300px;
    }
</style>