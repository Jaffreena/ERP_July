    function customRound(number) {
        const num = parseFloat(number);
        const decimal = num % 1;

        if (decimal >= 0.5) {
            return Math.ceil(num);
        } else {
            return Math.floor(num);
        }
    }
    // window.onload = CalculateFooter();

    function FormatNumber(num) {
        if (num === "" || isNaN(num)) return "0";

        var formattedValue = parseFloat(num).toFixed(10);
        var parts = formattedValue.split(".");
        if (parts.length > 1) {
            parts[1] = parts[1].replace(/0+$/, "");
            if (parts[1].length === 0) parts.pop();
        }

        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");

        return parts.join(".");
    }

    function SearchWHT() {
        var Vendor = $("#PIH_Vendor_Number").val();
        var GRNDate = $("#PIH_InvoiceDate").val();
        var WHTax = $("#PIH_WHT_Number").val();

        GetWHT(Vendor, WHTax, GRNDate);
    }
    function GetWHT(Vendor, WHTax, GRNDate) {
        $.ajax({
            type: "get",
            url: "wht",
            data: { Vendor: Vendor, WHTNumber: WHTax, GRNDate: GRNDate },
            datatype: "json",
            traditional: true,
            success: function (data) {
                if (data != null) {
                    $("#PIH_WHT_Tax").val(data.tax);
                    $("#PIH_WHT_Percent").val(data.percentage);
                }
                else {
                    $("#PIH_WHT_Tax").val(1);
                    $("#PIH_WHT_Percent").val(0);
                }
                // CalAmount();
                (async () => {
                    await CalculateAllExpenses();
                })();
            }
        });
    }

