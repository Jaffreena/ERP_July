    async function CalculateIBatch(currentInput) {
        const currentRow = currentInput.closest('tr.NewRow');

        const POINumber = currentRow.find("input.PII_POI_Number").val();
        const POHNumber = currentRow.find("input.PII_POH_Number").val();
        const Qty = parseFloat(removeCommas(currentRow.find('input.PII_Qty').val())) || 0;
        const MaterialValue = parseFloat(removeCommas(currentRow.find('input.PII_Amount').val())) || 0;

        // Early return if invalid data
        if (!POHNumber || Qty === 0) return;

        // Calculate batch totals
        let totalMaterial = 0;
        $("tr.NewRow").each(function () {
            const row = $(this);
            if (row.find("input.PII_POH_Number").val() === POHNumber &&
                row.find("input.PII_IsDeleted").val() !== 'true') {
                totalMaterial += parseFloat(removeCommas(row.find("input.PII_Amount").val())) || 0;
            }
        });

        // Calculate header expenses
        let BExpense = 0;
        $("tr.ExNewRow").each(function () {
            const row = $(this);
            if (row.find("input.PIH_EXP_IsDeleted").val() === "true") return;

            const EXPPOHNumber = row.find("input.PIH_EXP_POH_Number").val();
            const Charge = row.find("select.PIH_EXP_CM_Number").val();
            const Allocate = row.find("select.PIH_EXP_Allocate_Number").val();
            const ExpenseValue = parseFloat(removeCommas(row.find("input.PIH_EXP_ExpenseValue").val())) || 0;
            const ExpenseBase = parseFloat(removeCommas(row.find("input.PIH_EXP_ExpenseBase").val())) || 0;

            if (POHNumber === EXPPOHNumber && Allocate === "1") {
                switch (Charge) {
                    case "1":
                        if (totalMaterial > 0) {
                            BExpense += (ExpenseValue / totalMaterial) * MaterialValue;
                        }
                        break;
                    case "2":
                        BExpense += Qty * ExpenseBase;
                        break;
                    case "3":
                        BExpense += MaterialValue * ExpenseBase / 100;
                        break;
                }
            }
        });

        // Calculate item expenses
        let BIExpense = 0;
        if (POINumber) {
            $("tr.IExNewRow").each(function () {
                const row = $(this);
                if (row.find("input.PII_EXP_IsDeleted").val() === 'true') return;

                const EXPPOINumber = row.find('input.PII_EXP_POI_Number').val();
                const EXPPOHNumber = row.find('input.PII_EXP_POH_Number').val();
                const Allocate = row.find("select.PII_EXP_Allocate_Number").val();

                if (EXPPOINumber === POINumber && EXPPOHNumber === POHNumber && Allocate === "1") {
                    const ExpenseValue = parseFloat(removeCommas(row.find("input.PII_EXP_ExpenseValue").val())) || 0;
                    BIExpense += ExpenseValue;
                }
            });
        }

        // Calculate unit price and update batch rows
        const unitPrice = (BExpense + BIExpense + MaterialValue) / Qty;

        $("tr.IBatNewRow").each(function () {
            const irow = $(this);
            const RowPOINumber = irow.find("input.PII_BCH_POI_Number").val();
            const RowPOHNumber = irow.find("input.PII_BCH_POH_Number").val();
            const isDeleted = irow.find("input.PII_BCH_IsDeleted").val();

            if (RowPOINumber === POINumber && RowPOHNumber === POHNumber && isDeleted !== 'true') {
                const BtQty = parseFloat(removeCommas(irow.find("input.PII_BCH_Qty").val())) || 0;
                const BtBatchValue = BtQty * unitPrice;

                irow.find("input.PII_BCH_UnitPrice").val(DecimalIndianRupees(unitPrice.toFixed(2)));
                irow.find("input.PII_BCH_Value").val(DecimalIndianRupees(BtBatchValue.toFixed(2)));
            }
        });
    }
</script>

