@model List<ERP_DTO.POToPurchaseInvoiceItem_DTO>

<div class="col table-fixed h-100">
    <div class="w-12 table-responsive table-body table-body-f">
        <table class="table table-one table-striped table-bordered table-hover align-middle w-100" id="ItemTable">
            <thead>
                <tr class="table-info text-center">
                    <th class="px-2 del">
                    </th>
                    <th class="text-start">Purchase Order Number</th>
                    <th class="text-start">Item Code</th>
                    <th class="text-start">Description</th>
                    <th class="text-start">Item Group</th>
                    <th class="text-start text-center">Warehouse</th>
                    <th class="table-width-md">UoM</th>
                    <th class="table-width-xl">PO Qty</th>
                    <th class="table-width-xl text-center">Invoice Qty</th>
                    <th class="table-width-xl text-end">Unit Price</th>
                    <th class="table-width-3xl text-end">Amount</th>
                    <th class="table-width-3xl text-end">
                        Expense value
                    </th>
                    <th class="table-width-lg text-center">
                        HSN
                    </th>
                    <th class="table-width-xxl text-end">
                        GST Amount
                    </th>
                    <th class="table-width-sm text-center">
                        WHT Percent
                    </th>
                    <th class="table-width-xxl text-end">
                        WH_Tax Amount
                    </th>
                </tr>
            </thead>
            <tbody id="TableBody">
                <tr id="TempRow" style="display: none;">
                    <td class="p-2 del">
                        <input type="checkbox" class="CheckItem form-check-input" name="CheckItem">
                    </td>
                    <td>
                        <input id="PII_POH_OrderNo" class="form-control PII_POH_OrderNo" autocomplete="off" readonly />
                    </td>
                    <td>
                        <input id="PII_POI_Number" class="PII_POI_Number" type="hidden" />
                        <input id="PII_POH_Number" class="PII_POH_Number" type="hidden" />
                        <input id="PII_MS_Number" class="PII_MS_Number" type="hidden" />
                        <input id="PII_Item_Number" class="PII_Item_Number" type="hidden" />
                        <input id="PII_ItemCode" class="form-control PII_ItemCode" autocomplete="off" />
                        <div class="search-results card" style="display:none"></div>
                    </td>
                    <td>
                        <input id="PII_Description" class="form-control PII_Description" autocomplete="off" readonly />
                    </td>
                    <td>
                        <input id="PII_ItemGroup" class="form-control PII_ItemGroup" autocomplete="off" readonly />
                    </td>
                    <td>
                        <select id="PII_Warehouse_Number" class="form-select PII_Warehouse_Number" asp-items="@ViewBag.Warehouse"></select>
                    </td>
                    <td class="table-width-md">
                        <select id="PII_UoM_Number" class="form-select PII_UoM_Number text-center" asp-items="@ViewBag.UoM"></select>
                        <input id="PII_DecimalPlaces" class="form-control PII_DecimalPlaces" autocomplete="off" type="hidden" />
                        @* <input type="hidden" id="PII_UoM" class="form-control PII_UoM" autocomplete="off" /> *@
                    </td>
                    <td class="table-width-xl">
                        <input id="PII_POQty" class="form-control PII_POQty decimal text-center" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-xl">
                        <input id="PII_Qty" class="form-control PII_Qty number QtyNumbers text-center" autocomplete="off" />
                    </td>
                    <td class="table-width-xl">
                        <input id="PII_UnitPrice" class="form-control PII_UnitPrice number text-end" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-3xl">
                        <input id="PII_Amount" class="form-control PII_Amount text-end" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-3xl">
                        <input id="PII_ExpenseValue" class="form-control PII_ExpenseValue text-end" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-lg">
                        <select id="PII_HSN_Number" class="form-select PII_HSN_Number text-center" asp-items="@ViewBag.HSN"></select>
                    </td>
                    <td class="table-width-xxl">
                        <input id="PII_GST_Amount" class="form-control PII_GST_Amount text-end" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-sm">
                        <input id="PII_WHT_Percent" class="form-control PII_WHT_Percent text-end" autocomplete="off" readonly />
                    </td>
                    <td class="table-width-xxl">
                        <input id="PII_WHT_Amount" class="form-control PII_WHT_Amount text-end" autocomplete="off" readonly />
                        <input name="PII_IsDeleted" class="PII_IsDeleted" value="false" type="hidden" />
                    </td>
                </tr>
                @if (Model != null)
                {
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr class="NewRow" style="@(@Model[i].PII_IsDeleted == "true" ? "display: none;" : "")">
                            <td class="p-2 del">
                                <input type="checkbox" class="CheckItem form-check-input" name="CheckItem">
                            </td>
                            <td>
                                <input id="PII_POH_OrderNo" name="InvoiceItems[@i].PII_POH_OrderNo" class="form-control PII_POH_OrderNo" readonly value="@Model[i].PII_POH_OrderNo" />
                            </td>
                            <td>
                                <input id="PII_POI_Number" name="InvoiceItems[@i].PII_POI_Number" class="PII_POI_Number" type="hidden" value="@Model[i].PII_POI_Number" />
                                <input id="PII_POH_Number" name="InvoiceItems[@i].PII_POH_Number" class="PII_POH_Number" type="hidden" value="@Model[i].PII_POH_Number" />
                                <input id="PII_MS_Number" name="InvoiceItems[@i].PII_MS_Number" class="PII_MS_Number" type="hidden" value="@Model[i].PII_MS_Number" />
                                <input id="PII_Item_Number" name="InvoiceItems[@i].PII_Item_Number" class="PII_Item_Number" type="hidden" value="@Model[i].PII_Item_Number" />
                                <input id="PII_ItemCode" name="InvoiceItems[@i].PII_ItemCode" class="form-control PII_ItemCode" autocomplete="off" value="@Model[i].PII_ItemCode" oninput="OnInput(this)" onfocus="OnFocus(this)" />
                                <div class="search-results card" style="display:none"></div>
                            </td>
                            <td>
                                <input id="PII_Description" name="InvoiceItems[@i].PII_Description" class="form-control PII_Description" readonly value="@Model[i].PII_Description" />
                            </td>
                            <td>
                                <input id="PII_ItemGroup" name="InvoiceItems[@i].PII_ItemGroup" class="form-control PII_ItemGroup" readonly value="@Model[i].PII_ItemGroup" />
                            </td>
                            <td>
                                <select id="PII_Warehouse_Number" name="InvoiceItems[@i].PII_Warehouse_Number" class="form-select PII_Warehouse_Number">
                                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Warehouse)
                                    {
                                        if (item.Value == Model[i].PII_Warehouse_Number)
                                        {
                                            <option value="@item.Value" selected>@item.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td class="table-width-md">
                                <select id="PII_UoM_Number" name="InvoiceItems[@i].PII_UoM_Number" class="form-select PII_UoM_Number">
                                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.UoM)
                                    {
                                        if (item.Value == Model[i].PII_UoM_Number)
                                        {
                                            <option value="@item.Value" selected>@item.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                                @* <input id="PII_UoM" name="InvoiceItems[@i].PII_UoM" class="form-control PII_UoM" type="hidden" value="@Model[i].PII_UoM" /> *@
                                <input id="PII_DecimalPlaces" name="InvoiceItems[@i].PII_DecimalPlaces" class="form-control PII_DecimalPlaces" autocomplete="off" value="@Convert.ToDouble(@Model[i].PII_DecimalPlaces)" type="hidden" />
                            </td>
                            <td class="table-width-xl">
                                <input id="PII_POQty" name="InvoiceItems[@i].PII_POQty" class="form-control PII_POQty decimal text-center" autocomplete="off" readonly value="@Convert.ToDouble(@Model[i].PII_POQty)" />
                            </td>
                            <td class="table-width-xl">
                                <input id="PII_Qty" name="InvoiceItems[@i].PII_Qty" class="form-control PII_Qty number QtyNumbers text-center" autocomplete="off" value="@Convert.ToDouble(@Model[i].PII_Qty)" />
                            </td>
                            <td class="table-width-xl">
                                <input id="PII_UnitPrice" name="InvoiceItems[@i].PII_UnitPrice" class="form-control PII_UnitPrice number text-end" readonly autocomplete="off" value="@Convert.ToDouble(@Model[i].PII_UnitPrice)" />
                            </td>
                            <td class="table-width-3xl">
                                <input id="PII_Amount" name="InvoiceItems[@i].PII_Amount" class="form-control PII_Amount text-end" readonly autocomplete="off" value="@Convert.ToDouble(@Model[i].PII_Amount)" />
                                @if (@Model[i].PII_Number != 0)
                                {
                                    <input name="InvoiceItems[@i].Number" class="Number" value="@Model[i].PII_Number" type="hidden" />
                                }
                                <input name="InvoiceItems[@i].PII_IsDeleted" class="PII_IsDeleted" value="@Model[i].PII_IsDeleted" type="hidden" />
                            </td>
                            <td class="table-width-3xl">
                                <input id="PII_ExpenseValue" name="InvoiceItems[@i].PII_ExpenseValue" class="form-control PII_ExpenseValue text-end" autocomplete="off" readonly value="@Convert.ToDouble(@Model[i].PII_ExpenseValue)" />
                            </td>
                            <td class="table-width-lg">
                                <select id="PII_HSN_Number" name="InvoiceItems[@i].PII_HSN_Number" class="form-select PII_HSN_Number">
                                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.HSN)
                                    {
                                        if (item.Value == Model[i].PII_HSN_Number)
                                        {
                                            <option value="@item.Value" selected>@item.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </td>
                            <td class="table-width-xxl">
                                <input id="PII_GST_Amount" name="InvoiceItems[@i].PII_GST_Amount" class="form-control PII_GST_Amount text-end" autocomplete="off" readonly value="@Convert.ToDouble(@Model[i].PII_GST_Amount)" />
                            </td>
                            <td class="table-width-sm">
                                <input id="PII_WHT_Percent" name="InvoiceItems[@i].PII_WHT_Percent" class="form-control PII_WHT_Percent" autocomplete="off" readonly value="@Convert.ToDouble(@Model[i].PII_WHT_Percent)" />
                            </td>
                            <td class="table-width-xxl">
                                <input id="PII_WHT_Amount" name="InvoiceItems[@i].PII_WHT_Amount" class="form-control PII_WHT_Amount text-end" autocomplete="off" readonly value="@Convert.ToDouble(@Model[i].PII_WHT_Amount)" />
                            </td>
                        </tr>
                    }
                }
            </tbody>
            <tfoot>
                <tr class="table-info fw-bold">
                    <td colspan="7" class="text-end py-2"><span class="float-end  pe-3">Total</span></td>
                    <td>
                        <input id="TotalPOQty" class="form-control text-center" readonly />
                    </td>
                    <td>
                        <input id="TotalQty" class="form-control text-center" readonly />
                    </td>
                    <td>
                    </td>
                    <td>
                        <input id="TotalAmount" class="form-control text-end" readonly />
                    </td>
                    <td>
                        <input id="TotalExpenseValue" class="form-control text-end" readonly />
                    </td>
                    <td>
                    </td>
                    <td>
                        <input id="TotalGST" class="form-control text-end" readonly />
                    </td>
                    <td>
                    </td>
                    <td>
                        <input id="TotalWHT" class="form-control text-end" readonly />
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
    <div class="row table-footer align-items-center">
        <div class="col">
            <a class="RowRemove btn btn-primary">
                Delete Row
            </a>
        </div>
    </div>
</div>
<script>
    function initializeFlatpickrs() {
        $(".PII_DeliveryDate").flatpickr({
            dateFormat: "d-M-Y",
            altInput: false,
        });
    }

    var rowCount = @(Model != null ? Model.Count : 0);
    var isAddingRow = false;

    function addRow(Po) {
        var NewRow = $("#TempRow").clone().removeAttr("style").removeAttr("id").addClass("NewRow");
        NewRow.find("input.PII_POI_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_POI_Number").val(Po.poI_Number);
        NewRow.find("input.PII_POH_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_POH_Number").val(Po.poH_Number);
        NewRow.find("input.PII_POH_OrderNo").attr("name", "InvoiceItems[" + rowCount + "].PII_POH_OrderNo").val(Po.poH_OrderNo);
        NewRow.find("input.PII_MS_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_MS_Number").val(Po.poI_MS_Number);
        NewRow.find("input.PII_Item_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_Item_Number").val(Po.poI_Item_Number);
        NewRow.find("input.PII_ItemCode").attr("name", "InvoiceItems[" + rowCount + "].PII_ItemCode").val(Po.poI_ItemCode);
        NewRow.find("input.PII_Description").attr("name", "InvoiceItems[" + rowCount + "].PII_Description").val(Po.poI_ItemDescription);
        NewRow.find("input.PII_DecimalPlaces").attr("name", "InvoiceItems[" + rowCount + "].PII_DecimalPlaces").val(Po.poI_DecimalPlaces);
        NewRow.find("input.PII_ItemGroup").attr("name", "InvoiceItems[" + rowCount + "].PII_ItemGroup").val(Po.poI_ItemGroup);
        NewRow.find("select.PII_Warehouse_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_Warehouse_Number").val(Po.poI_Warehouse_Number);
        NewRow.find("select.PII_UoM_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_UoM_Number").val(Po.poI_UoM_Number);
        NewRow.find("input.PII_POQty").attr("name", "InvoiceItems[" + rowCount + "].PII_POQty").val(Po.poI_Qty);
        NewRow.find("input.PII_Qty").attr("name", "InvoiceItems[" + rowCount + "].PII_Qty").val(Po.poI_Qty);
        NewRow.find("input.PII_UnitPrice").attr("name", "InvoiceItems[" + rowCount + "].PII_UnitPrice").val(Po.poI_UnitPrice);
        NewRow.find("input.PII_Amount").attr("name", "InvoiceItems[" + rowCount + "].PII_Amount").val(Po.poI_Amount);

        NewRow.find("input.PII_ExpenseValue").attr("name", "InvoiceItems[" + rowCount + "].PII_ExpenseValue");
        NewRow.find("select.PII_HSN_Number").attr("name", "InvoiceItems[" + rowCount + "].PII_HSN_Number").val(Po.poI_HSN);
        NewRow.find("input.PII_GST_Amount").attr("name", "InvoiceItems[" + rowCount + "].PII_GST_Amount");
        NewRow.find("input.PII_WHT_Percent").attr("name", "InvoiceItems[" + rowCount + "].PII_WHT_Percent");
        NewRow.find("input.PII_WHT_Amount").attr("name", "InvoiceItems[" + rowCount + "].PII_WHT_Amount");
        NewRow.find("input.PII_IsDeleted").attr("name", "InvoiceItems[" + rowCount + "].PII_IsDeleted").val("false");

        $("#TableBody").append(NewRow);
        rowCount++;
        NewRow.data("isValid", false);
        isAddingRow = false;

        initializeFlatpickrs();
    }

    $(document).on('keydown', "tr.NewRow select, tr.NewRow input.PII_DeliveryDate,tr.NewRow input.PII_Item_Number,tr.NewRow input.PII_Qty,tr.NewRow input.PII_UnitPrice, tr.NewRow input[type='text']", function (event) {
        if (event.keyCode === 9) {
            if (!validateField($(this)))
                event.preventDefault();
        }
    });

    $(document).on('change', "tr.NewRow select.PII_UoM_Number", function () {
        var selectedValue = $(this).val();
        var currentInput = $(this);
        var currentRow = currentInput.closest('tr.NewRow');

        var uom = currentRow.find('input.PII_UoM').val();

        if (uom === selectedValue) { } else {
            alert("Selected Uom differs from item master purchase unit");
        }

        $.ajax({
            type: "get",
            url: "uom",
            data: { UoM: selectedValue },
            datatype: "json",
            traditional: true,
            success: function (decimalPlaces) {
                if (decimalPlaces === "") {
                    decimalPlaces = 2;
                }

                currentRow.find('input.PII_DecimalPlaces').val(decimalPlaces);
                var value = currentRow.find('input.PII_Qty').val();
                currentRow.find('input.PII_Qty').val(NumberToIndianRupees(value, decimalPlaces));
            }
        });
    });
    $(document).on('change', "tr.NewRow select.PII_HSN_Number", function () {
        // CalAmount();
        (async () => {
            await CalculateAllExpenses();
        })();
    });
