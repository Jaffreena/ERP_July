    function UpdateItemButton() {
        const selectedValues = $(".CheckItem:checked").map(function() {
            return $(this).closest("tr").find("td:eq(1)").text().trim();
        }).get();

        $(".OneItemMode").prop("disabled", selectedValues.length !== 1);
    }

    function OnInput(inputElement) {
        searchItem(inputElement);
    }
    function OnFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            searchItem(inputElement);
        }
        else {
            $(this).select();
        }
    }
    function searchItem(inputElement) {
        var itemCode = inputElement.value;
        var resultsDiv = $(inputElement).next('.search-results');
        var Metrial = $("#PIH_MS_Number").val();

        if (Metrial) {
            $.ajax({
                url: 'item',
                data: { ItemCode: itemCode, MS: Metrial },
                type: 'GET',
                success: function (data) {
                    resultsDiv.empty();
                    if (data && data.length > 0) {
                        resultsDiv.show();
                        var table = $('<div class="card-body modal-content"><table class="table table-bordered table-hover mb-0"><thead><tr class="table-info"><th>Item Code</th><th>Description</th><th>Item Group</th></tr></thead><tbody></tbody></table></div>');
                        data.forEach(function (item) {
                            var row = $('<tr></tr>');
                            row.append('<td>' + item.itemCode + '</td>');
                            row.append('<td>' + item.itemDescription + '</td>');
                            row.append('<td>' + item.itemGroup + '</td>');
                            table.find('tbody').append(row);

                            row.on('click', function () {
                                $(inputElement).val(item.itemCode);
                                $(inputElement).closest('tr').find('input.PII_Item_Number').val(item.itemNumber);
                                $(inputElement).closest('tr').find('input.PII_ItemCode').val(item.itemCode);
                                $(inputElement).closest('tr').find('input.PII_Description').val(item.itemDescription);
                                $(inputElement).closest('tr').find('input.PII_ItemGroup').val(item.itemGroup);
                                $(inputElement).closest('tr').find('input.PII_DecimalPlaces').val(item.decimalPlaces);
                                $(inputElement).closest('tr').find('input.PII_MS_Number').val(item.materialSegregation);
                                $(inputElement).closest('tr').find('select.PII_Warehouse_Number').val(item.purchaseWarehouse);
                                $(inputElement).closest('tr').find('select.PII_UoM_Number').val(item.uoM);
                                $(inputElement).closest('tr').find('input.PII_UoM').val(item.uoM);
                                $(inputElement).closest('tr').find('select.PII_UoM_Number').focus();
                                $(inputElement).closest('tr').find('select.PII_HSN_Number').val(item.hsN_Code);

                                var decimalPlaces = item.decimalPlaces;
                                if (decimalPlaces === "") {
                                    decimalPlaces = 2;
                                }
                                var value = $(inputElement).closest('tr').find('input.PII_Qty').val();
                                $(inputElement).closest('tr').find('input.PII_Qty').val(NumberToIndianRupees(value, decimalPlaces));

                                SearchWHT();
                                // CalAmount();
                                (async () => {
                                    await CalculateAllExpenses();
                                })();

                                resultsDiv.hide();
                            });
                        });

                        var closeButton = $('<div class="card-header bg-primary py-1"><button type="button" class="p-0 float-end btn btn-sm btn-primary bg-opacity-10"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16"><path d = "M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"> </path></svg></button></div>');
                        closeButton.on('click', function () {
                            resultsDiv.hide();
                        });

                        resultsDiv.append(closeButton);
                        resultsDiv.append(table);
                    } else {
                        resultsDiv.hide();
                        resultsDiv.append('<p>No results found</p>');
                    }
                },
                error: function () {
                    resultsDiv.text('Error loading data.');
                    resultsDiv.show();
                }
            });
        }
        else {
        }
    }

