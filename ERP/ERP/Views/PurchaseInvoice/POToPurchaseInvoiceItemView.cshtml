<script>
    $(document).ready(function () {
        $('#ExchangeRate').hide();
        ExchangeVisibility();
        GetCustor();

        $("#PIH_ImportOrder").change(function () {
            var isChecked = $(this).is(':checked');

            var resultsDiv = $(".vendor-search-results");
            resultsDiv.hide();

            if ($("#PIH_VendorLocation").val() != "") {
                if (isChecked && $("#PIH_VendorLocation").val() != "2") {
                    if (confirm("Do you want to change the status of the Import Order? This action will clear the already selected vendor.")) {
                        $("#PIH_Vendor").val("");
                        $("#PIH_Vendor_Number").val("");
                        $("#PIH_Currency").val("");
                        $("#PIH_Currency_Number").val("");
                        $("#PIH_VendorLocation").val("");
                        $("#PIH_WHT_Number").val("");

                        var dropdown = document.getElementById("PIH_TaxCluster_Number");
                        dropdown.innerHTML = "";

                        var GRNDate = $("#PIH_InvoiceDate").val();
                        GetWHT(0, 0, GRNDate);
                    }
                    else {
                        $(this).prop('checked', false);
                    }
                }
                else if (!isChecked && $("#PIH_VendorLocation").val() != "1") {
                    if (confirm("Do you want to change the status of the Import Order? This action will clear the already selected vendor.")) {
                        $("#PIH_Vendor").val("");
                        $("#PIH_Vendor_Number").val("");
                        $("#PIH_Currency").val("");
                        $("#PIH_Currency_Number").val("");
                        $("#PIH_VendorLocation").val("");
                        $("#PIH_WHT_Number").val("");

                        var dropdown = document.getElementById("PIH_TaxCluster_Number");
                        dropdown.innerHTML = "";

                        var GRNDate = $("#PIH_InvoiceDate").val();
                        GetWHT(0, 0, GRNDate);
                    }
                    else {
                        $(this).prop('checked', true);
                    }
                }
            }
            ExchangeVisibility();
        });

        function GetCustor() {
            SearchClustor($('#PIH_Vendor_Number').val(), "");
        }
    });
</script>