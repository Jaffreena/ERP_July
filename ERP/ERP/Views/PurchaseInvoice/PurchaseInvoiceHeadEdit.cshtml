@model ERP_DTO.PurchaseInvoiceHead_DTO


@if (Model.PIH_Number != 0)
{
    <input asp-for="PIH_Number" type="hidden" class="Number" />
}

<div class="col-auto left-menu text-black">
    <div class="row">
        <div class="col-12">
            <div class="row align-items-center mb-3">
                <div class="col-auto">
                    <input class="form-check-input" type="radio" checked disabled /> Direct
                </div>
                <div class="col-auto">
                    <button name="Mode" value="POTOITEM" class="bg-transparent border-0 shadow-0 icon-link text-black">
                        <input class="form-check-input m-0" type="radio" disabled /> PO To Item
                    </button>
                </div>
                <div class="col-auto">
                    <button name="Mode" value="POITEMTO" class="bg-transparent border-0 shadow-0 icon-link text-black">
                        <input class="form-check-input m-0" type="radio" disabled /> Item To PO
                    </button>
                </div>
            </div>
        </div>
        <div class="col-12 col-md">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_InvoiceNo" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input asp-for="PIH_InvoiceNo" class="form-control Key KeyDup" autocomplete="off" readonly />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_InvoiceDate" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input asp-for="PIH_InvoiceDate" class="form-control Key datepicker" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_ImportOrder" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input class="form-check-input" type="checkbox" asp-for="PIH_ImportOrder" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_MS_Number" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <select asp-for="PIH_MS_Number" class="form-select" asp-items="@ViewBag.MaterialSegregation"></select>
                </div>
            </div>
        </div>
        <div class="col-12 col-md">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_Vendor_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_Vendor_Number" class="form-control" type="hidden" />
                    <input asp-for="PIH_VendorLocation" class="form-control" type="hidden" />
                    <input asp-for="PIH_CreditDays" class="form-control" type="hidden" />
                    <input asp-for="PIH_PaymentBase" class="form-control" type="hidden" />
                    <input asp-for="PIH_Vendor" class="form-control" autocomplete="off" oninput="OnVendorInput(this)" onfocus="OnVendorFocus(this)" />
                    <div class="vendor-search-results card" style="display:none"></div>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_SupplierInvoiceNo" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_SupplierInvoiceNo" class="form-control Key KeyDup" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_SupplierInvoiceDate" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_SupplierInvoiceDate" class="form-control Key datepicker" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_DueDate" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_DueDate" class="form-control Key" readonly autocomplete="off" />
                </div>
            </div>
        </div>
        <div class="col-12 col-md">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_TaxCluster_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <select asp-for="PIH_TaxCluster_Number" class="form-select" onchange="SearchGST()"></select>
                    @if (Model != null)
                    {
                        <input asp-for="PIH_TaxClusterNumber" class="form-control" type="hidden" value="@Model.PIH_TaxCluster_Number" />
                    }
                    <div class="cluster-results dropdown-results search-results bg-primary p-2" style="display:none"></div>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_WHT_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_WHT_Tax" class="form-control" type="hidden" />
                    <input asp-for="PIH_WHT_Percent" class="form-control" type="hidden" />
                    <select asp-for="PIH_WHT_Number" class="form-select" asp-items="@ViewBag.WHTax" onchange="SearchWHT()"></select>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="PIH_Currency_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_Currency" class="form-control" readonly autocomplete="off" />
                    <input asp-for="PIH_Currency_Number" class="form-control" type="hidden" />
                    <input asp-for="PIH_DecimalPlaces" class="form-control" type="hidden" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1" id="ExchangeRate">
                <label asp-for="PIH_ExchangeRate" class="col-sm-5 col-form-label ps-0 text-nowrap"></label>
                <div class="col-sm-7">
                    <input asp-for="PIH_ExchangeRate" class="form-control Key decimal" autocomplete="off" />
                </div>
            </div>
        </div>
    </div>
</div>
<div class="col-auto right-menu text-center border-start">
    @if (Model.PIH_Number != 0)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    @* <button type="button" class="btn btn-primary btn-sm px-2 w-100 mb-1" id="MiscExpenseModal" data-bs-toggle="modal" data-bs-target="#Expense">
        Misc. Expense
    </button> *@
    <button type="button" class="btn btn-primary btn-sm px-2 w-100 mb-1 HeaderExpense" id="MiscExpenseModal">
        Misc. Expense
    </button>
</div>
