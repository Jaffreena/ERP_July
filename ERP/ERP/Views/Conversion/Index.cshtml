                                                                                <div class="search-results card"
                                                                                     style="display:none">
                                                                                </div>

                                                                            </td>

                                                                            <!-- DESCRIPTION -->
                                                                            <td>

                                                                                <input id="JIDNI_Item_Description"
                                                                                       class="form-control JIDNI_Item_Description"
                                                                                       readonly />

                                                                            </td>

                                                                            <!-- OUTER DIA -->
                                                                            <td class="table-width-xl">

