@using System.Security.Claims

@{
    String Theme = "1";
    if (User.Identity.IsAuthenticated)
    {
        Theme = Convert.ToString(@User.FindFirst("ERP_THEME").Value);        
    }

}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@300;400;500;600&amp;display=swap" rel="stylesheet">
    <link href="~/css/bootstrap.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ERP.styles.css" asp-append-version="true" />
    <link href="~/css/select2.min.css" rel="stylesheet" />
    <link href="~/css/flatpickr.min.css" rel="stylesheet" />
</head>
<body data-bs-theme="@(Theme == "1" ? "blue" : "")@(Theme == "2" ? "dark" : "")@(Theme == "3" ? "light" : "")" class="overflow-hidden">
    @{
        ViewBag.Web = "https://localhost:7237";
    }
    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.22.1/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="~/js/receipt/receiptnote.js"></script>

    <script>
        flatpickr(".datepicker", {
            dateFormat: "d-M-Y",
            altInput: false,
        });
    </script>
    <!-- Modal -->
    <div class="modal modal-sm fade" id="DuplicateAlert" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <p class="modal-title" id="staticBackdropLabel">Warning</p>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4 text-dark fs-6 text-center icon-link justify-content-center">
                    <img src="~/img/danger.png" class="img-fluid" /> Duplicate Entry
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-primary px-4" id="DupOkay" ref="always_focus" data-bs-dismiss="modal" autofocus>Ok</button>
                </div>
            </div>
        </div>
    </div>

    @if (User.Identity.IsAuthenticated && User.HasClaim(ClaimTypes.Authentication, "Admin"))
    {
        <div class="w-100 Layout">
            <div class="navbar-vertical-top container-fluid fixed-top shadow bg-primary border-bottom">
                <div class="row h-100 align-items-center">
                    <div class="col-12 col-sm-3 col-lg-3 h-100 align-items-center">
                        <a class="navbar-brand w-100 h-100 d-flex" asp-area="" asp-controller="Home" asp-action="Index"><img src="~/img/logo.png" alt="logo" class="logo img-fluid"></a>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-6 h-100 bg-light bg-opacity-25 text-center align-content-center h6 border-start border-end">
                        ABC Private Limited
                    </div>
                    <div class="col-12 col-sm-3 col-lg-3 h-100 align-content-center">
                        <div class="dropdown float-end pe-3">
                            <div class="dropdown-toggle icon-link" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="bi bi-person-circle" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1" />
                                </svg>@User.Identity.Name !
                            </div>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="Theme">Theme</a></li>
                                <li><a class="dropdown-item">Reset Password</a></li>
                                <li><a class="dropdown-item" asp-controller="Home" asp-action="LogOut">Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <header class="navbar-vertical fixed-top navbar-nav navbar-expand-sm navbar-light bg-secondary">
                <nav class="border-end align-items-start shadow w-100 h-100 py-2 navbar-collapse collapse @(ViewBag.Collapse == true ? "show":"")">
                    <div class="container-fluid flex-column gx-3">
                        <ul class="navbar-nav w-100">
                            <li class="nav-item">
                                <a class="nav-link icon-link bg-set shadow float-end w-100 d-block p-2" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="true" aria-label="Toggle navigation">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="svg bi bi-chevron-double-left float-end" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"></path>
                                        <path fill-rule="evenodd" d="M12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0"></path>
