                </nav>
            </header>
            <div class="content">
                <div class="container-fluid h-100 gx-2">
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="container-fluid gx-5">
            @RenderBody()
        </div>
    }
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Modal -->
    <div class="modal modal-sm fade" id="ModelAlert" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header draggable-modal-header">
                    <p class="modal-title" id="staticBackdropLabel">Warning</p>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body py-4 text-dark fs-6 text-center icon-link justify-content-center">
                    <img src="~/img/danger.png" class="img-fluid" /> @Html.Raw(ViewBag.ErrorMessage)
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-primary px-4" id="AlertOkay" autofocus ref="always_focus" data-bs-dismiss="modal">Ok</button>
                </div>
            </div>
        </div>
    </div>
    @{
        if (ViewBag.ErrorCode != null)
        {
            <script>
                $(function () {
                    new bootstrap.Modal($("#ModelAlert")).show();
                    $('#ModelAlert').on('shown.bs.modal', function () {
                        $(this).find('[autofocus]').focus();
                    });
                });
            </script>
        }
    }
    <!-- jQuery UI -->
    <script src="https://code.jquery.com/ui/1.12.1/jquery-ui.min.js"></script>
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">

    <script>
        const popoverTriggerList = document.querySelectorAll('[data-bs-toggle="popover"]')
        const popoverList = [...popoverTriggerList].map(popoverTriggerEl => new bootstrap.Popover(popoverTriggerEl))
        document.querySelectorAll('.popover-dismiss').forEach(function (el) {
        new bootstrap.Popover(el, {
        trigger: 'focus'
        });
        });
    </script>

    <!-- Modal -->
    <div class="modal modal-sm fade draggable-modal" id="DeleteAllAlert" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                @using (Html.BeginForm(null, null, FormMethod.Post))
                {
                    <input type="hidden" name="PSize" value="@ViewData["PageSize"]" />
                    <input type="hidden" name="PageNumber" value="@ViewData["PageNumber"]" />
                    <input type="hidden" name="Search" value="@ViewData["CurrentFilter"]" />
                    <input name="DeleteNumbers" id="DeleteNumbers" class="DeleteNumbers" type="hidden" />
                    <div class="modal-header draggable-modal-header">
                        <p class="modal-title" id="staticBackdropLabel">&nbsp;</p>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 text-dark fs-6 text-center w-100 icon-link justify-content-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" class="bi-lg bi-question-octagon-fill" viewBox="0 0 16 16">
                            <path d="M11.46.146A.5.5 0 0 0 11.107 0H4.893a.5.5 0 0 0-.353.146L.146 4.54A.5.5 0 0 0 0 4.893v6.214a.5.5 0 0 0 .146.353l4.394 4.394a.5.5 0 0 0 .353.146h6.214a.5.5 0 0 0 .353-.146l4.394-4.394a.5.5 0 0 0 .146-.353V4.893a.5.5 0 0 0-.146-.353zM5.496 6.033a.237.237 0 0 1-.24-.247C5.35 4.091 6.737 3.5 8.005 3.5c1.396 0 2.672.73 2.672 2.24 0 1.08-.635 1.594-1.244 2.057-.737.559-1.01.768-1.01 1.486v.105a.25.25 0 0 1-.25.25h-.81a.25.25 0 0 1-.25-.246l-.004-.217c-.038-.927.495-1.498 1.168-1.987.59-.444.965-.736.965-1.371 0-.825-.628-1.168-1.314-1.168-.803 0-1.253.478-1.342 1.134-.018.137-.128.25-.266.25h-.825zm2.325 6.443c-.584 0-1.009-.394-1.009-.927 0-.552.425-.94 1.01-.94.609 0 1.028.388 1.028.94 0 .533-.42.927-1.029.927" />
                        </svg> Do you want to delete it ?
                    </div>
                    <div class="modal-footer justify-content-center">
                        <button type="submit" name="Mode" class="btn btn-sm btn-primary px-4" id="DeleteAllOkay" autofocus ref="always_focus" value="DeleteAll">Yes</button>
                        <button type="button" class="btn btn-sm btn-primary px-4" data-bs-dismiss="modal">No</button>
                    </div>
                }
            </div>
        </div>
    </div>
    <!-- Modal -->
    <div class="modal modal-sm fade draggable-modal" id="DeleteAlert" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                @using (Html.BeginForm(null, null, FormMethod.Post))
                {
                    <input type="hidden" name="PSize" value="@ViewData["PageSize"]" />
                    <input type="hidden" name="PageNumber" value="@ViewData["PageNumber"]" />
                    <input type="hidden" name="Search" value="@ViewData["CurrentFilter"]" />
                    <input name="Number" id="Number" class="Number" type="hidden" />
                    <div class="modal-header draggable-modal-header">
                        <p class="modal-title" id="staticBackdropLabel">&nbsp;</p>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body py-4 text-dark fs-6 text-center w-100 icon-link justify-content-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="var(--bs-primary)" class="bi-lg bi-question-octagon-fill" viewBox="0 0 16 16">
                            <path d="M11.46.146A.5.5 0 0 0 11.107 0H4.893a.5.5 0 0 0-.353.146L.146 4.54A.5.5 0 0 0 0 4.893v6.214a.5.5 0 0 0 .146.353l4.394 4.394a.5.5 0 0 0 .353.146h6.214a.5.5 0 0 0 .353-.146l4.394-4.394a.5.5 0 0 0 .146-.353V4.893a.5.5 0 0 0-.146-.353zM5.496 6.033a.237.237 0 0 1-.24-.247C5.35 4.091 6.737 3.5 8.005 3.5c1.396 0 2.672.73 2.672 2.24 0 1.08-.635 1.594-1.244 2.057-.737.559-1.01.768-1.01 1.486v.105a.25.25 0 0 1-.25.25h-.81a.25.25 0 0 1-.25-.246l-.004-.217c-.038-.927.495-1.498 1.168-1.987.59-.444.965-.736.965-1.371 0-.825-.628-1.168-1.314-1.168-.803 0-1.253.478-1.342 1.134-.018.137-.128.25-.266.25h-.825zm2.325 6.443c-.584 0-1.009-.394-1.009-.927 0-.552.425-.94 1.01-.94.609 0 1.028.388 1.028.94 0 .533-.42.927-1.029.927" />
                        </svg> Do you want to delete it ?
                    </div>
                    <div class="modal-footer justify-content-center">
                        <button type="submit" name="Mode" class="btn btn-sm btn-primary px-4" id="DeleteOkay" autofocus ref="always_focus" value="Delete">Yes</button>
                        <button type="button" class="btn btn-sm btn-primary px-4" data-bs-dismiss="modal">No</button>
                    </div>
                }
            </div>
        </div>
    </div>
    <script type="text/javascript">
        $(function () {
            $(".DeleteAllButton").on('click', function () {
                var array = $.map($('input[name="DeleteNumber"]:checked'), function (c) { return c.value; })
                $(".DeleteNumbers").val(array);
                new bootstrap.Modal($("#DeleteAllAlert")).show();
                $('#DeleteAllAlert').on('shown.bs.modal', function () {
                    $(this).find('[autofocus]').focus();
                });
            });

            $(".DeleteButton").on('click', function () {
                var number = $(this).attr("value");
                $(".Number").val(number);
                new bootstrap.Modal($("#DeleteAlert")).show();
                $('#DeleteAlert').on('shown.bs.modal', function () {
                    $(this).find('[autofocus]').focus();
                });
            });
        });


        const selectAllCheckbox = document.getElementById('selectAllCheckbox'); const rowCheckboxes = document.querySelectorAll('.DeleteNumber'); if (selectAllCheckbox) { selectAllCheckbox.addEventListener('change', function () { rowCheckboxes.forEach(function (checkbox) { checkbox.checked = selectAllCheckbox.checked; }); }); }

            var array = $.map($('input[name="DeleteNumber"]:checked'), function (c) { return c.value; })
            if (array == "") {
                $('.MenuAction').addClass("d-none");
            } else {
                $('.MenuAction').removeClass("d-none");
            }
        });

        rowCheckboxes.forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                let allChecked = true;
                rowCheckboxes.forEach(function (checkBox) {
                    if (!checkBox.checked)
                        allChecked = false;
                });
                selectAllCheckbox.checked = allChecked;
            })
        })


        $(document).ready(function () {
            $('.DeleteNumber').change(function () {
                var array = $.map($('input[name="DeleteNumber"]:checked'), function (c) { return c.value; })
                if (array == "") {
                    $('.MenuAction').addClass("d-none");
                } else {
                    $('.MenuAction').removeClass("d-none");
                }
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.form-search').select2();
        });

        $(document).ready(function () {
            $(".modal").on("shown.bs.modal", function () {
                $(".modal-dialog").draggable({
                    handle: ".modal-header"
                });
            });
        });

        $(document).on('keydown', function (event) {
            if (event.key === 'Enter' || event.which === 13) {
                event.preventDefault();
            }
        });
    </script>
    <style>
        .modal-header {
            cursor: move;
        }

    </style>
