        }
        function autoExpandSelect(select) {
            const tempSpan = document.createElement('span');
            tempSpan.style.visibility = 'hidden';
            tempSpan.style.whiteSpace = 'pre';
            tempSpan.style.font = window.getComputedStyle(select).font;

            // Get selected option text
            const selectedOption = select.options[select.selectedIndex];
            tempSpan.textContent = selectedOption.text || select.placeholder;

            document.body.appendChild(tempSpan);
            const textWidth = tempSpan.offsetWidth;
            document.body.removeChild(tempSpan);

            const newWidth = Math.max(120, Math.min(400, textWidth + 40));
            select.style.width = newWidth + 'px';
        }

