    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const table = document.querySelector('.TableConfig');
            const headers = table.querySelectorAll('thead th');

            headers.forEach((th) => {
                // Create the handle
                const resizer = document.createElement('div');
                resizer.classList.add('th-resizer');
                th.appendChild(resizer);

                let startX, startWidth;

                resizer.addEventListener('mousedown', (e) => {
                    startX = e.pageX;
                    startWidth = th.offsetWidth;
                    document.addEventListener('mousemove', onMouseMove);
                    document.addEventListener('mouseup', onMouseUp);
                    e.preventDefault(); // Prevent text selection
                });

                function onMouseMove(e) {
                    const newWidth = startWidth + (e.pageX - startX);
                    th.style.width = newWidth + 'px';
                    // Also apply to all cells in this column
                    const colIndex = Array.from(th.parentNode.children).indexOf(th) + 1;
                    table.querySelectorAll('td:nth-child(' + colIndex + ')').forEach(td => {
                        td.style.width = newWidth + 'px';
                    });
                }

                function onMouseUp() {
                    document.removeEventListener('mousemove', onMouseMove);
                    document.removeEventListener('mouseup', onMouseUp);
                }
            });
        });

        document.addEventListener('DOMContentLoaded', function () {
            const filters = document.querySelectorAll('.column-filter');
            const table = document.querySelector('.TableConfig');
            const tbody = table.querySelector('tbody');

            filters.forEach(filter => {
                filter.addEventListener('keyup', () => {
                    const values = Array.from(filters).map(f => f.value.toLowerCase());
                    Array.from(tbody.rows).forEach(row => {
                        let visible = true;
                        values.forEach((val, idx) => {
                            if (val && !row.cells[idx].textContent.toLowerCase().includes(val)) {
                                visible = false;
                            }
                        });
                        row.style.display = visible ? '' : 'none';
                    });
                });
            });
        });
