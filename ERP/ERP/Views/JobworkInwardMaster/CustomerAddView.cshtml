@model List<ERP_DTO.CustomerAdd_DTO>


 
<div class="w-100 table-fixed h-100">
    <div class="w-100 table-responsive table-body table-body-f">
        <table class="table table-bordered align-middle table-hover align-middle mb-0 table-grid">
            <thead>
                <tr class="table-info">
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_ADTP_Number)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_AddressID)</th>
                    <th class="table-col-min-lg">@Html.DisplayNameFor(model => model.First().CUS_ADD_Address)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_City)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_State)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_Country)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_Pin)</th>
                    <th>@Html.DisplayNameFor(model => model.First().CUS_ADD_GSTIN)</th>
                    <th class="table-col-sm text-center">@Html.DisplayNameFor(model => model.First().CUS_ADD_Primary)</th>
                    <th class="action text-center">Action</th>
                </tr>
            </thead>
            <tbody id="AddTableBody">
                <tr id="AddTempRow" style="display: none;">
                    <td>
                        <select id="CUS_ADD_ADTP_Number" class="form-select CUS_ADD_ADTP_Number" asp-items="@ViewBag.AddressType"></select>
                    </td>
                    <td>
                        <input id="CUS_ADD_AddressID" class="form-control CUS_ADD_AddressID" autocomplete="off" />
                    </td>
                    <td class="table-col-min-lg">
                        <input id="CUS_ADD_Address" class="form-control CUS_ADD_Address" autocomplete="off" />
                    </td>
                    <td>
                        <input id="CUS_ADD_City" class="form-control CUS_ADD_City" autocomplete="off" />
                    </td>
                    <td>
                        <input id="CUS_ADD_State" class="form-control CUS_ADD_State" autocomplete="off" />
                    </td>
                    <td>
                        <input id="CUS_ADD_Country" class="form-control CUS_ADD_Country" autocomplete="off" />
                    </td>
                    <td>
                        <input id="CUS_ADD_Pin" class="form-control CUS_ADD_Pin" autocomplete="off" />
                    </td>
                    <td>
                        <input id="CUS_ADD_GSTIN" class="form-control CUS_ADD_GSTIN" autocomplete="off" />
                    </td>
                    <td class="table-col-sm text-center">
                        <input type="checkbox" id="CUS_ADD_Primary" class="form-check-input CUS_ADD_Primary" />
                    </td>
                    <td class="action text-center">
                        <input type="hidden" name="CUS_ADD_IsDeleted" class="CUS_ADD_IsDeleted" value="0" />
                        <a class="AddRowRemove btn text-danger p-0 icon-link shadow-none">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                            </svg>
                        </a>
                    </td>
                </tr>
                @if (Model != null)
                {
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        <tr class="AddNewRow" style="@(@Model[i].CUS_ADD_IsDeleted == 1 ? "display: none;" : "")">
                            <td>
                                <select id="CUS_ADD_ADTP_Number" name="CUS_Add_List[@i].CUS_ADD_ADTP_Number" class="form-select CUS_ADD_ADTP_Number">
                                    @if (ViewBag.AddressType != null)
                                    {
                                    @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.AddressType)
                                    {
                                        if (item.Value == Model[i].CUS_ADD_ADTP_Number.ToString())
                                        {
                                            <option value="@item.Value" selected>@item.Text</option>
                                        }
                                        else
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                    }
                                </select>
                            </td>
                            <td>
                                <input id="CUS_ADD_AddressID" name="CUS_Add_List[@i].CUS_ADD_AddressID" class="form-control CUS_ADD_AddressID" autocomplete="off" value="@Model[i].CUS_ADD_AddressID" />
                            </td>
                            <td class="table-col-min-lg">
                                <input id="CUS_ADD_Address" name="CUS_Add_List[@i].CUS_ADD_Address" class="form-control CUS_ADD_Address" autocomplete="off" value="@Model[i].CUS_ADD_Address" />
                            </td>
                            <td>
                                <input id="CUS_ADD_City" name="CUS_Add_List[@i].CUS_ADD_City" class="form-control CUS_ADD_City" autocomplete="off" value="@Model[i].CUS_ADD_City" />
                            </td>
                            <td>
                                <input id="CUS_ADD_State" name="CUS_Add_List[@i].CUS_ADD_State" class="form-control CUS_ADD_State" autocomplete="off" value="@Model[i].CUS_ADD_State" />
                            </td>
                            <td>
                                <input id="CUS_ADD_Country" name="CUS_Add_List[@i].CUS_ADD_Country" class="form-control CUS_ADD_Country" autocomplete="off" value="@Model[i].CUS_ADD_Country" />
                            </td>
                            <td>
                                <input id="CUS_ADD_Pin" name="CUS_Add_List[@i].CUS_ADD_Pin" class="form-control CUS_ADD_Pin" autocomplete="off" value="@Model[i].CUS_ADD_Pin" />
                            </td>
                            <td>
                                <input id="CUS_ADD_GSTIN" name="CUS_Add_List[@i].CUS_ADD_GSTIN" class="form-control CUS_ADD_GSTIN" autocomplete="off" value="@Model[i].CUS_ADD_GSTIN" />
                            </td>
                            <td class="table-col-sm text-center">
                                <input type="checkbox" id="CUS_ADD_Primary" name="CUS_Add_List[@i].CUS_ADD_Primary" class="form-check-input CUS_ADD_Primary" value="@(@Model[i].CUS_ADD_Primary ? "true" : "flase")" @(@Model[i].CUS_ADD_Primary ? "checked" : "") />
                            </td>
                            <td class="action text-center">
                                @if (@Model[i].CUS_ADD_Number != 0)
                                {
                                    <input name="CUS_Add_List[@i].CUS_ADD_Number" type="hidden" class="CUS_ADD_Number" value="@Model[i].CUS_ADD_Number" />
                                }
                                <input type="hidden" name="CUS_Add_List[@i].CUS_ADD_IsDeleted" class="CUS_ADD_IsDeleted" value="@Model[i].CUS_ADD_IsDeleted" />
                                <a class="AddRowRemove btn text-danger p-0 icon-link shadow-none">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                        <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                    </svg>
                                </a>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>
    </div>
    <div class="w-100 table-footer align-items-center">
        <a id="AddRowButton" class="btn btn-primary">Add Row</a>
    </div>
</div>

<script>
    
   

        function validateAddressGrid() {

        var isValid = true;
             $("#AddTableBody tr.AddNewRow:visible").each(function () {

            var row = $(this);

            // Skip deleted rows
            if (row.find(".CUS_ADD_IsDeleted").val() == "1") {
                return true;
            }

            var addressType = row.find(".CUS_ADD_ADTP_Number").val();
            var addressID = row.find(".CUS_ADD_AddressID").val().trim();

            var address = row.find(".CUS_ADD_Address").val().trim();
            var city = row.find(".CUS_ADD_City").val().trim();
            var state = row.find(".CUS_ADD_State").val().trim();
            var country = row.find(".CUS_ADD_Country").val().trim();
            var pin = row.find(".CUS_ADD_Pin").val().trim();
            var gstin = row.find(".CUS_ADD_GSTIN").val().trim();

            // Any other field entered
            var anyOtherFieldFilled =
                address != "" ||
                city != "" ||
                state != "" ||
                country != "" ||
                pin != "" ||
                gstin != "";

            // BOTH missing
            if (anyOtherFieldFilled && (addressType == "" || addressType == "0") && addressID == "") {

                alert("Address Type is required.\nAddress ID is required.");

                row.find(".CUS_ADD_ADTP_Number").focus();

                isValid = false;

                return false;
            }

            // Only Address Type missing
            else if (anyOtherFieldFilled && (addressType == "" || addressType == "0")) {

                alert("Address Type is required.");

                row.find(".CUS_ADD_ADTP_Number").focus();

                isValid = false;

                return false;
            }

            // Only Address ID missing
            else if (anyOtherFieldFilled && addressID == "") {

                alert("Address ID is required.");

                row.find(".CUS_ADD_AddressID").focus();

                isValid = false;

                return false;
            }
        });

        return isValid;
    }
        function validateDuplicateAddressID() {

        var addressIds = [];
        var isValid = true;

        // Only visible rows
        $("#AddTableBody tr.AddNewRow:visible").each(function () {

            var currentInput = $(this).find(".CUS_ADD_AddressID");

            var addressId = currentInput.val().trim();

            // Ignore empty values
            if (addressId != "") {

                // Duplicate found
                if (addressIds.includes(addressId)) {

                    alert("Duplicate Address ID not allowed !");

                    currentInput.focus();

                    isValid = false;

                    return false;
                }

                // Store unique AddressID
                addressIds.push(addressId);
            }
        });

        return isValid;
    }
    $(document).ready(function () {
        var rowCount = @(Model != null ? Model.Count : 0);
        var isAddRow = false;

        function addRow() {
            var NewRow = $("#AddTempRow").clone().removeAttr("style").removeAttr("id").addClass("AddNewRow");
            NewRow.find("select.CUS_ADD_ADTP_Number").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_ADTP_Number");
            NewRow.find("input.CUS_ADD_AddressID").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_AddressID");
            NewRow.find("input.CUS_ADD_Address").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_Address");
            NewRow.find("input.CUS_ADD_City").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_City");
            NewRow.find("input.CUS_ADD_State").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_State");
            NewRow.find("input.CUS_ADD_Country").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_Country");
            NewRow.find("input.CUS_ADD_Pin").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_Pin");
            NewRow.find("input.CUS_ADD_GSTIN ").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_GSTIN ");
            NewRow.find("input.CUS_ADD_Primary").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_Primary").val("false");
            NewRow.find("input.CUS_ADD_IsDeleted").attr("name", "CUS_Add_List[" + rowCount + "].CUS_ADD_IsDeleted").val(0);

            $("#AddTableBody").append(NewRow);
            rowCount++;
            NewRow.data("isValid", false);
            isAddRow = false;
        }

        if ($("tr.AddNewRow").length == 0) {
            addRow();
        }

        // $(document).on('change', 'tr.AddNewRow input.CUS_ADD_Primary', function() {
        //     if ($(this).is(':checked')) {
        //         $('tr.AddNewRow .CUS_ADD_Primary').not(this).prop('checked', false);

        //         $('tr.AddNewRow .CUS_ADD_Primary').val('true');
        //     } else {
        //         $('tr.AddNewRow .CUS_ADD_Primary').val('false');
        //     }
        // });

          $(document).on('click', '.AddRowRemove', function () {

        var row = $(this).closest('tr');

        row.find("input.CUS_ADD_IsDeleted").val(1);

        console.log("CUS_ADD_IsDeleted Value : ",
            row.find("input.CUS_ADD_IsDeleted").val());

        row.hide();
    });

        $(document).on('keydown', "tr.AddNewRow select, tr.AddNewRow input.CUS_ADD_Country, tr.AddNewRow input.CUS_ADD_City, tr.AddNewRow input.CUS_ADD_Pin, tr.AddNewRow input[type='text']", function (event) {
            if (event.keyCode === 9) {
                if (!validateField($(this)))
                    event.preventDefault();
            }
        });


        $(document).on("change", "tr.AddNewRow select, tr.AddNewRow input.CUS_ADD_Country, tr.AddNewRow input.CUS_ADD_City, tr.AddNewRow input.CUS_ADD_Pin, input[type='text']", function () {
            if (isAddRow)
                return;
            isAddRow = true;

            var currentInput = $(this);
            var isValid = validateField(currentInput);
            var currentRow = $(this).closest("tr.AddNewRow");
            if (isValid) {
                if (checkAllFieldsValid(currentRow)) {
                    currentRow.data("isValid", true);
                }
                else {
                    currentRow.data("isValid", false);
                }
            }
            else {
                currentRow.data("isValid", false);
            }
            if (currentRow.data("isValid")) {
                var lastRow = $("tr.AddNewRow").last();
                if (checkAllFieldsValid(lastRow))
                    addRow();
            }
            else {
                isAddRow = false;
            }
        });

        function checkAllFieldsValid(currentRow) {
            var allFieldsValid = true;
            $("tr.AddNewRow:visible").each(function () {
                $(this).find("select.CUS_ADD_ADTP_Number,input.CUS_ADD_AddressID").each(function () {
                    if (!validateField($(this))) {
                        allFieldsValid = false;
                        return false;
                    }
                });
                if (!allFieldsValid) return false;
            });
                var addressIds = [];

    $("tr.AddNewRow:visible").find("input.CUS_ADD_AddressID").each(function () {

        var value = $(this).val().trim();

        if (value != "") {

            if (addressIds.includes(value)) {

                alert("Duplicate Address ID not allowed !");

                $(this).focus();

                allFieldsValid = false;

                return false;
            }

            addressIds.push(value);
        }
    });
            return allFieldsValid;
        }

        function validateField(currentInput) {
            var valid = 1;
            var inputValue = currentInput.val();
            if (inputValue === "") {
                valid = 0;
            }

            if (valid == 0) {
                return false;
            }
            else {
                return true;
            }
        }
        function AddRowFun()
        {
             validateAddressGrid();
            validateDuplicateAddressID();
            var lastRow = $("tr.AddNewRow").last();
            if (checkAllFieldsValid(lastRow)) {
                addRow();
                return true;
            }
              else {

        let firstInvalidField = null;
        let errorMessage = "";

        // Check Address Type (dropdown)
        let addressType = lastRow.find("select.CUS_ADD_ADTP_Number");
        if (addressType.length > 0 && !addressType.val()) {
            firstInvalidField = addressType;
            errorMessage = "Please enter Address Type";
        }

        // Check Address ID (textbox)
        let addressId = lastRow.find("input.CUS_ADD_AddressID");
        if (!errorMessage && addressId.length > 0 && !addressId.val().trim()) {
            firstInvalidField = addressId;
            errorMessage = "Please enter Address ID";
        }

        if (firstInvalidField != null) {
            $("#AlertMessage").text(errorMessage);
            $("#AlertModal").modal('show');

            firstInvalidField.focus();
            return false;
        }
    }
        }

        $("#AddRowButton").click(function () {
           AddRowFun()
        });


        function isDuplicateAddress(type, addressId, currentRow) {
            var isDuplicate = false;

            $('tr.AddNewRow:visible').not(currentRow).each(function() {
                var rowType = $(this).find('.CUS_ADD_ADTP_Number').val();
                var rowAddressId = $(this).find('.CUS_ADD_AddressID').val();

                if (rowType === type && rowAddressId === addressId) {
                    isDuplicate = true;
                    return false;
                }
            });

            return isDuplicate;
        }

        $(document).on('change', '.CUS_ADD_ADTP_Number', function() {
            var currentRow = $(this).closest('tr.AddNewRow');
            var addressType = $(this).val();
            var addressId = currentRow.find('.CUS_ADD_AddressID').val();

            if (addressType && addressId && isDuplicateAddress(addressType, addressId, currentRow)) {
                alert('This Address ID already exists for the selected Address Type!');
                currentRow.find('.CUS_ADD_AddressID').focus();
            }
        });

        $(document).on('change', '.CUS_ADD_AddressID', function() {
            var currentRow = $(this).closest('tr.AddNewRow');
            var addressType = currentRow.find('.CUS_ADD_ADTP_Number').val();
            var addressId = $(this).val();

            if (addressType && addressId && isDuplicateAddress(addressType, addressId, currentRow)) {
                alert('This Address ID already exists for the selected Address Type!');
                $(this).focus();
            }
        });

        $(document).on('change', '.CUS_ADD_Primary', function(event) {
            var CurrentRow = $(this).closest('tr.AddNewRow');
            var AddressType = CurrentRow.find('.CUS_ADD_ADTP_Number').val();
            var AddressID = CurrentRow.find('.CUS_ADD_AddressID').val();

            if ($(this).is(':checked') && AddressType) {
                    $('tr.AddNewRow').not(CurrentRow).each(function() {
                        var RowType = $(this).find('.CUS_ADD_ADTP_Number').val();
                        var RowId = $(this).find('.CUS_ADD_AddressID').val();
                        if (RowType === AddressType) {
                            $(this).find('.CUS_ADD_Primary').prop('checked', false);
                            $(this).find('.CUS_ADD_Primary').val('false');
                        }
                    });
            }
            $(this).val('true');
        });

            $("#btnSave, #btnUpdate").on("click", function (e) {

        var lastRow = $("tr.AddNewRow").last();

        var hasAnyValue = false;

        lastRow.find("input:not([type='hidden']):not([type='button']):not([type='submit']), select, textarea").each(function () {

            if ($(this).prop("disabled")) return true;

            if ($(this).is(":checkbox")) {

                if ($(this).is(":checked")) {
                    hasAnyValue = true;
                    return false;
                }

            } else {

                if ($.trim($(this).val()) !== "") {
                    hasAnyValue = true;
                    return false;
                }
            }
        });

        // ✅ IMPORTANT: If row is completely empty → STOP HERE
        if (!hasAnyValue) {
            return true; // no validation, no AddRowFun, no submit block
        }

        // Only validate when user entered something
        if (!AddRowFun()) {
            e.preventDefault();
            return false;
        }

    });
    });
     
</script>