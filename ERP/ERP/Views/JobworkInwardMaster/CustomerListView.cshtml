@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}
<div class="row table-cal align-items-center">
    <div class="col align-items-center">
        <form asp-action="Customer" method="get">
            <div class="row align-items-center">
                <div class="col text-dark py-1">
                    @{
                        Int32 TotalSize = Convert.ToInt32(ViewData["TotalSize"]);
                        Int32 PageNumber = Convert.ToInt32(ViewData["PageNumber"]);
                        Int32 PageSize = Convert.ToInt32(ViewData["PageSize"]);
                        Int32 StartNumber = 1;
                        Int32 EndNumber = 0;

                        if (PageNumber > 1)
                        {
                            StartNumber = StartNumber + ((PageNumber - 1) * PageSize);
                        }
                        EndNumber = (EndNumber + PageSize) + ((PageNumber - 1) * PageSize);
                        if (EndNumber > TotalSize)
                        {
                            EndNumber = TotalSize;
                        }

                        if (StartNumber > EndNumber)
                        {
                            StartNumber = EndNumber;
                        }
                    }
                    Showing @StartNumber to @EndNumber
                </div>
                <div class="col text-center">
                    Total records @TotalSize
                </div>
                <div class="col">
                    <nav>
                        <ul class="pagination mb-0 float-end">
                            <li class="page-Buyer">
                                <a asp-action="Customer" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex - 1)" class="page-link @prevDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                        <path fill-rule="evenodd" d="M12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                    </svg>
                                </a>
                            </li>
                            <li class="page-Buyer">
                                <a asp-action="Customer" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex + 1)" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                    </svg>
                                </a>
                            </li>
                            <li>
                                <a class="page-link">
                                    @ViewData["PageNumber"]
                                </a>
                            </li>
                            <li class="page-Buyer">
                                <a asp-action="Customer" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex + 1)" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708" />
                                    </svg>
                                </a>
                            </li>
                            <li class="page-Buyer">
                                <a asp-action="Customer" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@ViewData["PageCount"]" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-right" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708" />
                                        <path fill-rule="evenodd" d="M7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708" />
                                    </svg>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </form>
    </div>
</div>