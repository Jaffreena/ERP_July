                                                                                    <input name="Items[0].JISVOI_Item_Number"
                                                                                           type="hidden"
                                                                                           class="JISVOI_Item_Number" />

                                                                                    <input name="Items[0].JISVOI_Item_Code"
                                                                                           autocomplete="off"
                                                                                           class="form-control JISVOI_Item_Code"
                                                                                           oninput="OnInputItem(this)"
                                                                                           onfocus="OnFocusItem(this)" />

                                                                             <div class="search-results card"
       style="display:none; min-height:100px; max-height:600px; overflow-y:auto;">
  </div>
                                                                                </td>

                                                                                <td>
                                                                    <textarea name="Items[0].Description"
                                                                              class="form-control Description"
                                                                              rows="2"
                                                                              readonly></textarea>

                                                                                   
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].OuterDia"
                                                                           class="form-control OuterDia text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Thickness"
                                                                           class="form-control Thickness text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Length"
                                                                           class="form-control Length text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Width"
                                                                                           class="form-control Width text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].MaterialGrade"
                                                                                           class="form-control MaterialGrade"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].ItemGroup"
                                                                                           class="form-control ItemGroup"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <select name="Items[0].JISVOI_UoM_Number"
                                                                            class="form-select JISVOI_UoM_Number text-center"
                                                                                            asp-items="@ViewBag.UOM">
                                                                                    </select>
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_Qty"
                                                                                           class="form-control JISVOI_Qty text-center" />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_UnitPrice"
                                                                           class="form-control JISVOI_UnitPrice text-end" />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_Amount"
                                                                                           class="form-control JISVOI_Amount text-end"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_DeliveryDate"
                                                                                           type="date"
                                                                           class="form-control datepicker JISVOI_DeliveryDate text-center" />
                                                                                </td>

                                                                            </tr>
                                                                            <tr class="NewRow" data-rowid="1">

                                                                                <td class="p-2 del">
                                                                                    <input type="checkbox"
                                                                                           class="CheckItem form-check-input">
                                                                                </td>

                                                                                <td>
                                                                                    <select name="Items[0].JISVOI_PRS_Number"
                                                                                            class="form-select JISVOI_PRS_Number"
                                                                                            asp-items="@ViewBag.Process">
                                                                                    </select>
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_IsDeleted"
                                                                                           type="hidden"
                                                                                           value="false"
                                                                                           class="JISVOI_IsDeleted" />
                                                                                    <input name="Items[0].JISVOI_Number"
                                                                                           type="hidden"
                                                                                           class="JISVOI_Number" />

                                                                                    <input name="Items[0].JISVOI_Item_Number"
                                                                                           type="hidden"
                                                                                           class="JISVOI_Item_Number" />

                                                                                    <input name="Items[0].JISVOI_Item_Code"
                                                                                           autocomplete="off"
                                                                                           class="form-control JISVOI_Item_Code"
                                                                                           oninput="OnInputItem(this)"
                                                                                           onfocus="OnFocusItem(this)" />

                                                                                     <div class="search-results card"
       style="display:none; min-height:100px; max-height:600px; overflow-y:auto;">
  </div>
                                                                                </td>

                                                                                <td>
                                                                    <textarea name="Items[0].Description"
                                                                              class="form-control Description"
                                                                              rows="2"
                                                                              readonly></textarea>
                                                                                  
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].OuterDia"
                                                                           class="form-control OuterDia text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Thickness"
                                                                                           class="form-control Thickness text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Length"
                                                                                           class="form-control Length text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].Width"
                                                                                           class="form-control Width text-center"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].MaterialGrade"
                                                                                           class="form-control MaterialGrade"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].ItemGroup"
                                                                                           class="form-control ItemGroup"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <select name="Items[0].JISVOI_UoM_Number"
                                                                                            class="form-select JISVOI_UoM_Number"
                                                                                            asp-items="@ViewBag.UOM">
                                                                                    </select>
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_Qty"
                                                                                           class="form-control JISVOI_Qty text-center" />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_UnitPrice"
                                                                                           class="form-control JISVOI_UnitPrice text-end" />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_Amount"
                                                                                           class="form-control JISVOI_Amount text-end"
                                                                                           readonly />
                                                                                </td>

                                                                                <td>
                                                                                    <input name="Items[0].JISVOI_DeliveryDate"
                                                                                           type="date"
                                                                           class="form-control datepicker JISVOI_DeliveryDate text-center" />
                                                                                </td>

                                                                            </tr>
                                                                        </tbody>

                                                                        <tfoot>
                                                                            <tr class="table-info">
                                                                                <td colspan="11" class="text-end py-2">
                                                                                    <span class="float-end pe-3">Total</span>
                                                                                </td>

                                                                                <td>
                                                                                    <input id="TotalQty"
                                                                                           class="form-control text-end"
                                                                                           readonly />
                                                                                </td>

