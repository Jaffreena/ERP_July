@model ERP_DTO.SaleOrderHead_DTO


@if (Model.SOH_Number != 0)
{
    <input asp-for="SOH_Number" type="hidden" readonly class="Number" />
}

<div class="row">
    <div class="col-12 col-md-3">
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_RegNo" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_RegNo" readonly class="form-control Key KeyDup" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_RegDate" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_RegDate" readonly class="form-control Key datepicker" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_OrderNo" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_OrderNo" readonly class="form-control Key KeyDup" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_OrderDate" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_OrderDate" readonly class="form-control Key datepicker" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_ExportOrder" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input class="form-check-input" disabled type="checkbox" asp-for="SOH_ExportOrder" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_MS_Number" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <select asp-for="SOH_MS_Number" readonly class="form-select" asp-items="@ViewBag.MaterialSegregation"></select>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">

        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_BUY_Number" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_BUY_Number" readonly class="form-control" type="hidden" />
                <input asp-for="SOH_BUY_LOC_Number" readonly class="form-control" type="hidden" />
                <input asp-for="SOH_BUY_Name" readonly class="form-control" autocomplete="off" />
                <div class="buyer-search-results bg-primary card" style="display:none"></div>
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_CUR_Number" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_CUR_Name" readonly class="form-control" autocomplete="off" />
                <input asp-for="SOH_CUR_Number" readonly class="form-control" type="hidden" />
                <input asp-for="SOH_CUR_DecimalPlaces" readonly class="form-control" type="hidden" />
            </div>
        </div>
        <div id="ExchangeRate" class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_ExchangeRate" class="col-sm-5 col-form-label ps-0 text-nowrap"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_ExchangeRate" readonly class="form-control Key decimal" autocomplete="off" />
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_PaymentTerms" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_PaymentTerms" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_PaymentMethod" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_PaymentMethod" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_DeliveryTerms" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_DeliveryTerms" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_DeliveryMethod" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_DeliveryMethod" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
    </div>
    <div class="col-12 col-md-3">
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_QCR" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_QCR" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_TDC" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_TDC" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
        <div class="row align-items-center px-2 mb-1">
            <label asp-for="SOH_OtherRemarks" class="col-sm-5 col-form-label ps-0"></label>
            <div class="col-sm-7">
                <input asp-for="SOH_OtherRemarks" readonly class="form-control Key" autocomplete="off" />
            </div>
        </div>
    </div>
</div>
