@model ERP_DTO.SaleOrderHead_DTO


@if (Model.SOH_Number != 0)
{
    <input asp-for="SOH_Number" type="hidden" class="Number" />
}

<div class="col-auto left-menu text-black">
    <div class="row">
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_RegNo" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_RegNo" class="form-control Key KeyDup" readonly autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_RegDate" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_RegDate" class="form-control Key datepicker" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_OrderNo" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_OrderNo" class="form-control Key KeyDup"  autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_OrderDate" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_OrderDate" class="form-control Key datepicker" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_ExportOrder" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input class="form-check-input" type="checkbox" asp-for="SOH_ExportOrder" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_MS_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <select asp-for="SOH_MS_Number" class="form-select" asp-items="@ViewBag.MaterialSegregation"></select>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_BUY_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_BUY_Number" class="form-control" type="hidden" />
                    <input asp-for="SOH_BUY_LOC_Number" class="form-control" type="hidden" />
                    <input asp-for="SOH_BUY_Name" class="form-control" autocomplete="off" oninput="OnBuyerInput(this)" onfocus="OnBuyerFocus(this)" />
                    <div class="buyer-search-results bg-primary card" style="display:none"></div>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_CUR_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_CUR_Name" class="form-control" readonly autocomplete="off" />
                    <input asp-for="SOH_CUR_Number" class="form-control" type="hidden" />
                    <input asp-for="SOH_CUR_DecimalPlaces" class="form-control" type="hidden" />
                </div>
            </div>
            <div id="ExchangeRate" class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_ExchangeRate" class="col-sm-5 col-form-label ps-0 text-nowrap"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_ExchangeRate" class="form-control Key decimal" autocomplete="off" />
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_PaymentTerms" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_PaymentTerms" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_PaymentMethod" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_PaymentMethod" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_DeliveryTerms" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_DeliveryTerms" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_DeliveryMethod" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_DeliveryMethod" class="form-control Key" autocomplete="off" />
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_QCR" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_QCR" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_TDC" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_TDC" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SOH_OtherRemarks" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SOH_OtherRemarks" class="form-control Key" autocomplete="off" />
                </div>
            </div>
        </div>
    </div>
</div>
<div class="col-auto right-menu text-center border-start">
    @if (Model.SOH_Number != 0)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    <button type="button" class="btn btn-primary btn-sm px-1 w-100 mb-1" id="IncomeModal" data-bs-toggle="modal" data-bs-target="#Income">
        Header Misc.Income
    </button>
    <button type="button" class="btn btn-primary btn-sm px-1 w-100 mb-1" data-bs-toggle="modal" data-bs-target="#BuyerAddress">
        Address
    </button>
</div>