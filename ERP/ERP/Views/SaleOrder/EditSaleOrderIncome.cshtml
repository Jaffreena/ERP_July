@model List<ERP_DTO.SaleOrderIncome_DTO>

<div class="w-100 table-responsive">
    <table class="table table-bordered table-hover align-middle table-grid mb-0">
        <thead>
            <tr class="table-info">
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_MIC_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_MIC_Description)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_Remarks)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_OCRN_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_CM_Number)</th>
                <th class="table-width-xl text-end">@Html.DisplayNameFor(M => M.First().SOH_INC_IncomeBase)</th>
                <th class="table-width-3xl text-end">@Html.DisplayNameFor(M => M.First().SOH_INC_IncomeValue)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_ALCT_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOH_INC_LA_Number)</th>
                <th class="action text-center">Action</th>
            </tr>
        </thead>
        <tbody id="InTableBody">
            <tr id="InTempRow" style="display: none;">
                <td>
                    <select id="SOH_INC_MIC_Number" class="form-select SOH_INC_MIC_Number" asp-items="@ViewBag.IncomeCode"></select>
                </td>
                <td>
                    <input id="SOH_INC_MIC_Description" class="form-control SOH_INC_MIC_Description" readonly autocomplete="off" />
                </td>
                <td>
                    <input id="SOH_INC_Remarks" class="form-control SOH_INC_Remarks" autocomplete="off" />
                </td>
                <td>
                    <select id="SOH_INC_OCRN_Number" class="form-select SOH_INC_OCRN_Number" asp-items="@ViewBag.Occurrence"></select>
                </td>
                <td>
                    <select id="SOH_INC_CM_Number" class="form-select SOH_INC_CM_Number" asp-items="@ViewBag.ChargeableMethod"></select>
                </td>
                <td class="table-width-xl">
                    <input id="SOH_INC_IncomeBase" class="form-control SOH_INC_IncomeBase decimal text-end" autocomplete="off" />
                </td>
                <td class="table-width-3xl">
                    <input id="SOH_INC_IncomeValue" class="form-control SOH_INC_IncomeValue decimal text-end" readonly autocomplete="off" />
                </td>
                <td>
                    <select id="SOH_INC_ALCT_Number" class="form-select SOH_INC_ALCT_Number" asp-items="@ViewBag.Allocate"></select>
                </td>
                <td>
                    <select id="SOH_INC_LA_Number" class="form-select SOH_INC_LA_Number" asp-items="@ViewBag.LedgerAccount"></select>
                </td>
                <td class="action text-center">
                    <input type="hidden" id="SOH_INC_IsDeleted" class="SOH_INC_IsDeleted" />
                    <a class="InRowRemove text-danger p-0 icon-link shadow-none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                            <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                        </svg>
                    </a>
                </td>
            </tr>

            @if (Model != null)
            {
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr class="InNewRow" style="@(@Model[i].SOH_INC_IsDeleted == 1 ? "display: none;" : "")">
                        <td>
                            <select id="SOH_INC_MIC_Number" name="Income[@i].SOH_INC_MIC_Number" class="form-select SOH_INC_MIC_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.IncomeCode)
                                {
                                    if (item.Value == Model[i].SOH_INC_MIC_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <input id="SOH_INC_MIC_Description" name="Income[@i].SOH_INC_MIC_Description" class="form-control SOH_INC_MIC_Description" readonly autocomplete="off" value="@Model[i].SOH_INC_MIC_Description" />
                        </td>
                        <td>
                            <input id="SOH_INC_Remarks" name="Income[@i].SOH_INC_Remarks" class="form-control SOH_INC_Remarks" autocomplete="off" value="@Model[i].SOH_INC_Remarks" />
                        </td>
                        <td>
                            <select id="SOH_INC_OCRN_Number" name="Income[@i].SOH_INC_OCRN_Number" class="form-select SOH_INC_OCRN_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Occurrence)
                                {
                                    if (item.Value == Model[i].SOH_INC_OCRN_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select id="SOH_INC_CM_Number" name="Income[@i].SOH_INC_CM_Number" class="form-select SOH_INC_CM_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ChargeableMethod)
                                {
                                    if (item.Value == Model[i].SOH_INC_CM_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="table-width-xl">
                            <input id="SOH_INC_IncomeBase" name="Income[@i].SOH_INC_IncomeBase" class="form-control SOH_INC_IncomeBase decimal text-end" autocomplete="off" value="@Model[i].SOH_INC_IncomeBase" />
                        </td>
                        <td class="table-width-3xl">
                            <input id="SOH_INC_IncomeValue" name="Income[@i].SOH_INC_IncomeValue" class="form-control SOH_INC_IncomeValue decimal text-end" readonly autocomplete="off" value="@Model[i].SOH_INC_IncomeValue" />
                        </td>
                        <td>
                            <select id="SOH_INC_ALCT_Number" name="Income[@i].SOH_INC_ALCT_Number" class="form-select SOH_INC_ALCT_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Allocate)
                                {
                                    if (item.Value == Model[i].SOH_INC_ALCT_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select id="SOH_INC_LA_Number" name="Income[@i].SOH_INC_LA_Number" class="form-select SOH_INC_LA_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.LedgerAccount)
                                {
                                    if (item.Value == Model[i].SOH_INC_LA_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="action text-center">
                            @if (@Model[i].SOH_INC_Number != 0)
                            {
                                <input name="Income[@i].SOH_INC_Number" type="hidden" class="SOH_INC_Number" value="@Model[i].SOH_INC_Number" />
                            }
                            <input type="hidden" name="Income[@i].SOH_INC_IsDeleted" id="SOH_INC_IsDeleted" class="SOH_INC_IsDeleted" value="@Model[i].SOH_INC_IsDeleted" />
                            <a class="InRowRemove text-danger p-0 icon-link shadow-none">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                    <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr class="table-info">
                <td colspan="6" class="text-end py-2">Total</td>
                <td class="table-width-3xl text-end">
                    <input id="TotalIncAmount" class="form-control text-end" readonly />
                </td>
                <td colspan="3">
                </td>
            </tr>
        </tfoot>
    </table>
</div>
<script>
    $(document).ready(function () {
        var rowCount = @(Model != null ? Model.Count : 0);
        var isAddingRow = false;

        function InAddRow() {
            var InNewRow = $("#InTempRow").clone().removeAttr("style").removeAttr("id").addClass("InNewRow");
            InNewRow.find("select.SOH_INC_MIC_Number").attr("name", "Income[" + rowCount + "].SOH_INC_MIC_Number");
            InNewRow.find("input.SOH_INC_MIC_Description").attr("name", "Income[" + rowCount + "].SOH_INC_MIC_Description");
            InNewRow.find("input.POH_SOH_INC_Remarks").attr("name", "Income[" + rowCount + "].POH_SOH_INC_Remarks");
            InNewRow.find("select.SOH_INC_OCRN_Number").attr("name", "Income[" + rowCount + "].SOH_INC_OCRN_Number");
            InNewRow.find("select.SOH_INC_CM_Number").attr("name", "Income[" + rowCount + "].SOH_INC_CM_Number");
            InNewRow.find("input.SOH_INC_IncomeBase").attr("name", "Income[" + rowCount + "].SOH_INC_IncomeBase");
            InNewRow.find("input.SOH_INC_IncomeValue").attr("name", "Income[" + rowCount + "].SOH_INC_IncomeValue");
            InNewRow.find("select.SOH_INC_ALCT_Number").attr("name", "Income[" + rowCount + "].SOH_INC_ALCT_Number");
            InNewRow.find("select.SOH_INC_LA_Number").attr("name", "Income[" + rowCount + "].SOH_INC_LA_Number");
            InNewRow.find("input.SOH_INC_IsDeleted").attr("name", "Income[" + rowCount + "].SOH_INC_IsDeleted").val(0);

            $("#InTableBody").append(InNewRow);
            rowCount++;
            InNewRow.data("isValid", false);
            isAddingRow = false;
        }

        document.getElementById('IncomeModal').addEventListener('click', AddNewRowClick);
        function AddNewRowClick() {
            var count = $("tr.InNewRow").filter(function () {
                var input = parseInt($(this).find('input.SOH_INC_IsDeleted').val());
                return input !== 1;
            }).length;

            if (count === 0) {
                InAddRow();
            }
        }

        if ($("tr.InNewRow").length == 0) {
            InAddRow();
        }

        var count = $("tr.InNewRow").filter(function () {
            return $(this).find("input.SOH_INC_IsDeleted").val() !== 1;
        }).length;

        if (count === 0) {
            InAddRow();
        }

        $(document).on('click', '.InRowRemove', function () {
            $(this).closest('tr').find("input.SOH_INC_IsDeleted").val(1);
            $(this).closest('tr').hide();
        });

        $(document).on('keydown', "tr.InNewRow select, tr.InNewRow input.SOH_INC_IncomeBase, tr.InNewRow input[type='text']", function (event) {
            if (event.keyCode === 9) {
                if (!InValidateField($(this)))
                    event.preventDefault();
            }
        });

        $(document).on("change", "tr.InNewRow select, tr.InNewRow input.SOH_INC_IncomeBase, input[type='text']", function () {
            if (isAddingRow)
                return;
            isAddingRow = true;

            var currentInput = $(this);
            var isValid = InValidateField(currentInput);
            var currentRow = $(this).closest("tr.InNewRow");
            if (isValid) {
                if (InCheckAllFieldsValid(currentRow)) {
                    currentRow.data("isValid", true);
                }
                else {
                    currentRow.data("isValid", false);
                }
            }
            else {
                currentRow.data("isValid", false);
            }
            if (currentRow.data("isValid")) {
                var lastRow = $("tr.InNewRow").last();
                if (InCheckAllFieldsValid(lastRow))
                    InAddRow();
            }
            else {
                isAddingRow = false;
            }
        });

        function InCheckAllFieldsValid(currentRow) {
            var allFieldsValid = true;
            $("tr.InNewRow:visible").each(function () {
                $(this).find("select, input.SOH_INC_IncomeBase, input[type='text']").each(function () {
                    if (!InValidateField($(this))) {
                        allFieldsValid = false;
                        return false;
                    }
                });
                if (!allFieldsValid) return false;
            });
            return allFieldsValid;
        }

        function InValidateField(currentInput) {
            var valid = 1;
            var inputValue = currentInput.val();
            if (inputValue === "") {
                valid = 0;
            }
            if (currentInput.hasClass(".SOH_INC_IncomeBase")) {
                valid = InValidateAmount(currentInput);
            }
            if (valid == 0) {
                return false;
            }
            else {
                return true;
            }
        }

        function InValidateAmount(currentInput) {
            var valid = 1;

            var currentRow = currentInput.closest("tr.InNewRow");
            var PercentInput = currentRow.find("input.SOH_INC_IncomeBase");
            var Percent = removeCommas(PercentInput.val());
            if (Percent > 0) {
            }
            else {
                valid = 0;
            }
            return valid;
        }

        $(document).on('change', "tr.InNewRow select.SOH_INC_MIC_Number", function () {
            var selectedValue = $(this).val();
            var Description = $(this).closest("tr.InNewRow").find(".SOH_INC_MIC_Description");
            var Ledger = $(this).closest("tr.InNewRow").find(".SOH_INC_LA_Number");
            var Allocate = $(this).closest("tr.InNewRow").find(".SOH_INC_ALCT_Number");
            var Occurrence = $(this).closest("tr.InNewRow").find(".SOH_INC_OCRN_Number");
            var Chargeable = $(this).closest("tr.InNewRow").find(".SOH_INC_CM_Number");

            $.ajax({
                type: "get",
                url: "../income/des",
                data: { Title: selectedValue },
                datatype: "json",
                traditional: true,
                success: function (Income) {
                    Description.val(Income.miC_Description);
                    Ledger.val(Income.miC_LA_Number);
                    Occurrence.val(Income.miC_OCRN_Number);
                    Chargeable.val(Income.miC_CM_Number);
                    Allocate.val(Income.miC_ALCT_Number);
                }
            });
        });

        $("#InCloseButton").click(function () {
            InCloseButton();
        });

        $("#InOkayButton").click(function () {
            InCloseButton();
        });

        function InCloseButton() {
            $("tr.InNewRow").each(function () {
                var IncomeCode = $(this).find("select.SOH_INC_MIC_Number").val();
                var Occurrence = $(this).find("select.SOH_INC_OCRN_Number").val();
                var ChargeableMethod = $(this).find("select.SOH_INC_CM_Number").val();
                var IncomeBase = removeCommas($(this).find("input.SOH_INC_IncomeBase").val());
                var Allocate = $(this).find("select.SOH_INC_ALCT_Number").val();
                var LedgerAccount = $(this).find("select.SOH_INC_LA_Number").val();

                if (!IncomeCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(IncomeBase > 0)) {
                    $(this).closest('tr').find("input.SOH_INC_IsDeleted").val(1);
                    $(this).closest('tr').hide();
                }
            });

            var lastRow = $("tr.InNewRow").last();
            if (InCheckAllFieldsValid(lastRow)) {
                $("#Income").modal('hide');

                CalculateFooter();
            }
            else {
                alert("Please complete all fields !");
            }
        }

        $(document).on('click', '.InAddRowButton', function () {
            var lastRow = $("tr.InNewRow").last();
            if (InCheckAllFieldsValid(lastRow)) {
                InAddRow();
            }
            else {
                var firstInvalidField = null;
                lastRow.find("select, input.SOH_INC_IncomeBase, input[type='text']").each(function () {
                    if (!InValidateField($(this))) {
                        if (firstInvalidField == null)
                            firstInvalidField = $(this);
                        return false;
                    }
                });
                if (firstInvalidField != null) {
                    alert("Please complete all fields !");
                    firstInvalidField.focus();
                }
            }
        });

        $(document).on('input', "input.SOH_INC_IncomeBase", function (event) {
            InAssignValue($(this));
            IncCalculateFooter();
        });

        $(document).on('change', "tr.InNewRow select.SOH_INC_CM_Number", function () {
            InAssignValue($(this));
            IncCalculateFooter();
        });

        window.onload = IncCalculateFooter();
    });

    async function IncCalculateFooter() {
        var TotalIncAmount = 0;
        $("tr.InNewRow").each(function () {
            var IncAmount = $(this).find(".SOH_INC_IncomeValue").val();
            TotalIncAmount += parseFloat(removeCommas(IncAmount));
        });
        $("#TotalIncAmount").val(DecimalIndianRupees(TotalIncAmount.toFixed(2)));
    }

    function InAssignValue(currentInput) {
        var row = currentInput.closest("tr.InNewRow");

        var Charge = row.find("select.SOH_INC_CM_Number").val();

        if (Charge === "1") {
            var IncomeBase = parseFloat(removeCommas(row.find("input.SOH_INC_IncomeBase").val())) || 0;
            row.find("input.SOH_INC_IncomeValue").val(DecimalIndianRupees(IncomeBase));
        }
        else if (Charge === "2") {
            var ItemQty = parseFloat(removeCommas($("#TotalQty").val())) || 0;
            var IncomeBase = parseFloat(removeCommas(row.find("input.SOH_INC_IncomeBase").val())) || 0;
            var IncomeValue = ItemQty * IncomeBase;
            row.find("input.SOH_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
        }
        else if (Charge === "3") {
            var ItemAmount = parseFloat(removeCommas($("#TotalAmount").val())) || 0;
            var IncomeBase = parseFloat(removeCommas(row.find("input.SOH_INC_IncomeBase").val())) || 0;
            var IncomeValue = ItemAmount * IncomeBase / 100;
            row.find("input.SOH_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
        }
    }
</script>
<style>
    .search-results {
        position: absolute;
        z-index: 1000;
        overflow-y: auto;
        width: 400px;
        max-height: 300px;
    }
</style>