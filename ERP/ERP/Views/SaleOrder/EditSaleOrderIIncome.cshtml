@model List<ERP_DTO.SaleOrderIIncome_DTO>

<div class="w-100 table-responsive">
    <table class="table table-bordered table-hover align-middle table-grid mb-0">
        <thead>
            <tr class="table-info">
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_MIC_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_MIC_Description)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_Remarks)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_OCRN_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_CM_Number)</th>
                <th class="table-width-xl text-end">@Html.DisplayNameFor(M => M.First().SOI_INC_IncomeBase)</th>
                <th class="table-width-3xl text-end">@Html.DisplayNameFor(M => M.First().SOI_INC_IncomeValue)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_ALCT_Number)</th>
                <th>@Html.DisplayNameFor(M => M.First().SOI_INC_LA_Number)</th>
                <th class="action text-center">Action</th>
            </tr>
        </thead>
        <tbody id="IInTableBody">
            <tr id="IInTempRow" style="display: none;">
                <td>
                    <input id="SOI_INC_SOI_Number" class="SOI_INC_SOI_Number" type="hidden" />
                    <input id="SOI_INC_ITM_Number" class="SOI_INC_ITM_Number" type="hidden" />
                    <input id="SOI_INC_ITM_Index" class="SOI_INC_ITM_Index" type="hidden" />
                    <select id="SOI_INC_MIC_Number" class="form-select SOI_INC_MIC_Number" asp-items="@ViewBag.IncomeCode"></select>
                </td>
                <td>
                    <input id="SOI_INC_MIC_Description" class="form-control SOI_INC_MIC_Description" readonly autocomplete="off" />
                </td>
                <td>
                    <input id="SOI_SOI_INC_Remarks" class="form-control SOI_INC_Remarks" autocomplete="off" />
                </td>
                <td>
                    <select id="SOI_INC_OCRN_Number" class="form-select SOI_INC_OCRN_Number" asp-items="@ViewBag.Occurrence"></select>
                </td>
                <td>
                    <select id="SOI_INC_CM_Number" class="form-select SOI_INC_CM_Number" asp-items="@ViewBag.ChargeableMethod"></select>
                </td>
                <td class="table-width-xl">
                    <input id="SOI_INC_IncomeBase" class="form-control SOI_INC_IncomeBase decimal text-end" autocomplete="off" />
                </td>
                <td class="table-width-3xl">
                    <input id="SOI_INC_IncomeValue" class="form-control SOI_INC_IncomeValue decimal text-end" readonly autocomplete="off" />
                </td>
                <td>
                    <select id="SOI_INC_ALCT_Number" class="form-select SOI_INC_ALCT_Number" asp-items="@ViewBag.Allocate"></select>
                </td>
                <td>
                    <select id="SOI_INC_LA_Number" class="form-select SOI_INC_LA_Number" asp-items="@ViewBag.LedgerAccount"></select>
                </td>
                <td class="action text-center">
                    <input type="hidden" id="SOI_INC_IsDeleted" class="SOI_INC_IsDeleted" />
                    <a class="IInRowRemove text-danger p-0 icon-link shadow-none">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                            <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                        </svg>
                    </a>
                </td>
            </tr>
            @if (Model != null)
            {
                @for (int i = 0; i < Model.Count; i++)
                {
                    <tr class="IInNewRow" style="@(@Model[i].SOI_INC_IsDeleted == 1 ? "display: none;" : "")">
                        <td>
                            <input id="SOI_INC_SOI_Number" name="ItemExpenses[@i].SOI_INC_SOI_Number" class="SOI_INC_SOI_Number" type="hidden" value="@Model[i].SOI_INC_SOI_Number" />
                            <input id="SOI_INC_ITM_Number" name="ItemIncome[@i].SOI_INC_ITM_Number" class="SOI_INC_ITM_Number" type="hidden" value="@Model[i].SOI_INC_ITM_Number" />
                            <input id="SOI_INC_ITM_Index" name="ItemIncome[@i].SOI_INC_ITM_Index" class="SOI_INC_ITM_Index" type="hidden" value="@Model[i].SOI_INC_ITM_Index" />
                            <select id="SOI_INC_MIC_Number" name="ItemIncome[@i].SOI_INC_MIC_Number" class="form-select SOI_INC_MIC_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.IncomeCode)
                                {
                                    if (item.Value == Model[i].SOI_INC_MIC_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <input id="SOI_INC_MIC_Description" name="ItemIncome[@i].SOI_INC_MIC_Description" readonly class="form-control SOI_INC_MIC_Description" autocomplete="off" value="@Model[i].SOI_INC_MIC_Description" />
                        </td>
                        <td>
                            <input id="SOI_INC_Remarks" name="ItemIncome[@i].SOI_INC_Remarks" class="form-control SOI_INC_Remarks" autocomplete="off" value="@Model[i].SOI_INC_Remarks" />
                        </td>
                        <td>
                            <select id="SOI_INC_OCRN_Number" name="ItemIncome[@i].SOI_INC_OCRN_Number" class="form-select SOI_INC_OCRN_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Occurrence)
                                {
                                    if (item.Value == Model[i].SOI_INC_OCRN_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select id="SOI_INC_CM_Number" name="ItemIncome[@i].SOI_INC_CM_Number" class="form-select SOI_INC_CM_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.ChargeableMethod)
                                {
                                    if (item.Value == Model[i].SOI_INC_CM_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="table-width-xl">
                            <input id="SOI_INC_IncomeBase" name="ItemIncome[@i].SOI_INC_IncomeBase" class="form-control SOI_INC_IncomeBase decimal text-end" autocomplete="off" value="@Model[i].SOI_INC_IncomeBase" />
                        </td>
                        <td class="table-width-3xl">
                            <input id="SOI_INC_IncomeValue" name="ItemIncome[@i].SOI_INC_IncomeValue" readonly class="form-control SOI_INC_IncomeValue decimal text-end" autocomplete="off" value="@Model[i].SOI_INC_IncomeValue" />
                        </td>
                        <td>
                            <select id="SOI_INC_ALCT_Number" name="ItemIncome[@i].SOI_INC_ALCT_Number" class="form-select SOI_INC_ALCT_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Allocate)
                                {
                                    if (item.Value == Model[i].SOI_INC_ALCT_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select id="SOI_INC_LA_Number" name="ItemIncome[@i].SOI_INC_LA_Number" class="form-select SOI_INC_LA_Number">
                                @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.LedgerAccount)
                                {
                                    if (item.Value == Model[i].SOI_INC_LA_Number)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </td>
                        <td class="action text-center">
                            @if (@Model[i].SOI_INC_Number != 0)
                            {
                                <input name="ItemIncome[@i].SOI_INC_Number" type="hidden" class="SOI_INC_Number" value="@Model[i].SOI_INC_Number" />
                            }
                            <input type="hidden" name="ItemIncome[@i].SOI_INC_IsDeleted" value="@Model[i].SOI_INC_IsDeleted" class="SOI_INC_IsDeleted" />
                            <a class="IInRowRemove text-danger p-0 icon-link shadow-none">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                    <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
        <tfoot>
            <tr class="table-info">
                <td colspan="6" class="text-end py-2">Total</td>
                <td class="table-width-3xl text-end">
                    <input id="TotalIIncAmount" class="form-control text-end" readonly />
                </td>
                <td colspan="3">
                </td>
            </tr>
        </tfoot>
    </table>
</div>
<script>
    $(document).ready(function () {
        var rowCount = @(Model != null ? Model.Count : 0);
        var isAddingRow = false;

        function IInNewRow() {
            var IInNewRow = $("#IInTempRow").clone().removeAttr("style").removeAttr("id").addClass("IInNewRow");
            IInNewRow.find("input.SOI_INC_SOI_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_SOI_Number").val($("#SOI_TEMP_Number").val());
            IInNewRow.find("input.SOI_INC_ITM_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_ITM_Number").val($("#SOI_TEMP_ITM_Number").val());
            IInNewRow.find("input.SOI_INC_ITM_Index").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_ITM_Index").val($("#SOI_TEMP_Index").val());
            IInNewRow.find("select.SOI_INC_MIC_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_MIC_Number");
            IInNewRow.find("input.SOI_INC_MIC_Description").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_MIC_Description");
            IInNewRow.find("input.SOI_SOI_INC_Remarks").attr("name", "ItemIncome[" + rowCount + "].SOI_SOI_INC_Remarks");
            IInNewRow.find("select.SOI_INC_OCRN_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_OCRN_Number");
            IInNewRow.find("select.SOI_INC_CM_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_CM_Number");
            IInNewRow.find("input.SOI_INC_IncomeBase").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_IncomeBase");
            IInNewRow.find("input.SOI_INC_IncomeValue").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_IncomeValue");
            IInNewRow.find("select.SOI_INC_ALCT_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_ALCT_Number");
            IInNewRow.find("select.SOI_INC_LA_Number").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_LA_Number");
            IInNewRow.find("input.SOI_INC_IsDeleted").attr("name", "ItemIncome[" + rowCount + "].SOI_INC_IsDeleted").val(0);

            $("#IInTableBody").append(IInNewRow);
            rowCount++;
            IInNewRow.data("isValid", false);
            isAddingRow = false;
        }

        $(document).on('click', '.IInRowRemove', function () {
            $(this).closest('tr').find("input.SOI_INC_IsDeleted").val(1);
            $(this).closest('tr').hide();

            (async () => {
                IIncCalculateFooter();
            })();
        });

        $(document).on('keydown', "tr.IInNewRow select, tr.IInNewRow input.SOI_INC_IncomeBase, tr.IInNewRow input[type='text']", function (event) {
            if (event.keyCode === 9) {
                if (!IInValidateField($(this)))
                    event.preventDefault();
            }
        });

        $(document).on("change", "tr.IInNewRow select, tr.IInNewRow input.SOI_INC_IncomeBase, input[type='text']", function () {
            if (isAddingRow)
                return;
            isAddingRow = true;

            var currentInput = $(this);
            var isValid = IInValidateField(currentInput);
            var currentRow = $(this).closest("tr.IInNewRow");
            if (isValid) {
                if (IInCheckAllFieldsValid(currentRow)) {
                    currentRow.data("isValid", true);
                }
                else {
                    currentRow.data("isValid", false);
                }
            }
            else {
                currentRow.data("isValid", false);
            }
            if (currentRow.data("isValid")) {
                var lastRow = $("tr.IInNewRow").last();
                if (IInCheckAllFieldsValid(lastRow))
                    IInNewRow();
            }
            else {
                isAddingRow = false;
            }
        });

        function IInCheckAllFieldsValid(currentRow) {
            var allFieldsValid = true;
            $("tr.IInNewRow:visible").each(function () {
                $(this).find("select, input.SOI_INC_IncomeBase, input[type='text']").each(function () {
                    if (!IInValidateField($(this))) {
                        allFieldsValid = false;
                        return false;
                    }
                });
                if (!allFieldsValid) return false;
            });
            return allFieldsValid;
        }

        function IInValidateField(currentInput) {
            var valid = 1;
            var inputValue = currentInput.val();
            if (inputValue === "") {
                valid = 0;
            }
            if (currentInput.hasClass(".SOI_INC_IncomeBase")) {
                valid = IIncValidateAmount(currentInput);
            }
            if (valid == 0) {
                return false;
            }
            else {
                return true;
            }
        }

        function IIncValidateAmount(currentInput) {
            var valid = 1;

            var currentRow = currentInput.closest("tr.IInNewRow");
            var PercentInput = currentRow.find("input.SOI_INC_IncomeBase");
            var Percent = removeCommas(PercentInput.val());
            if (Percent > 0) {
            }
            else {
                valid = 0;
            }
            return valid;
        }

        $(document).on('change', "tr.IInNewRow select.SOI_INC_MIC_Number", function () {
            var selectedValue = $(this).val();
            var Description = $(this).closest("tr.IInNewRow").find(".SOI_INC_MIC_Description");
            var Ledger = $(this).closest("tr.IInNewRow").find(".SOI_INC_LA_Number");
            var Allocate = $(this).closest("tr.IInNewRow").find(".SOI_INC_ALCT_Number");
            var Occurrence = $(this).closest("tr.IInNewRow").find(".SOI_INC_OCRN_Number");
            var Chargeable = $(this).closest("tr.IInNewRow").find(".SOI_INC_CM_Number");

            $.ajax({
                type: "get",
                url: "../income/des",
                data: { Title: selectedValue },
                datatype: "json",
                traditional: true,
                success: function (Income) {
                    Description.val(Income.miC_Description);
                    Ledger.val(Income.miC_LA_Number);
                    Occurrence.val(Income.miC_OCRN_Number);
                    Chargeable.val(Income.miC_CM_Number);
                    Allocate.val(Income.miC_ALCT_Number);
                }
            });
        });

        $("#IInCloseButton").click(function () {
            IInCloseButton();
        });

        $("#IInOkayButton").click(function () {
            IInCloseButton();
        });

        function IInCloseButton() {
            $("tr.IInNewRow").each(function () {
                var IncomeCode = $(this).find("select.SOI_INC_MIC_Number").val();
                var Occurrence = $(this).find("select.SOI_INC_OCRN_Number").val();
                var ChargeableMethod = $(this).find("select.SOI_INC_CM_Number").val();
                var IncomeBase = removeCommas($(this).find("input.SOI_INC_IncomeBase").val());
                var Allocate = $(this).find("select.SOI_INC_ALCT_Number").val();
                var LedgerAccount = $(this).find("select.SOI_INC_LA_Number").val();

                if (!IncomeCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(IncomeBase > 0)) {
                    $(this).closest('tr').find("input.SOI_INC_IsDeleted").val(1);
                    $(this).closest('tr').hide();
                }
            });

            var lastRow = $("tr.IInNewRow").last();
            if (IInCheckAllFieldsValid(lastRow)) {
                $("#IIncome").modal('hide');

                CalAmount();
            }
            else {
                alert("Please complete all fields !");
            }

            CalculateFooter();
        }

        $("#IInNewRowButton").click(function () {
            var lastRow = $("tr.IInNewRow").last();
            if (IInCheckAllFieldsValid(lastRow)) {
                IInNewRow();
            }
            else {
                var firstInvalidField = null;
                lastRow.find("select, input.SOI_INC_IncomeBase, input[type='text']").each(function () {
                    if (!IInValidateField($(this))) {
                        if (firstInvalidField == null)
                            firstInvalidField = $(this);
                        return false;
                    }
                });
                if (firstInvalidField != null) {
                    alert("Please complete all fields !");
                    firstInvalidField.focus();
                }
            }
        });

        $(document).on('click', '.ItemIncomeView', function () {
            let CheckedCount = document.querySelectorAll('.CheckItem:checked').length;
            let CheckedCheckbox = document.querySelector('.CheckItem:checked');
            if(CheckedCount==0){
                alert("Select any one row from the list");

            } else if(CheckedCount>1){
                alert("Select only one row from the list");
            }
            else if(CheckedCount==1){
                var currentRow = $(CheckedCheckbox).closest('tr.NewRow');

                var ItemNumber = currentRow.find('input.SOI_ITM_Number').val();
                var Index = currentRow.find('input.SOI_Index').val();
                var Qty = currentRow.find('input.SOI_Qty').val();
                var MatrialValue = currentRow.find('input.SOI_Amount').val();
                var SOINumber = currentRow.find('input.SOI_Number').val();

                if (SOINumber) {
                    $("#SOI_TEMP_Number").val(SOINumber);
                    $("#SOI_TEMP_ITM_Number").val(ItemNumber);
                    $("#SOI_TEMP_ITM_Index").val(Index);
                    $("#SOI_TEMP_Qty").val(Qty);
                    $("#SOI_TEMP_Amount").val(MatrialValue);

                    var cout = 0;
                    $("tr.IInNewRow").each(function () {
                        var RowSOINumber = $(this).find("input.SOI_INC_SOI_Number").val();
                        var IsDeleted = $(this).find("input.SOI_INC_IsDeleted").val();

                        if (RowSOINumber === SOINumber && (IsDeleted != 1)) {
                            $(this).closest('tr').show();
                            cout++;
                        } else {
                            $(this).closest('tr').hide();
                        }
                    });

                    if (cout === 0) {
                        IInNewRow();
                    }

                    new bootstrap.Modal($("#IIncome")).show();
                    $('#IIncome').on('shown.bs.modal', function () {
                        $(this).find('[autofocus]').focus();

                        (async () => {
                            IIncCalculateFooter();
                        })();
                    });
                }
                else if (ItemNumber) {
                    $("#SOI_TEMP_ITM_Number").val(ItemNumber);
                    $("#SOI_TEMP_Number").val(SOINumber);
                    $("#SOI_TEMP_Index").val(Index);
                    $("#SOI_TEMP_Qty").val(Qty);
                    $("#SOI_TEMP_Amount").val(MatrialValue);

                    var cout = 0;
                    $("tr.IInNewRow").each(function () {
                        var RowItemNumber = $(this).find("input.SOI_INC_ITM_Number").val();
                        var RowItemIndex = $(this).find("input.SOI_INC_ITM_Index").val();
                        var IsDeleted = $(this).find("input.SOI_INC_IsDeleted").val();

                        if (RowItemNumber === ItemNumber && RowItemIndex === Index && (IsDeleted != 1)) {
                            $(this).closest('tr').show();
                            cout++;
                        } else {
                            $(this).closest('tr').hide();
                        }
                    });

                    if (cout === 0) {
                        IInNewRow();
                    }

                    new bootstrap.Modal($("#IIncome")).show();
                    $('#IIncome').on('shown.bs.modal', function () {
                        $(this).find('[autofocus]').focus();

                        (async () => {
                            IIncCalculateFooter();
                        })();
                    });
                }

            }
        });

        $(document).on('input', "input.SOI_INC_IncomeBase", function (event) {
            IInAssignValue($(this));
            IIncCalculateFooter();
        });

        $(document).on('change', "tr.IInNewRow select.SOI_INC_CM_Number", function () {
            IInAssignValue($(this));
            IIncCalculateFooter();
        });
    });


    async function IIncCalculateFooter() {
        var TotalIncAmount = 0;
        $("tr.IInNewRow:visible").each(function () {
            var IncAmount = $(this).find(".SOI_INC_IncomeValue").val();
            TotalIncAmount += parseFloat(removeCommas(IncAmount));
        });
        $("#TotalIIncAmount").val(DecimalIndianRupees(TotalIncAmount.toFixed(2)));
    }

    function IInAssignValue(currentInput) {
        var row = currentInput.closest("tr.IInNewRow");

        var Charge = row.find("select.SOI_INC_CM_Number").val();
        var IncomeBase = parseFloat(removeCommas(row.find("input.SOI_INC_IncomeBase").val())) || 0;

        if (Charge === "1") {
            row.find("input.SOI_INC_IncomeValue").val(DecimalIndianRupees(IncomeBase));
        }
        else if (Charge === "2") {
            var ItemQty = parseFloat(removeCommas($("#SOI_TEMP_Qty").val())) || 0;
            var IncomeValue = ItemQty * IncomeBase;
            row.find("input.SOI_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
        }
        else if (Charge === "3") {
            var ItemAmount = parseFloat(removeCommas($("#SOI_TEMP_Amount").val())) || 0;
            var IncomeValue = ItemAmount * IncomeBase / 100;
            row.find("input.SOI_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
        }
    }
</script>
<style>
    .search-results {
        position: absolute;
        z-index: 1000;
        overflow-y: auto;
        width: 400px;
        max-height: 300px;
    }
</style>