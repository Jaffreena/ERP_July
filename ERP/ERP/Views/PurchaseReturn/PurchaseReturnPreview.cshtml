<script>
    function Print() {
        $("#PreviewButton").click();

        var printContents = document.getElementById("PrintPage").innerHTML;

        const iframe = document.createElement('iframe');
        document.body.appendChild(iframe);
        const iframeDoc = iframe.contentWindow.document;
        iframeDoc.open();
        iframeDoc.write(printContents);
        iframeDoc.close();

        setTimeout(() => {
            try {
                iframe.contentWindow.focus();
                iframe.contentWindow.print();
            } catch (error) { console.error("Printing from iframe failed:", error); }
            finally { setTimeout(() => { document.body.removeChild(iframe); }, 1000); }
        }, 250);
    }


    function DecimalIndianRupees(value) {
        if (value === "" || isNaN(value)) {
            return "0.00";
        }

        var formattedValue = parseFloat(value).toFixed(2);

        var parts = formattedValue.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");
        return parts.join(".");
    }


    function NumberToIndianRupees(value, decimalPlaces) {
        if (value === "" || isNaN(value)) {
            return "0";
        }

        var formattedValue = parseFloat(value).toFixed(decimalPlaces);

        var parts = formattedValue.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");

        if (parseFloat(value) % 1 === 0) {
            return parts[0];
        }
        return parts.join(".");
    }
    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest('tr').find("input.PRI_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
