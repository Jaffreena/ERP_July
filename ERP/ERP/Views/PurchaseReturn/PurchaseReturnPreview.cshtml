    function SearchClustor() {
        var Vendor = $("#PRH_Vendor_Number").val();
        var TaxCluster = $("#PRH_TaxCluster_Number").val();
        if (Vendor) {
            $.ajax({
                url: '../cluster',
                data: { Vendor: Vendor },
                type: 'GET',
                success: function (data) {
                    if (data && data.length > 0) {
                        var dropdown = document.getElementById("PRH_TaxCluster_Number");
                        dropdown.innerHTML = "";

                        var option = document.createElement("option");
                        option.value = "";
                        option.text = "";
                        dropdown.appendChild(option);

                        data.forEach(function (item) {
                            var option = document.createElement("option");
                            option.value = item.taxClusterNumber;
                            option.text = item.taxCluster;
                            dropdown.appendChild(option);
                        });

                        if (TaxCluster) {
                            $("#PRH_TaxCluster_Number").val(TaxCluster);
                        }
                        else {
                            AssignGST();
                        }
                    }
                },
                error: function () {
                }
            });
        }
    }
    SearchClustor();


    document.addEventListener("DOMContentLoaded", function () {
