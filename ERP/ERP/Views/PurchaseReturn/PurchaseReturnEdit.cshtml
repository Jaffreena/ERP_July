<script>
    $('form').submit(function (event) {
        $("tr.ExNewRow").each(function () {
            var ExpenseCode = $(this).find("select.PRH_EXP_Expense_Number").val();
            var Occurrence = $(this).find("select.PRH_EXP_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.PRH_EXP_CM_Number").val();
            var ExpenseBase = removeCommas($(this).find("input.PRH_EXP_ExpenseBase").val());
            var Allocate = $(this).find("select.PRH_EXP_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.PRH_EXP_LA_Number").val();

            if (!ExpenseCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(ExpenseBase > 0)) {
                $(this).find("input.PRH_EXP_IsDeleted").val("true");
                $(this).hide();
            }
        });

        $("tr.IExNewRow").each(function () {
            var ExpenseCode = $(this).find("select.PRI_EXP_Expense_Number").val();
            var Occurrence = $(this).find("select.PRI_EXP_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.PRI_EXP_CM_Number").val();
            var ExpenseBase = removeCommas($(this).find("input.PRI_EXP_ExpenseBase").val());
            var Allocate = $(this).find("select.PRI_EXP_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.PRI_EXP_LA_Number").val();

            if (!ExpenseCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(ExpenseBase > 0)) {
                $(this).closest('tr').find("input.PRI_EXP_IsDeleted").val("true");
                $(this).closest('tr').hide();
            }
        });

        $("tr.NewRow").each(function () {
            var ItemNumber = $(this).find("input.PRI_Item_Number").val();
            var Qty = removeCommas($(this).find("input.PRI_Qty").val());
            var UnitPrice = removeCommas($(this).find("input.PRI_UnitPrice").val());
            var UoMNumber = $(this).find("select.PRI_UoM_Number").val();

            if (!ItemNumber && !UoMNumber && !(Qty > 0) && !(UnitPrice > 0)) {
                $(this).find("input.PRI_IsDeleted").val("true");
                $(this).hide();
            }
        });
    });

    function NumberToIndianRupees(value, decimalPlaces) {
        if (value === "" || isNaN(value)) {
            return "0";
        }

        var formattedValue = parseFloat(value).toFixed(decimalPlaces);

        var parts = formattedValue.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");

        if (parseFloat(value) % 1 === 0) {
            return parts[0];
        }
        return parts.join(".");
    }
    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest('tr').find("input.PRI_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
        $(this).val(NumberToIndianRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest('tr').find("input.PRI_DecimalPlaces").val();

        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(NumberToIndianRupees(value, decimalPlaces));
        }
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    $(".UnitDecimal").each(function () {
        var ValueResult = "0";
        var value = $(this).val();
        var decimalPlaces = $("#PRH_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
        ValueResult = formatToIndianRupees(removeCommas(value), decimalPlaces);
        $(this).val(ValueResult);
    });
    $(document).on("blur", ".UnitDecimal", function () {
        var ValueResult = "0";
        var value = $(this).val();

        var decimalPlaces = $("#PRH_DecimalPlaces").val();

        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }

        if (value.trim() === "" || isNaN(value)) {
        } else {
            ValueResult = formatToIndianRupees(value, decimalPlaces);
            $(this).val(ValueResult);
        }
    });
    $(document).on("focus", ".UnitDecimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });
    function formatToIndianRupees(value, UnitDecimalPlaces) {
        var ValueResult = "0";
        if (value === "" || isNaN(value)) {
        }
        else {
            ValueResult = value;
        }

        var fromat = parseFloat(ValueResult).toFixed(UnitDecimalPlaces);

        var parts = fromat.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");
        return parts.join(".");
    }

    function OnVendorInput(inputElement) {
        SearchVendor(inputElement);
    }
    function OnVendorFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchVendor(inputElement);
        }
        else {
            $(this).select();
        }
    }
    function SearchVendor(inputElement) {
        var vendor = inputElement.value;
        var PRHDATE = $("#PRH_ReturnDate").val();
        var resultsDiv = $(inputElement).next('.vendor-search-results');
        var isChecked = $("#PRH_ImportOrder").prop("checked");
        var Import;

        if (isChecked) {
            Import = true;
        } else {
            Import = false;
        }

        $.ajax({
            url: '../vendor',
            data: { Vendor: vendor, PRHDATE: PRHDATE, Import: Import },
            type: 'GET',
            success: function (data) {
                resultsDiv.empty();
                if (data && data.length > 0) {
                    resultsDiv.show();
                    var table = $('<div class="card-body modal-content"><table class="table table-bordered mb-0 table-hover"><thead><tr class="table-info"><th>Vendor Code</th><th>Vendor Name</th><th>Currency</th></tr></thead><tbody></tbody></table></div>');
                    data.forEach(function (ven) {
                        var row = $('<tr></tr>');
                        row.append('<td>' + ven.vendorCode + '</td>');
                        row.append('<td>' + ven.vendorName + '</td>');
                        row.append('<td>' + ven.currencyCode + '</td>');
                        table.find('tbody').append(row);

                        row.on('click', function () {
                            $(inputElement).val(ven.vendorName);
                            $("#PRH_Vendor_Number").val(ven.vendorNumber);
                            $("#PRH_Currency").val(ven.currencyCode);
                            $("#PRH_Currency_Number").val(ven.currency);
                            $("#PRH_VendorLocation").val(ven.vendorLocation);
                            $("#PRH_WHT_Number").val(ven.withholdTax);
                            $("#PRH_CreditDays").val(ven.creditDays);
                            $("#PRH_PaymentBase").val(ven.paymentBase);

                            resultsDiv.hide();

                            SearchClustor(ven.vendorNumber, ven.taxNumber);
                            GetWHT(ven.vendorNumber, ven.withholdTax, PRHDATE);

                            // if (ven.paymentBase === 2) {
                                var Date = $("#PRH_ReturnDate").val();
                                var Credit = $("#PRH_CreditDays").val();

                                if (Date == '') { } else {
                                    var CurentDate = addDays(Date, Credit);
                                    $("#PRH_DueDate").val(CurentDate);
                                }
                            // }
                            // else if (ven.paymentBase === 3) {
                            //     var Date = $("#PRH_SupplierReturnDate").val();
                            //     var Credit = $("#PRH_CreditDays").val();

                            //     if (Date == '') { } else {
                            //         var CurentDate = addDays(Date, Credit);
                            //         $("#PRH_DueDate").val(CurentDate);
                            //     }
                            // }
                            // else {
                            //     $("#PRH_DueDate").val("");
                            // }
                        });
                    });

                    var closeButton = $('<div class="card-header bg-primary py-1"><button type="button" class="p-0 float-end btn btn-sm btn-primary bg-opacity-10"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16"><path d = "M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"> </path></svg></button></div>');
                    closeButton.on('click', function () {
                        resultsDiv.hide();
                    });

                    resultsDiv.append(closeButton);
                    resultsDiv.append(table);
                } else {
                    resultsDiv.hide();
                    resultsDiv.append('<p>No results found</p>');
                }
            },
            error: function () {
                resultsDiv.text('Error loading data.');
                resultsDiv.show();
            }
        });
    }

    $(".decimal").each(function () {
        var value = $(this).val();
        $(this).val(DecimalIndianRupees(removeCommas(value)));
    });
    $(document).on("blur", ".decimal", function () {
        var value = $(this).val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0.00");
        } else {
            $(this).val(DecimalIndianRupees(removeCommas(value)));
        }
    });
    $(document).on("focus", ".decimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    function OnClustorInput(inputElement) {
        SearchVendor(inputElement);
    }
    function OnClustorFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchClustor(inputElement);
        }
        else {
            $(this).select();
        }
    }
    function SearchClustor(Vendor, taxNumber) {
        if (Vendor) {
            $.ajax({
                url: '../cluster',
                data: { Vendor: Vendor },
                type: 'GET',
                success: function (data) {
                    if (data && data.length > 0) {
                        var dropdown = document.getElementById("PRH_TaxCluster_Number");
                        dropdown.innerHTML = "";

                        var option = document.createElement("option");
                        option.value = "";
                        option.text = "";
                        dropdown.appendChild(option);

                        data.forEach(function (item) {
                            var option = document.createElement("option");
                            option.value = item.taxClusterNumber;
                            option.text = item.taxCluster;
                            dropdown.appendChild(option);
                        });
                    }

                    if (taxNumber) {
                        $("#PRH_TaxCluster_Number").val(taxNumber);
                    }
                    else {
                        AssignGST();
                    }
                },
                error: function () {
                    resultsDiv.text('Error loading data.');
                    resultsDiv.show();
                }
            });
        }
    }

    function addDays(date, days) {
        const dateAfterAddingDays = new Date(date);
        dateAfterAddingDays.setDate(dateAfterAddingDays.getDate() + parseInt(days));

        const day = dateAfterAddingDays.getDate().toString().padStart(2, '0');
        const year = dateAfterAddingDays.getFullYear();
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
            "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        const monthAbbr = monthNames[dateAfterAddingDays.getMonth()];

        const result = `${day}-${monthAbbr}-${year}`;
        return result;
    }

    function ExchangeVisibility() {
        if ($('#PRH_ImportOrder').is(':checked')) {
            $('#ExchangeRate').show();
        } else {
            $('#ExchangeRate').hide();
        }
    }

    flatpickr(".datepicker", {
        dateFormat: "d-M-Y",
        altInput: false,
    });

    function AssignGST() {
        var TaxCluster = $("#PRH_TaxClusterNumber").val();
        $("#PRH_TaxCluster_Number").val(TaxCluster);
    }

    document.addEventListener("DOMContentLoaded", function () {
        ExchangeVisibility();

        const MainDiv = document.getElementById('BodyHeight');
        const HeadDiv = document.getElementById('CardHeader');
        const BodyDiv = document.getElementById('CardBody');
        const FooterDiv = document.getElementById('CardFooter');

        if (HeadDiv && BodyDiv) {
            const MainHeight = MainDiv.offsetHeight;
            const HeadHeight = HeadDiv.offsetHeight;
            const FooterHeight = FooterDiv.offsetHeight;
            BodyDiv.style.height = (MainHeight - HeadHeight - FooterHeight - 10) + 'px';
        }
    });
</script>
