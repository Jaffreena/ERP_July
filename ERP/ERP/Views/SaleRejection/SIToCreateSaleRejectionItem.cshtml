                    $("#SRH_WHT_Percent").val(data.percentage);
                }
                else {
                    $("#SRH_WHT_Tax").val(1);
                    $("#SRH_WHT_Percent").val(0);
                }
                (async () => {
                    await CalculateAllIncomes();
                })();
            }
        });
    }

