    async function CalculateAll() {
        const $newRows = $("tr.NewRow");
        const $inNewRows = $("tr.InNewRow");
        const $iInxNewRows = $("tr.IInNewRow");
        const cluster = $("#SRH_TCT_Number").val() || $("#SRH_HIDE_TCT_Number").val();
        const RejectionDate = $("#SRH_RejectionDate").val();
        const whNumber = $("#SRH_WHT_Number").val();

        // Pre-calculate values that don't change during iteration
        const whTax = whNumber ? $("#SRH_WHT_Tax").val() : "1";
        const whPercent = whNumber ? $("#SRH_WHT_Percent").val() : 0;

        // Process items and Incomes in parallel
        const [itemResults, headerIncomeResults] = await Promise.all([
            processItems($newRows, $iInxNewRows, cluster, RejectionDate, whTax, whPercent),
        ]);

        // Calculate footer with all results
        await calculateFooter(itemResults, headerIncomeResults);
    }

    // Function to generate unique item key
    function generateItemKey(SRI_Number, SRI_ITM_Number, SRI_Index) {
        // Priority 1: Use SRI_Number if available and valid
        if (SRI_Number && parseInt(SRI_Number) > 0) {
            return `SRI_${SRI_Number}`;
        }
        // Priority 2: Use combination of ITM_Number and ITM_Index
        else if (SRI_ITM_Number && SRI_Index) {
            return `ITM_${SRI_ITM_Number}_${SRI_Index}`;
        }
        // Fallback: Generate random key for new items
        return `NEW_${Math.random().toString(36).substr(2, 9)}`;
    }

    async function processItems($newRows, $iInxNewRows, cluster, RejectionDate, whTax, whPercent) {
        const itemPromises = [];
        const itemIncomeMap = new Map();

        // Pre-calculate item Incomes with dual identification
        $iInxNewRows.each(function() {
            const $row = $(this);
            // ParseInt and compare to 1
            if (parseInt($row.find("input.SRI_INC_IsDeleted").val()) === 1) return;

            // Get both identification methods - FIXED FIELD NAMES
            const SRI_Number = $row.find("input.SRI_INC_SRI_Number").val();
            const SRI_ITM_Number = $row.find("input.SRI_INC_ITM_Number").val(); // FIXED
            const SRI_Index = $row.find("input.SRI_INC_ITM_Index").val(); // FIXED

            // Create unique key based on available identifiers
            const key = generateItemKey(SRI_Number, SRI_ITM_Number, SRI_Index);

            if (!itemIncomeMap.has(key)) {
                itemIncomeMap.set(key, []);
            }

            itemIncomeMap.get(key).push({
                IncomeBase: parseFloat(removeCommas($row.find("input.SRI_INC_IncomeBase").val())) || 0,
                charge: $row.find("select.SRI_INC_CM_Number").val(),
                row: $row
            });
        });

        // Process each item row
        $newRows.each(function() {
            const $row = $(this);
            // ParseInt and compare to 1
            if (parseInt($row.find('input.SRI_IsDeleted').val()) === 1) return;

            const promise = processSingleItem($row, itemIncomeMap, cluster, RejectionDate, whTax, whPercent);
            itemPromises.push(promise);
        });

        return Promise.all(itemPromises);
    }

    async function processSingleItem($row, itemIncomeMap, cluster, RejectionDate, whTax, whPercent) {
        // Get both identification methods for the current item
        const SRI_Number = $row.find('input.SRI_Number').val();
        const SRI_ITM_Number = $row.find('input.SRI_ITM_Number').val();
        const SRI_Index = $row.find('input.SRI_Index').val();

        // Generate the key to find matching incomes
        const key = generateItemKey(SRI_Number, SRI_ITM_Number, SRI_Index);
        const hsnNumber = $row.find('.SRI_HSN_Number').val();

        const qty = parseFloat(removeCommas($row.find('input.SRI_Qty').val())) || 0;
        const unitPrice = parseFloat(removeCommas($row.find('input.SRI_UnitPrice').val())) || 0;
        const materialValue = parseFloat(removeCommas($row.find('input.SRI_Amount').val())) || 0;

        // Process item Incomes
        let IncomeTotal = parseFloat(removeCommas($row.find('input.SRI_IncomeValue').val())) || 0;
        let gstAmount = parseFloat(removeCommas($row.find('input.SRI_GST_Amount').val())) || 0;
        let whtAmount = parseFloat(removeCommas($row.find('input.SRI_WHT_Amount').val())) || 0;


        return {
            qty: qty,
            amount: materialValue,
            Income: IncomeTotal,
            gst: gstAmount,
            wht: whtAmount
        };
    }

    // Utility function for safe number operations
    function safeNumber(value, defaultValue = 0) {
        const num = parseFloat(value);
        return isNaN(num) ? defaultValue : num;
    }

    async function calculateFooter(itemResults) {
        // Use safe number handling
        const itemTotals = itemResults.reduce((acc, item) => ({
            totalQty: acc.totalQty + safeNumber(item.qty),
            totalAmount: acc.totalAmount + safeNumber(item.amount),
            totalIncome: acc.totalIncome + safeNumber(item.Income),
            totalGst: acc.totalGst + safeNumber(item.gst),
            totalWHT: acc.totalWHT + safeNumber(item.wht)
        }), { totalQty: 0, totalAmount: 0, totalIncome: 0, totalGst: 0, totalWHT: 0 });

        const totalGst = parseFloat(safeNumber(itemTotals.totalGst).toFixed(2));
        const totalAmount = parseFloat(safeNumber(itemTotals.totalAmount).toFixed(2));
        const totalIncome = parseFloat(safeNumber(itemTotals.totalIncome).toFixed(2));
        const totalWHT = parseFloat(safeNumber(itemTotals.totalWHT).toFixed(2));

        $("#TotalQty").val(FormatNumber(parseFloat(itemTotals.totalQty).toPrecision(15)));
        $("#TotalAmount").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#TotalIncomeValue").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        $("#TotalGST").val(DecimalIndianRupees(totalGst.toFixed(2)));
        $("#TotalWHT").val(DecimalIndianRupees(totalWHT.toFixed(2)));

        // const RejectionAmount = parseFloat((totalAmount + totalIncome + headerTotal + totalGst).toFixed(2));
        // const total = parseFloat((RejectionAmount + totalWHT).toFixed(2));
        // const WHtAmount = parseFloat((safeNumber(headerIncomeTotals.headerWHT) + totalWHT).toFixed(2));
        // const roundedValue = customRound(total);
        // const rounded = parseFloat((roundedValue - total).toFixed(2));

        // $("#SRH_MaterialCost").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        // $("#SRH_ItemMiscIncome").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        // $("#SRH_HeaderMiscIncome").val(DecimalIndianRupees(headerTotal.toFixed(2)));
        // $("#SRH_GST_Amount").val(DecimalIndianRupees(totalGst.toFixed(2)));
        // $("#SRH_RejectionAmount").val(DecimalIndianRupees(RejectionAmount.toFixed(2)));
        // $("#SRH_WHT_Amount").val(DecimalIndianRupees(WHtAmount.toFixed(2)));
        // $("#SRH_RoundOff").val(rounded.toFixed(2));
        // $("#SRH_BuyerReceivable").val(DecimalIndianRupees(roundedValue.toFixed(2)));
    }

    // Main entry point
    async function CalculateAllIncomes() {
        try {
            await CalculateAll();
        } catch (error) {
            console.error("Error in calculation:", error);
        }
    }
    window.onload = CalculateAllIncomes();

</script>

