     function Print() {
        $("#PreviewButton").click();

        var printContents = document.getElementById("PrintPage").innerHTML;

        const iframe = document.createElement('iframe');
        document.body.appendChild(iframe);
        const iframeDoc = iframe.contentWindow.document;
        iframeDoc.open();
        iframeDoc.write(printContents);
        iframeDoc.close();

        setTimeout(() => {
            try {
                iframe.contentWindow.focus();
                iframe.contentWindow.print();
            } catch (error) { console.error("Printing from iframe failed:", error); }
            finally { setTimeout(() => { document.body.removeChild(iframe); }, 1000); }
        }, 250);
    }


    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.PII_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(decimalPlaces)) decimalPlaces = 2;
        $(this).val(QtyDecimalRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.PII_DecimalPlaces").val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(QtyDecimalRupees(value, decimalPlaces));
        }
    });
    $(document).on("input", ".QtyNumbers", function () {
        var $this = $(this);
        var decimalPlaces = parseInt($this.closest("tr").find("input.PII_DecimalPlaces").val(), 10);
        if (isNaN(decimalPlaces)) decimalPlaces = 0;

        let clean = $this.val()
            .replace(/-/g, "")
            .replace(/[^0-9.]/g, "");

        const firstDot = clean.indexOf(".");
        if (firstDot !== -1) {
            clean =
                clean.substring(0, firstDot + 1) +
                clean.substring(firstDot + 1).replace(/\./g, "");
        }

        if (decimalPlaces === 0) {
            clean = clean.replace(/\./g, "");
        }
        else if (decimalPlaces > 0 && firstDot !== -1) {
            const parts = clean.split(".");
            if (parts[1].length > decimalPlaces) {
                parts[1] = parts[1].slice(0, decimalPlaces);
                clean = parts.join(".");
            }
        }

        $this.val(clean);
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

