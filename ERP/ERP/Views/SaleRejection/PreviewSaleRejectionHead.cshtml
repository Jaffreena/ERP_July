@model ERP_DTO.SaleRejectionHead_DTO


@if (Model.SRH_Number != 0)
{
    <input asp-for="SRH_Number" type="hidden" class="Number" />
}

<div class="col-auto left-menu text-black">
    <div class="row">
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_RejectionNo" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input asp-for="SRH_RejectionNo" class="form-control Key KeyDup" readonly autocomplete="off" readonly />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_RejectionDate" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input asp-for="SRH_RejectionDate" class="form-control Key datepicker" readonly autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_ExportOrder" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <input class="form-check-input" type="checkbox" disabled asp-for="SRH_ExportOrder" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_MS_Number" class="col-md-6 col-lg-5 col-form-label ps-0"></label>
                <div class="col-md-6 col-lg-7">
                    <select asp-for="SRH_MS_Number" class="form-select" readonly asp-items="@ViewBag.MaterialSegregation"></select>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_BUY_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SRH_BUY_Number" class="form-control" type="hidden" />
                    <input asp-for="SRH_BUY_LOC_Number" class="form-control" type="hidden" />
                    <input asp-for="SRH_BUY_Name" class="form-control" autocomplete="off" readonly />
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_TCT_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <select asp-for="SRH_TCT_Number" class="form-select" onchange="SearchGST()" disabled></select>
                    @{
                        if (Model != null)
                        {
                            <input asp-for="SRH_HIDE_TCT_Number" class="form-control" type="hidden" readonly value="@Model.SRH_TCT_Number" />
                        }
                    }
                    <div class="cluster-results dropdown-results search-results bg-primary p-2" style="display:none"></div>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_WHT_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SRH_WHT_Tax" class="form-control" type="hidden" readonly />
                    <input asp-for="SRH_WHT_Percent" class="form-control" type="hidden" readonly />
                    <select asp-for="SRH_WHT_Number" class="form-select" asp-items="@ViewBag.WHTax" disabled onchange="SearchWHT()"></select>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="SRH_CUR_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="SRH_CUR_Name" class="form-control" readonly autocomplete="off" />
                    <input asp-for="SRH_CUR_Number" class="form-control" type="hidden" readonly />
                    <input asp-for="SRH_CUR_DecimalPlaces" class="form-control" type="hidden" readonly />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1" id="ExchangeRate">
                <label asp-for="SRH_ExchangeRate" class="col-sm-5 col-form-label ps-0 text-nowrap"></label>
                <div class="col-sm-7">
                    <input asp-for="SRH_ExchangeRate" class="form-control Key decimal" autocomplete="off" readonly />
                </div>
            </div>
        </div>
    </div>
</div>