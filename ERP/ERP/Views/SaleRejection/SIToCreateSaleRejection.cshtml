<script>
    function GetAddress(){
        $("tr.AddNewRow").each(function () {
            var $currentRow = $(this);

            var ADTPNumber = $currentRow.find('select.SRH_ADD_ADTP_Number').val();
            var IsDeleted = parseInt($currentRow.find("input.SRH_ADD_IsDeleted").val());
            var Buyer = $('#SRH_BUY_Number').val();

            if(IsDeleted!==1){
                $.ajax({
                    type: "get",
                    url: "buyer/address",
                    data: { Buyer: Buyer, ADTPNumber: ADTPNumber },
                    datatype: "json",
                    traditional: true,
                    success: function (data) {
                        var AddressID = data.buyerAddressId;
                        var $AddressDropdown = $currentRow.find('select.SRH_ADD_AddressID');
                        var $AddressId = $currentRow.find('input.SRH_ADD_HIDE_AddressID').val();

                        console.log("$AddressId",$AddressId);

                        $AddressDropdown.empty();
                        $AddressDropdown.append($('<option>', {
                            value: '',
                            text: ''
                        }));

                        AddressID.forEach(function (item) {
                            $AddressDropdown.append($('<option>', {
                                value: item.buY_ADD_AddressID,
                                text: item.buY_ADD_AddressID
                            }));
                        });
                        $AddressDropdown.val($AddressId);
                    }
                });
            }
        });
    }
    GetAddress();
</script>