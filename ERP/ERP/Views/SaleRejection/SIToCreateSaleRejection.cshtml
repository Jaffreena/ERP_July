            var Allocate = $(this).find("select.SRH_INC_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.SRH_INC_LA_Number").val();
                                   
            if (!IncomeCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(IncomeBase > 0)) {
                $(this).find("input.SRH_INC_IsDeleted").val(1);
                $(this).hide();
            }
        });
        $("tr.IIncNewRow").each(function () {
            var IncomeCode = $(this).find("select.SRI_INC_Income_Number").val();
            var Occurrence = $(this).find("select.SRI_INC_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.SRI_INC_CM_Number").val();
            var IncomeBase = removeCommas($(this).find("input.SRI_INC_IncomeBase").val());
            var Allocate = $(this).find("select.SRI_INC_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.SRI_INC_LA_Number").val();

            if (!IncomeCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(IncomeBase > 0)) {
                $(this).find("input.SRI_INC_IsDeleted").val(1);
                $(this).hide();
            }
        });
        $("tr.NewRow").each(function () {
            var ItemNumber = $(this).find("input.SRI_Item_Number").val();
            var Qty = removeCommas($(this).find("input.SRI_Qty").val());
            var UnitPrice = removeCommas($(this).find("input.SRI_UnitPrice").val());
            var UoMNumber = $(this).find("select.SRI_UoM_Number").val();

            if (!ItemNumber && !UoMNumber && !(Qty > 0) && !(UnitPrice > 0)) {
                $(this).find("input.IsDeleted").val(1);
                $(this).hide();
            }
        });

        $('select').prop('disabled', false);
    });


    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.SRI_UoM_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(decimalPlaces)) decimalPlaces = 2;
        $(this).val(QtyDecimalRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.SRI_UoM_DecimalPlaces").val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(QtyDecimalRupees(value, decimalPlaces));
        }
    });
    $(document).on("input", ".QtyNumbers", function () {
        var $this = $(this);
        var decimalPlaces = parseInt($this.closest("tr").find("input.SRI_UoM_DecimalPlaces").val(), 10);
        if (isNaN(decimalPlaces)) decimalPlaces = 0;

        let clean = $this.val()
            .replace(/-/g, "")
            .replace(/[^0-9.]/g, "");

        const firstDot = clean.indexOf(".");
        if (firstDot !== -1) {
            clean =
                clean.substring(0, firstDot + 1) +
                clean.substring(firstDot + 1).replace(/\./g, "");
        }

        if (decimalPlaces === 0) {
            clean = clean.replace(/\./g, "");
        }
        else if (decimalPlaces > 0 && firstDot !== -1) {
            const parts = clean.split(".");
            if (parts[1].length > decimalPlaces) {
                parts[1] = parts[1].slice(0, decimalPlaces);
                clean = parts.join(".");
            }
        }

        $this.val(clean);
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

