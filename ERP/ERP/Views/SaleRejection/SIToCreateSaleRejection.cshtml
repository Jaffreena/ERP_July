<script>
    async function CalculateAll() {
        const $newRows = $("tr.NewRow");
        const $IncNewRows = $("tr.IncNewRow");
        const $iIncNewRows = $("tr.IIncNewRow");
        const cluster = $("#SRH_TCT_Number").val() || $("#SRH_HIDE_TCT_Number").val();
        const RejectionDate = $("#SRH_RejectionDate").val();
        const whNumber = $("#SRH_WHT_Number").val();

        // Pre-calculate values that don't change during iteration
        const whTax = whNumber ? $("#SRH_WHT_Tax").val() : "1";
        const whPercent = whNumber ? $("#SRH_WHT_Percent").val() : 0;

        // Process items and Income in parallel
        const [itemResults, headerIncomeResults] = await Promise.all([
            processItems($newRows, $iIncNewRows, cluster, RejectionDate, whTax, whPercent),
            processHeaderIncomes($IncNewRows, $newRows, cluster, RejectionDate, whTax, whPercent)
        ]);

        // Calculate footer with all results
        await calculateFooter(itemResults, headerIncomeResults);
    }

    async function processItems($newRows, $iIncNewRows, cluster, RejectionDate, whTax, whPercent) {
        const itemPromises = [];
        const itemIncomeMap = new Map();

        // Pre-calculate item Income
        $iIncNewRows.each(function() {
            const $row = $(this);
            if (parseInt($row.find("input.SRI_INC_IsDeleted").val()) === 1) return;

            const SIINumber = $row.find("input.SRI_INC_SII_Number").val();
            const SIHNumber = $row.find("input.SRI_INC_SIH_Number").val();
            const key = `${SIHNumber}-${SIINumber}`;

            if (!itemIncomeMap.has(key)) {
                itemIncomeMap.set(key, []);
            }

            itemIncomeMap.get(key).push({
                IncomeBase: parseFloat(removeCommas($row.find("input.SRI_INC_IncomeBase").val())) || 0,
                charge: $row.find("select.SRI_INC_CM_Number").val(),
                row: $row
            });
        });

        // Process each item row
        $newRows.each(function() {
            const $row = $(this);
            if (parseInt($row.find('input.SRI_IsDeleted').val()) === 1) return;

            const promise = processSingleItem($row, itemIncomeMap, cluster, RejectionDate, whTax, whPercent);
            itemPromises.push(promise);
        });

        return Promise.all(itemPromises);
    }

    async function processSingleItem($row, itemIncomeMap, cluster, RejectionDate, whTax, whPercent) {
        const SIHNumber = $row.find('input.SRI_SIH_Number').val();
        const SIINumber = $row.find('input.SRI_SII_Number').val();
        const key = `${SIHNumber}-${SIINumber}`;
        const hsnNumber = $row.find('.SRI_HSN_Number').val();

        const qty = -Math.abs(parseFloat(removeCommas($row.find('input.SRI_Qty').val())) || 0);
        const unitPrice = parseFloat(removeCommas($row.find('input.SRI_UnitPrice').val())) || 0;
        const materialValue = qty * unitPrice;

        // Calculate amount
        $row.find("input.SRI_Amount").val(DecimalIndianRupees(materialValue));

        // Process item Income
        let IncomeTotal = 0;
        const itemIncome = itemIncomeMap.get(key) || [];

        for (const Income of itemIncome) {
            let IncomeValue = 0;

            switch (Income.charge) {
                case "1":
                    IncomeValue = Income.IncomeBase;
                    break;
                case "2":
                    IncomeValue = qty * Income.IncomeBase;
                    break;
                case "3":
                    IncomeValue = materialValue * Income.IncomeBase / 100;
                    break;
            }
            IncomeValue = parseFloat(parseFloat(IncomeValue).toFixed(2));
            IncomeValue = -Math.abs(IncomeValue)
            Income.row.find("input.SRI_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));
            IncomeTotal += parseFloat(IncomeValue);
        }
        IncomeTotal = -Math.abs(IncomeTotal)
        $row.find("input.SRI_IncomeValue").val(DecimalIndianRupees(IncomeTotal));

        // Calculate GST and WHT
        const baseAmount = materialValue + IncomeTotal;
        let gstAmount = 0;
        let whtAmount = 0;

        if (cluster) {
            gstAmount = await GetClusterAmount(cluster, RejectionDate, hsnNumber, baseAmount);
            gstAmount = parseFloat(parseFloat(gstAmount).toFixed(2));
            $row.find("input.SRI_GST_Amount").val(DecimalIndianRupees(gstAmount));

            const totalAmount = whTax === "1" ? baseAmount + gstAmount : baseAmount;
            whtAmount = (totalAmount * whPercent / 100);
            whtAmount = Math.abs(parseFloat(whtAmount).toFixed(2));

            $row.find("input.SRI_WHT_Percent").val(DecimalIndianRupees(whPercent));
            $row.find("input.SRI_WHT_Amount").val(DecimalIndianRupees(whtAmount));
        }

        // Process batches if needed
        // await CalculateIBatch($row);

        return {
            SIQty: parseFloat(removeCommas($row.find('.SRI_SII_Qty').val())) || 0,
            qty: qty,
            amount: materialValue,
            Income: IncomeTotal,
            gst: gstAmount,
            wht: whtAmount
        };
    }

    async function processHeaderIncomes($IncNewRows, $newRows, cluster, RejectionDate, whTax, whPercent) {
        const promises = [];

        $IncNewRows.each(function() {
            const $row = $(this);
            if (parseInt($row.find("input.SRH_INC_IsDeleted").val()) !== 1){
                promises.push(processHeaderIncome($row, $newRows, cluster, RejectionDate, whTax, whPercent));
            }
        });

        return Promise.all(promises);
    }

    async function processHeaderIncome($row, $newRows, cluster, RejectionDate, whTax, whPercent) {
        const SIHNumber = $row.find("input.SRH_INC_SIH_Number").val();
        const charge = $row.find("select.SRH_INC_CM_Number").val();
        const isGst = $row.find("select.SRH_INC_CalculateGST").val();
        const IncomeBase = parseFloat(removeCommas($row.find("input.SRH_INC_IncomeBase").val())) || 0;

        const items = $newRows.map(function() {
            const $irow = $(this);
            if ($irow.find(".SRI_SIH_Number").val() === SIHNumber && parseInt($irow.find("input.SRI_IsDeleted").val()) !== 1) {
                return {
                    qty: parseFloat(removeCommas($irow.find(".SRI_Qty").val())) || 0,
                    amount: parseFloat(removeCommas($irow.find(".SRI_Amount").val())) || 0
                };
            }
            return null;
        }).get().reduce((acc, item) => ({
            itemQty: acc.itemQty + item.qty,
            itemAmount: acc.itemAmount + item.amount
        }), { itemQty: 0, itemAmount: 0 });

        let IncomeValue = 0;
        switch (charge) {
            case "1": IncomeValue = IncomeBase; break;
            case "2": IncomeValue = items.itemQty * IncomeBase; break;
            case "3": IncomeValue = items.itemAmount * IncomeBase / 100; break;
        }
        IncomeValue = parseFloat(parseFloat(IncomeValue).toFixed(2));
        IncomeValue = -Math.abs(IncomeValue)
        $row.find("input.SRH_INC_IncomeValue").val(DecimalIndianRupees(IncomeValue));

        let taxValue = 0;
        if (isGst === "2" && cluster) {
            const sacNumber = $row.find("input.SRH_INC_SAC_Number").val();
            taxValue = await GetClusterIncomeAmount(cluster, RejectionDate, sacNumber, IncomeValue);
        }
        taxValue = parseFloat(parseFloat(taxValue).toFixed(2));
        $row.find("input.SRH_INC_GST_Amount").val(DecimalIndianRupees(taxValue));

        const totalAmount = whTax === "1" ? IncomeValue + taxValue : IncomeValue;
        let whtAmount = (totalAmount * whPercent / 100);
        whtAmount = Math.abs(parseFloat(whtAmount).toFixed(2));

        $row.find("input.SRH_INC_WHT_Percent").val(DecimalIndianRupees(whPercent));
        $row.find("input.SRH_INC_WHT_Amount").val(DecimalIndianRupees(whtAmount));

        return { IncomeValue, taxValue, whtAmount };
    }

    // Utility function for safe number operations
    function safeNumber(value, defaultValue = 0) {
        const num = parseFloat(value);
        return isNaN(num) ? defaultValue : num;
    }

    async function calculateFooter(itemResults, headerIncomeResults) {
        const itemTotals = itemResults.reduce((acc, item) => ({
            totalSIQty: acc.totalSIQty + safeNumber(item.SIQty),
            totalQty: acc.totalQty + safeNumber(item.qty),
            totalAmount: acc.totalAmount + safeNumber(item.amount),
            totalIncome: acc.totalIncome + safeNumber(item.Income),
            totalGst: acc.totalGst + safeNumber(item.gst),
            totalWHT: acc.totalWHT + safeNumber(item.wht)
        }), { totalSIQty: 0, totalQty: 0, totalAmount: 0, totalIncome: 0, totalGst: 0, totalWHT: 0 });

        const headerIncomeTotals = headerIncomeResults.reduce((acc, Income) => ({
            headerTotal: acc.headerTotal + safeNumber(Income.IncomeValue),
            headerGst: acc.headerGst + safeNumber(Income.taxValue),
            headerWHT: acc.headerWHT + safeNumber(Income.whtAmount)
        }), { headerTotal: 0, headerGst: 0, headerWHT: 0 });

        const totalGst = parseFloat(safeNumber(itemTotals.totalGst).toFixed(2));
        const totalAmount = parseFloat(safeNumber(itemTotals.totalAmount).toFixed(2));
        const totalIncome = parseFloat(safeNumber(itemTotals.totalIncome).toFixed(2));
        const headerTotal = parseFloat(safeNumber(headerIncomeTotals.headerTotal).toFixed(2));
        const totalWHT = parseFloat(safeNumber(itemTotals.totalWHT).toFixed(2));

        $("#TotalSIQty").val(FormatNumber(parseFloat(itemTotals.totalSIQty).toFixed(2)));
        $("#TotalQty").val(FormatNumber(parseFloat(itemTotals.totalQty).toPrecision(15)));
        $("#TotalAmount").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#TotalIncomeValue").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        $("#TotalGST").val(DecimalIndianRupees(totalGst.toFixed(2)));
        $("#TotalWHT").val(DecimalIndianRupees(totalWHT.toFixed(2)));

        const overGst = parseFloat(parseFloat(totalGst + safeNumber(headerIncomeTotals.headerGst)).toFixed(2));
        const overWHT = parseFloat(parseFloat(totalWHT + safeNumber(headerIncomeTotals.headerWHT)).toFixed(2));
        const RejectionAmount = parseFloat((totalAmount + totalIncome + headerTotal + overGst).toFixed(2));

        const total = parseFloat((RejectionAmount + overWHT).toFixed(2));
        const roundedValue = customRound(total);
        const rounded = parseFloat((roundedValue + total).toFixed(2))* -1;

        $("#SRH_MaterialCost").val(DecimalIndianRupees(totalAmount.toFixed(2)));
        $("#SRH_ItemMiscIncome").val(DecimalIndianRupees(totalIncome.toFixed(2)));
        $("#SRH_HeaderMiscIncome").val(DecimalIndianRupees(headerTotal.toFixed(2)));
        $("#SRH_GST_Amount").val(DecimalIndianRupees(overGst.toFixed(2)));
        $("#SRH_RejectionAmount").val(DecimalIndianRupees(RejectionAmount.toFixed(2)));
        $("#SRH_WHT_Amount").val(DecimalIndianRupees(overWHT.toFixed(2)));
        $("#SRH_RoundOff").val(rounded.toFixed(2));
        $("#SRH_BuyerReceivable").val(DecimalIndianRupees(-roundedValue.toFixed(2)));
    }

    async function CalculateAllIncomes() {
        try {
            await CalculateAll();
        } catch (error) {
            console.error("Error in calculation:", error);
        }
    }
</script>

