    function ParseCustomDate(dateString) {
        if (!dateString || typeof dateString !== 'string') {
            return null;
        }

        const months = {
            'Jan': 0, 'Feb': 1, 'Mar': 2, 'Apr': 3, 'May': 4, 'Jun': 5,
            'Jul': 6, 'Aug': 7, 'Sep': 8, 'Oct': 9, 'Nov': 10, 'Dec': 11
        };

        const parts = dateString.split('-');

        if (parts.length === 3) {
            const day = parseInt(parts[0], 10);
            const monthStr = parts[1];
            const year = parseInt(parts[2], 10);

            if (months.haSIwnProperty(monthStr) && !isNaN(day) && !isNaN(year) && year > 1000) {
                const monthIndex = months[monthStr];
                const dateObj = new Date(year, monthIndex, day);
                if (dateObj.getFullYear() === year && dateObj.getMonth() === monthIndex && dateObj.getDate() === day) {
                    return dateObj;
                } else {
                }
            }
        }
        console.warn("Could not parse date string:", dateString, "Parts:", parts);
        return null;
    }
