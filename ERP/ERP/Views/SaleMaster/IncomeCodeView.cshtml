@model ERP_DTO.IncomeCode_DTO


@if (Model != null)
{
    <input asp-for="MIC_Number" type="hidden" class="Number" />
}
<div class="mb-3">
    <label asp-for="MIC_Code" class="control-label"></label>
    <input asp-for="MIC_Code" class="form-control Key KeyDup" autofocus="true" autocomplete="off" />
</div>
<div class="mb-3">
    <label asp-for="MIC_Description" class="control-label"></label>
    <textarea asp-for="MIC_Description" class="form-control Key" autocomplete="off"></textarea>
</div>
<div class="mb-3">
    <label asp-for="MIC_OCRN_Number" class="control-label"></label>
    <select asp-for="MIC_OCRN_Number" class="form-select" asp-items="@ViewBag.Occ"></select>
</div>
<div class="mb-3">
    <label asp-for="MIC_CM_Number" class="control-label"></label>
    <select asp-for="MIC_CM_Number" class="form-select" asp-items="@ViewBag.Cha"></select>
</div>
<div class="mb-3">
    <label asp-for="MIC_ALCT_Number" class="control-label"></label>
    <select asp-for="MIC_ALCT_Number" class="form-select" asp-items="@ViewBag.All"></select>
</div>
<div class="mb-3">
    <label asp-for="MIC_LA_Number" class="control-label"></label>
    <select asp-for="MIC_LA_Number" class="form-select form-search" asp-items="@ViewBag.COA"></select>
</div>
<div class="mb-3">
    <label asp-for="MIC_SAC_Number" class="control-label"></label>
    <select asp-for="MIC_SAC_Number" class="form-select form-search" asp-items="@ViewBag.SAC"></select>
</div>

<div>
    @if (Model != null)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
</div>
