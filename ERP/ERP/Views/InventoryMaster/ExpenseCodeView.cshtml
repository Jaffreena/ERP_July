@model ERP_DTO.ExpenseCode_DTO


@if (Model != null)
{
    <input asp-for="ExpenseCodeNumber" type="hidden" class="Number" />
}
<div class="mb-3">
    <label asp-for="ExpenseCode" class="control-label"></label>
        <input asp-for="ExpenseCode" class="form-control Key KeyDup" autofocus="true" autocomplete="off" />
</div>
<div class="mb-3">
    <label asp-for="EC_Description" class="control-label"></label>
        <textarea asp-for="EC_Description" class="form-control Key" autocomplete="off"></textarea>
</div>
<div class="mb-3">
    <label asp-for="LedgerAccount" class="control-label"></label>
        <select asp-for="LedgerAccount" class="form-select form-search" asp-items="@ViewBag.COA"></select>
    </div>
<div class="mb-3">
    <label asp-for="EC_SAC_Number" class="control-label"></label>
    <select asp-for="EC_SAC_Number" class="form-select form-search" asp-items="@ViewBag.SAC"></select>
    </div>
<div>
        @if (Model != null)
        {
            <input type="submit" name="Mode" value="Update" class="btn btn-primary me-3" />
            <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
        }
        else
        {
            <input type="submit" name="Mode" value="Save" class="btn btn-primary me-3" />
            <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
        }
    </div>
