@model ERP_DTO.Warehouse_DTO


@if (Model != null)
{
    <input asp-for="WarehouseNumber" type="hidden" class="Number" />
}
<div class="mb-3">
    <label asp-for="WarehouseCode" class="control-label"></label>
    <input asp-for="WarehouseCode" class="form-control Key KeyDup" autofocus="true" autocomplete="off" />
</div>
<div class="mb-3">
    <label asp-for="WarehouseDescription" class="control-label"></label>
    <textarea asp-for="WarehouseDescription" class="form-control Key" autocomplete="off"></textarea>
</div>
<div class="mb-3">
    <label asp-for="WarehouseGroup" class="control-label"></label>
    <select asp-for="WarehouseGroup" class="form-select" asp-items="@ViewBag.Under"></select>
</div>
<div class="mb-3">
    <label asp-for="WarehouseCategory" class="control-label"></label>
    <select asp-for="WarehouseCategory" class="form-select form-search" asp-items="@ViewBag.Category"></select>
</div>
<div>
    @if (Model != null)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
</div>