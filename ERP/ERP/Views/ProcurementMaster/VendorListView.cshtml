@model ERP_DTO.PaginatedList_DTO<ERP_DTO.Vendor_DTO>

@functions {
    string SortClass(string column)
    {
        var current = ViewData["CurrentSort"]?.ToString();
        return current == column ? "sorted-asc"
             : current == column + "_desc" ? "sorted-desc"
             : "";
    }

    string NextSort(string column)
    {
        var current = ViewData["CurrentSort"]?.ToString();
        return current == column ? column + "_desc" : column;
    }
}

<form asp-action="Vendor" method="get">
    <input type="hidden" name="sortOrder" value="@ViewData["CurrentSort"]" />
    <input type="hidden" name="PageNumber" value="@ViewData["PageNumber"]" />
    <input type="hidden" name="PSize" value="@ViewData["PageSize"]" />
    <div class="w-100 border p-2 table-body-h-c">
        <div class="table-body table-responsive h-100">
            <table class="table table-bordered align-middle table-hover align-middle mb-0 table-grid TableConfig">
                <thead>
                    <tr class="table-info">
                        <th class="px-2 del">
                            <div class="th-resizer"></div>
                            <input type="checkbox" class="selectAllCheckbox form-check-input border-white" id="selectAllCheckbox">
                        </th>
                        <th class="@SortClass("Code")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Code")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Vendor Code
                            </a>
                        </th>
                        <th class="@SortClass("Name")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Name")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Vendor Name
                            </a>
                        </th>
                        <th class="@SortClass("Location")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Location")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Location
                            </a>
                        </th>
                        <th class="@SortClass("Currency")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Currency")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Currency
                            </a>
                        </th>
                        <th class="@SortClass("Group")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Group")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Vendor Group
                            </a>
                        </th>
                        <th class="@SortClass("Category")">
                            <div class="th-resizer"></div>
                            <a asp-action="Vendor"
                               asp-route-sortOrder="@NextSort("Category")"
                               asp-route-Search="@ViewData["CurrentFilter"]"
                               asp-route-PSize="@ViewData["PageSize"]"
                               asp-route-PageNumber="@ViewData["PageNumber"]">
                                Vendor Category
                            </a>
                        </th>
                        <th class="action text-center">Action</th>
                    </tr>
                    <tr>
                        <th class="px-2 del"></th>
                        <th>
                            <input type="text" value="@ViewData["FilterVendorCode"]" class="column-filter form-control form-control-sm" data-column="0" placeholder="Vendor Code">
                        </th>
                        <th class="table-col-xxl">
                            <input type="text" value="@ViewData["FilterVendorName"]" class="column-filter form-control form-control-sm" data-column="1" placeholder="Vendor Name">
                        </th>
                        <th>
                            <input type="text" value="@ViewData["FilterVendorLocation"]" class="column-filter form-control form-control-sm" data-column="2" placeholder="Location">
                        </th>
                        <th class="table-width-md text-center">
                            <input type="text" value="@ViewData["FilterVendorCurrency"]" class="column-filter form-control form-control-sm" data-column="3" placeholder="Currency">
                        </th>
                        <th>
                            <input type="text" value="@ViewData["FilterVendorGroup"]" class="column-filter form-control form-control-sm" data-column="4" placeholder="Group">
                        </th>
                        <th>
                            <input type="text" value="@ViewData["FilterVendorCategory"]" class="column-filter form-control form-control-sm" data-column="5" placeholder="Category">
                        </th>
                        <th class="action text-center"></th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        Int32 i = 1;
                    }
                    @foreach (var item in Model)
                    {
                        <tr data-id="@i">
                            <td class="p-2 del">
                                <input type="checkbox" class="DeleteNumber form-check-input" name="DeleteNumber" value="@item.VendorNumber">
                            </td>
                            <td>@Html.DisplayFor(modelitem => item.VendorCode)</td>
                            <td class="table-col-xxl">@Html.DisplayFor(modelitem => item.VendorName)</td>
                            <td>@Html.DisplayFor(modelitem => item.VendorLocation)</td>
                            <td class="table-width-md text-center">@Html.DisplayFor(modelitem => item.Currency)</td>
                            <td>@Html.DisplayFor(modelitem => item.VendorGroup)</td>
                            <td>@Html.DisplayFor(modelitem => item.VendorCategory)</td>
                            <td class="action text-center">
                                <form asp-action="Vendor">
                                    <input type="hidden" name="PSize" value="@ViewData["PageSize"]" />
                                    <input type="hidden" name="PageNumber" value="@ViewData["PageNumber"]" />
                                    <input type="hidden" name="Search" value="@ViewData["CurrentFilter"]" />
                                    <input name="VendorNumber" id="VendorNumber" value="@item.VendorNumber" type="hidden" />
                                    <button type="submit" name="Mode" value="Edit" class="btn text-primary p-0 me-1 shadow-none icon-link">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-fill" viewBox="0 0 16 16">
                                            <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z" />
                                        </svg>
                                    </button>

                                    <a value="@item.VendorNumber" class="DeleteButton btn text-danger p-0 icon-link shadow-none" data-value="@item.VendorNumber">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash3-fill" viewBox="0 0 16 16">
                                            <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5" />
                                        </svg>
                                    </a>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <ul id="ActionMenu">
                <li data-action="view">View Details</li>
                <li data-action="edit">Edit Row</li>
                <li data-action="delete">Delete Row</li>
                <hr>
                <li data-action="copyCell">Copy Cell Text</li>
                <li data-action="copyRow">Copy Row Data (Visible)</li>
                <hr>
                <li id="ActionMenuHideColumn" data-action="hideColumn">Hide "Column Name"</li>
                <li data-action="configureColumns">Configure Columns...</li>
            </ul>

            <!-- Column Configuration Modal -->
            <div id="ConfigModal">
                <div class="ConfigModal-content">
                    <span id="ConfigModalClose">&times;</span>
                    <h2>Configure Table Columns</h2>
                    <p>Check or uncheck columns to show or hide them. Drag to reorder.</p>
                    <div id="ConfigCheckboxes">
                        <!-- Checkboxes will be dynamically inserted here -->
                    </div>
                    <div class="ConfigModal-actions">
                        <button id="ResetColumnsButton">Reset to Default</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}
<div class="row table-cal align-items-center">
    <div class="col align-items-center">
        <form asp-action="Vendor" method="get">
            <div class="row align-items-center">
                <div class="col text-dark py-1">
                    @{
                        Int32 TotalSize = Convert.ToInt32(ViewData["TotalSize"]);
                        Int32 PageNumber = Convert.ToInt32(ViewData["PageNumber"]);
                        Int32 PageSize = Convert.ToInt32(ViewData["PageSize"]);
                        Int32 StartNumber = 1;
                        Int32 EndNumber = 0;

                        if (PageNumber > 1)
                        {
                            StartNumber = StartNumber + ((PageNumber - 1) * PageSize);
                        }
                        EndNumber = (EndNumber + PageSize) + ((PageNumber - 1) * PageSize);
                        if (EndNumber > TotalSize)
                        {
                            EndNumber = TotalSize;
                        }

                        if (StartNumber > EndNumber)
                        {
                            StartNumber = EndNumber;
                        }
                    }
                    Showing @StartNumber to @EndNumber
                </div>
                <div class="col text-center">
                    Total records @TotalSize
                </div>
                <div class="col">
                    <nav>
                        <ul class="pagination mb-0 float-end">
                            <li class="page-Vendor">
                                <a asp-action="Vendor" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex - 1)" class="page-link @prevDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M8.354 1.646a.5.5 0 0 1 0 .708L2.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                        <path fill-rule="evenodd" d="M12.354 1.646a.5.5 0 0 1 0 .708L6.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                    </svg>
                                </a>
                            </li>
                            <li class="page-Vendor">
                                <a asp-action="Vendor" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex + 1)" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0" />
                                    </svg>
                                </a>
                            </li>
                            <li>
                                <a class="page-link">
                                    @ViewData["PageNumber"]
                                </a>
                            </li>
                            <li class="page-Vendor">
                                <a asp-action="Vendor" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@(Model.PageIndex + 1)" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708" />
                                    </svg>
                                </a>
                            </li>
                            <li class="page-Vendor">
                                <a asp-action="Vendor" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-PSize="@ViewData["PageSize"]" asp-route-pageNumber="@ViewData["PageCount"]" class="page-link @nextDisabled">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-double-right" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M3.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L9.293 8 3.646 2.354a.5.5 0 0 1 0-.708" />
                                        <path fill-rule="evenodd" d="M7.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L13.293 8 7.646 2.354a.5.5 0 0 1 0-.708" />
                                    </svg>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        </form>
    </div>
</div>
