<script>
    $('.navbar-nav > .nav-item.procurement > a').addClass("active");
</script>

<script>

    $('form').submit(function (event) {
      

       
            

         $("#IBatNewRowButton").click(function () {
            var lastRow = $("tr.IBatNewRow").last();
            if (IBatCheckAllFieldsValid(lastRow)) {
                IBatNewRow();
            }
            else {
                var firstInvalidField = null;
                lastRow.find("select, input.PII_BCH_Qty, input[type='text']").each(function () {
                    if (!IBatValidateField($(this))) {
                        if (firstInvalidField == null)
                            firstInvalidField = $(this);
                        return false;
                    }
                });
                if (firstInvalidField != null) {
                    alert("Please complete all fields !");
                    firstInvalidField.focus();
                }
            }
            BatchCalculateFooter();
        });







        $("tr.NewRow").each(function () {
            var ItemNumber = $(this).find("input.PII_Item_Number").val();
            var Qty = removeCommas($(this).find("input.PII_Qty").val());
            var UnitPrice = removeCommas($(this).find("input.PII_UnitPrice").val());
            var UoMNumber = $(this).find("select.PII_UoM_Number").val();

            if (!ItemNumber && !UoMNumber && !(Qty > 0) && !(UnitPrice > 0)) {
                $(this).find("input.IsDeleted").val("true");
                $(this).hide();
            }
        });
      
    });

    function NumberToIndianRupees(value, decimalPlaces) {
        if (value === "" || isNaN(value)) {
            return "0";
        }

        var formattedValue = parseFloat(value).toFixed(decimalPlaces);

        var parts = formattedValue.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");

        if (parseFloat(value) % 1 === 0) {
            return parts[0];
        }
        return parts.join(".");
    }
    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest('tr').find("input.PII_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
        $(this).val(NumberToIndianRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest('tr').find("input.PII_DecimalPlaces").val();

        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(NumberToIndianRupees(value, decimalPlaces));
        }
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    $(".UnitDecimal").each(function () {
        var ValueResult = "0";
        var value = $(this).val();
        var decimalPlaces = $("#PIH_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
        ValueResult = formatToIndianRupees(removeCommas(value), decimalPlaces);
        $(this).val(ValueResult);
    });
    $(document).on("blur", ".UnitDecimal", function () {
        var ValueResult = "0";
        var value = $(this).val();

        var decimalPlaces = $("#PIH_DecimalPlaces").val();

        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }

        if (value.trim() === "" || isNaN(value)) {
        } else {
            ValueResult = formatToIndianRupees(value, decimalPlaces);
            $(this).val(ValueResult);
        }
    });
    $(document).on("focus", ".UnitDecimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });
    function formatToIndianRupees(value, UnitDecimalPlaces) {
        var ValueResult = "0";
        if (value === "" || isNaN(value)) {
        }
        else {
            ValueResult = value;
        }

        var fromat = parseFloat(ValueResult).toFixed(UnitDecimalPlaces);

        var parts = fromat.split(".");
        parts[0] = parts[0].replace(/(\d)(?=(\d\d)+\d$)/g, "$1,");
        return parts.join(".");
    }

    
    

    $(".decimal").each(function () {
        var value = $(this).val();
        $(this).val(DecimalIndianRupees(removeCommas(value)));
    });
    $(document).on("blur", ".decimal", function () {
        var value = $(this).val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0.00");
        } else {
            $(this).val(DecimalIndianRupees(removeCommas(value)));
        }
    });
    $(document).on("focus", ".decimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    $(document).on('change', "#PIH_InvoiceDate", function () {
        var paymentBase = $("#PIH_PaymentBase").val();

        if (paymentBase === "2") {
            var InDate = $("#PIH_InvoiceDate").val();
            var Credit = $("#PIH_CreditDays").val();

            if (InDate == '') { } else {
                var CurentDate = addDays(InDate, Credit);
                $("#PIH_DueDate").val(CurentDate);
            }
        }
        else if (paymentBase === "3") {
            var InDate = $("#PIH_SupplierInvoiceDate").val();
            var Credit = $("#PIH_CreditDays").val();

            if (InDate == '') { } else {
                var CurentDate = addDays(InDate, Credit);
                $("#PIH_DueDate").val(CurentDate);
            }
        }
        else {
            $("#PIH_DueDate").val("");
        }

        var PIHDate = $("#PIH_InvoiceDate").val();
        const date = new Date(PIHDate);

        const Year = date.getFullYear();
        const Month = date.getMonth() + 1;
        const Day = date.getDate();

        const ForMonth = String(Month).padStart(2, '0');
        const ForDay = String(Day).padStart(2, '0');

        const ForDate = `${Year}${ForMonth}${ForDay}`;

        $.ajax({
            url: 'numbering',
            data: { PIDate: ForDate },
            type: 'GET',
            success: function (data) {
                if (data === "") {

                }
                else {
                    $('#PIH_InvoiceNo').val(data);
                }
            },
            error: function () {
            }
        });

       
        GetVendor();
    });
 

    
    function addDays(date, days) {
        const dateAfterAddingDays = new Date(date);
        dateAfterAddingDays.setDate(dateAfterAddingDays.getDate() + parseInt(days));

        const day = dateAfterAddingDays.getDate().toString().padStart(2, '0');
        const year = dateAfterAddingDays.getFullYear();
        const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
            "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
        const monthAbbr = monthNames[dateAfterAddingDays.getMonth()];

        const result = `${day}-${monthAbbr}-${year}`;
        return result;
    }

   

    flatpickr(".datepicker", {
        dateFormat: "d-M-Y",
        altInput: false,
    });



     document.addEventListener("DOMContentLoaded", function () {
        const MainDiv = document.getElementById('BodyHeight');
        const HeadDiv = document.getElementById('BodyCardHeader');
        const BodyDiv = document.getElementById('BodyCardBody');
        const FooterDiv = document.getElementById('BodyCardFooter');

        if (HeadDiv && BodyDiv) {
            const MainHeight = MainDiv.offsetHeight;
            const HeadHeight = HeadDiv.offsetHeight;
            const FooterHeight = FooterDiv.offsetHeight;
            BodyDiv.style.height = (MainHeight - HeadHeight - FooterHeight) + 'px';
        } else {
        }
    });

 
</script>
