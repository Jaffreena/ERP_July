<script>
       // ===== REMOVE COMMAS =====
    function removeCommas(v){
        return (v || '').toString().replace(/,/g,'');
    }

    // ===== INDIAN NUMBER FORMAT =====
    function DecimalIndianRupees(v){

        if(v==="" || isNaN(v)) return "0.00";

        let p=parseFloat(v).toFixed(2).split(".");

        p[0]=p[0].replace(/(\d)(?=(\d\d)+\d$)/g,"$1,");

        return p.join(".");
    }

    // ===== CALCULATE FOOTER =====
    function BatchCalculateFooter(){

        let qty=0,val=0;

        $("tr.IBatNewRow:visible").each(function(){

            let r=$(this);

            // SKIP DELETED ROW
            if(r.find(".RNI_BCH_IsDeleted").val()!=="true"){

                qty+=parseFloat(removeCommas(r.find(".RNI_BCH_AmendedQty").val()))||0;

                val+=parseFloat(removeCommas(r.find(".RNI_BCH_Value").val()))||0;
            }
        });

        // SET TOTALS
        $("#BatchTotalQty").val(DecimalIndianRupees(qty));

        $("#BatchTotalValue").val(DecimalIndianRupees(val));
    }

    // ===== CALL AFTER PAGE LOAD =====
    $(document).ready(function(){

        setTimeout(()=>BatchCalculateFooter(),500);

    });
</script>

<script>
                    var TempBatch = {};
                        function ValidateBatch() {

            let MissingItems = [];
            let MismatchItems = [];

            $('#ItemTable tbody tr.NewRow').each(function () {

                let row = $(this);

                // Skip deleted rows
                if (row.find('.IsDeleted').val() == "1") return;

                let ItemNumber = row.find('.Item_Number').val();
                let ItemCode = row.find('.Item_Code').val();

                if (!ItemNumber) return;

                let itemQty = parseFloat(row.find('.Qty').val()) || 0;
                let itemAmount = parseFloat(row.find('.Amount').val()) || 0;

                // 🔥 ALWAYS SAFE ARRAY
                let batches = TempBatch[ItemNumber] || [];

                // ❌ No batches
                if (batches.length === 0) {
                    MissingItems.push(ItemCode);
                    return;
                }

                let totalBatchQty = 0;
                let totalBatchAmount = 0;

                // 🔥 SUM BATCHES
                $.each(batches, function (i, b) {

                    if (b.RNI_BCH_IsDeleted == "1") return;

                    totalBatchQty += parseFloat(b.RNI_BCH_AmendedQty) || 0;
                    totalBatchAmount += parseFloat(b.RNI_BCH_Value) || 0;
                });

                const EPS = 0.0001;

                // 🔥 VALIDATION
                if (Math.abs(itemQty - totalBatchQty) > EPS ||
                    Math.abs(itemAmount - totalBatchAmount) > EPS) {

                    MismatchItems.push(
                        ItemCode +
                        " | Item Qty: " + itemQty +
                        ", Batch Qty: " + totalBatchQty +
                        " | Item Amt: " + itemAmount +
                        ", Batch Amt: " + totalBatchAmount
                    );
                }

            });

            return {
                MissingItems,
                MismatchItems
            };
        }
   
    
        function BatchJSON() {



            $("#IBatTableBody tr.IBatNewRow:visible").each(function () {

                var row = $(this);

                var ItemNumber = row.find(".RNI_BCH_Item_Number").val();

                // Create array for item if not exists
                if (!TempBatch[ItemNumber]) {
                    TempBatch[ItemNumber] = [];
                }
               // alert(row.find(".RNI_BCH_UnitPrice").val()+"row.find('.RNI_BCH_UnitPrice').val()")
                // Add object into item array
                TempBatch[ItemNumber].push({

                    RNI_BCH_Item_Number: ItemNumber,

                    RNI_BCH_Date: row.find(".RNI_BCH_Date").val(),

                    RNI_BCH_Number: row.find(".RNI_BCH_No").val(),

                    RNI_BCH_Qty: row.find(".RNI_BCH_AmendedQty").val(),

                    RNI_BCH_UnitPrice: row.find(".RNI_BCH_UnitPrice").val(),

                    RNI_BCH_Value: row.find(".RNI_BCH_Value").val(),

                    RNI_BCH_IsDeleted: row.find(".RNI_BCH_IsDeleted").val()

                });

            });

            console.log(TempBatch);
        }


