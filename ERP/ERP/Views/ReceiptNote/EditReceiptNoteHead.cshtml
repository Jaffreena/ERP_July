<script>
    $(document).ready(function () {
        InitializeGstFlatpickrs();

        function InitializeGstFlatpickrs() {
            $(".datepicker").flatpickr({
                dateFormat: "d-M-Y",   // 30-Apr-2026
                altInput: true,        // shows formatted date
                altFormat: "d-M-Y",   // display format
                allowInput: true,     // user can type manually
                defaultDate: new Date() // optional: today default
            });
        }
    });
</script>
<script>
     function OnBuyerInput(inputElement) {
        SearchBuyer(inputElement);
    }
    function OnBuyerFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchBuyer(inputElement);
        }
        else {
          $(inputElement).select();
        }
    }
    async function SearchBuyer(inputElement) {
        var Buyer = inputElement.value;
        var SIHDate = $("#RN_Date").val();
        var resultsDiv = $(inputElement).next('.buyer-search-results');
        // var isChecked = $("#SIH_ExportOrder").prop("checked");
        var Export;

        // if (isChecked) {
        //     Export = true;
        // } else {
            Export = false;
        // }

        $.ajax({
            url: '/jobinward/transactions/receipt-note/cutomer',
            data: { Buyer: Buyer, SIHDate: SIHDate, Export: Export },
            type: 'GET',
            success: function (data) {
                console.log(data)
                resultsDiv.empty();
                if (data && data.length > 0) {
                    resultsDiv.show();
                    var table = $('<div class="card-body modal-content p-0"><table class="table table-bordered table-hover table-fixed table-grid mb-0"><thead><tr class="table-info"><th class="table-col-xxl">JW Customer Name</th><th class="table-width-lg text-center">Currency</th></tr></thead><tbody></tbody></table></div>');
                    data.forEach(function (Buy) {
                        var row = $('<tr></tr>');
                        row.append('<td class="table-col-xxl">' + Buy.cuS_Name + '</td>');
                        row.append('<td class="table-width-lg text-center">' + Buy.cuS_CUR_Name + '</td>');
                        table.find('tbody').append(row);

                        row.on('click', function () {
                            $(inputElement).val(Buy.cuS_Name);
                             // $("#JWC_Number").val(Buy.cuS_Number)
                            $("#JWC_Number").val(Buy.cuS_Number)
                           $("#JWC_Name").val(Buy.cuS_Name);
                                $("#Currency_Name").val(Buy.cuS_CUR_Name)
                            $("#Currency_Number").val(Buy.cuS_CUR_Number)
                            $("#SIH_CUR_Number").val(Buy.cuS_CUR_Number)
                            $("#SIH_BUY_LOC_Number").val(Buy.cuS_LOC_Number)
                            $("#SIH_CUR_DecimalPlaces").val(Buy.cuS_CUR_DecimalPlaces)
                            $("#SIH_WHT_Number").val(Buy.cuS_WHT_Number)
                            
                               $("#WH_Number").val(Buy.cuS_WH_Number)
                            resultsDiv.hide();

                            // SearchClustor(Buy.buY_Number, Buy.buY_TCT_Number);
                            // GetWHT(Buy.buY_Number, Buy.buY_WHT_Number, SIHDate);

                            // CalculateAllIncomes();
                        });
                    });

                    var closeButton = $('<div class="card-header bg-primary py-1 px-1"><button type="button" class="p-0 float-end btn btn-sm btn-primary bg-opacity-10 d-flex"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16"><path d = "M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"> </path></svg></button></div>');
                    closeButton.on('click', function () {
                        resultsDiv.hide();
                    });

                    resultsDiv.append(closeButton);
                    resultsDiv.append(table);
                } else {
                    resultsDiv.hide();
                    resultsDiv.append('<p>No results found</p>');
                }
            },
            error: function () {
                resultsDiv.text('Error loading data.');
                resultsDiv.show();
            }
        });
    }
</script>
<script>
    function showAlert(message, focusSelector = null) {
        $('#AlertMessage').html(message);

        const modal = new bootstrap.Modal(document.getElementById('ModelAlert'));
        modal.show();

        $('#ModelAlert').off('hidden.bs.modal').on('hidden.bs.modal', function () {
            if (focusSelector) {
                setTimeout(() => $(focusSelector).focus(), 100);
            }
        });
        
    } 


       $("#MS_Number").change(function () {

        // Check whether any visible row contains item
        let hasItem = $("tr.NewRow").filter(function () {

            let row = $(this);

            let isDeleted = row.find(".IsDeleted").val() === "true";

            let itemNumber = row.find(".Item_Number").val();

            return !isDeleted &&
                   itemNumber &&
                   itemNumber.trim() !== "";

        }).length > 0;


        // No items → allow directly
        if (!hasItem)
            return;


        // Confirmation
        if (confirm("Changing this will clear all grid values. Continue?")) {

            $("tr.NewRow").each(function () {

                let row = $(this);

                // Clear all inputs except delete flag
                row.find("input")
                   .not(".IsDeleted")
                   .val("");

                // Reset dropdowns
                row.find("select")
                   .prop("selectedIndex", 0);

                // Reset delete flag
                row.find(".IsDeleted")
                   .val("false");

            });

        }
        else {

            // Restore previous value
            $(this).val($(this).data("old"));

        }

    });


