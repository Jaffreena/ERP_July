<script>
       $(document).on('change', "#RN_Date", function () {
               var PIHDate = $("#RN_Date").val();

    if (!PIHDate) return;

    const date = new Date(PIHDate);

    const Year = date.getFullYear();
    const Month = String(date.getMonth() + 1).padStart(2, '0');
    const Day = String(date.getDate()).padStart(2, '0');

    const ForDate = `${Year}${Month}${Day}`;

    console.log(ForDate);

        let rnDate = $(this).val();

        if (!rnDate) return;

        $.ajax({
            url: '/jobinward/transactions/receipt-note/numbering',
            type: 'GET',
            data: { RNHDate: ForDate },
            success: function (data) {

                if (data !== "") {
                    $('#RN_No').val(data);
                } else {
                    $('#RN_No').val("");
                }
            }
        });
    });
        $("#AlertOkay").click(function () {

        $("#ModelAlert").modal("hide");
        $(".modal-backdrop").hide();

    });
</script>