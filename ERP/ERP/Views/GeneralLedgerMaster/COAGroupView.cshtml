@model ERP_DTO.COA_Group_DTO


@if (Model != null)
{
    <input asp-for="LedgerGroupNumber" type="hidden" class="Number" />
}
<div class="mb-3">
    <label asp-for="LedgerGroup" class="control-label"></label>
    <input asp-for="LedgerGroup" class="form-control Key KeyDup" autofocus="true" autocomplete="off" />
</div>
<div class="mb-3">
    <label asp-for="UnderLGroup" class="control-label"></label>
    <select asp-for="UnderLGroup" class="form-select" asp-items="@ViewBag.Under"></select>
</div>
<div class="mb-3">
    <label asp-for="GroupNature" class="control-label"></label>
    <select asp-for="GroupNature" class="form-select" asp-items="@ViewBag.Nature" data-live-search="true"></select>
</div>

<div>
    @if(Model != null)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary me-3" />
        <input type="submit" name="Mode" value="Clear" class="btn btn-primary" />
    }
</div>