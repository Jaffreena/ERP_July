@model ERP_DTO.PurchaseOrderHead_DTO


@if (Model.POH_Number != 0)
{
    <input asp-for="POH_Number" type="hidden" class="Number" />
}

<div class="col-auto left-menu text-black">
    <div class="row">
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_OrderNo" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_OrderNo" class="form-control Key KeyDup" readonly autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Date" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Date" class="form-control Key datepicker" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_ImportOrder" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input class="form-check-input" type="checkbox" asp-for="POH_ImportOrder" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_MS_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <select asp-for="POH_MS_Number" class="form-select" asp-items="@ViewBag.MaterialSegregation"></select>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Vendor_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Vendor_Number" class="form-control" type="hidden" />
                    <input asp-for="POH_VendorLocation" class="form-control" type="hidden" />
                    <input asp-for="POH_Vendor" class="form-control" autocomplete="off" oninput="OnVendorInput(this)" onfocus="OnVendorFocus(this)" />
                    <div class="vendor-search-results bg-primary card" style="display:none"></div>
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Currency_Number" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Currency" class="form-control" readonly autocomplete="off" />
                    <input asp-for="POH_Currency_Number" class="form-control" type="hidden" />
                    <input asp-for="POH_DecimalPlaces" class="form-control" type="hidden" />
                </div>
            </div>
            <div id="ExchangeRate" class="row align-items-center px-2 mb-1">
                <label asp-for="POH_ExchangeRate" class="col-sm-5 col-form-label ps-0 text-nowrap"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_ExchangeRate" class="form-control Key decimal" autocomplete="off" />
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_PaymentTerms" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_PaymentTerms" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_MOP" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_MOP" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_DeliveryTerms" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_DeliveryTerms" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_MOD" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_MOD" class="form-control Key" autocomplete="off" />
                </div>
            </div>
        </div>
        <div class="col-12 col-md-3">
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Tax" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Tax" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Inspection" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Inspection" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_TDC" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_TDC" class="form-control Key" autocomplete="off" />
                </div>
            </div>
            <div class="row align-items-center px-2 mb-1">
                <label asp-for="POH_Remarks" class="col-sm-5 col-form-label ps-0"></label>
                <div class="col-sm-7">
                    <input asp-for="POH_Remarks" class="form-control Key" autocomplete="off" />
                </div>
            </div>
        </div>
    </div>
</div>
<div class="col-auto right-menu text-center border-start">
    @if (Model.POH_Number != 0)
    {
        <input type="submit" name="Mode" value="Update" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    else
    {
        <input type="submit" name="Mode" value="Save" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
        <input type="submit" name="Mode" value="Clear All" class="btn btn-primary btn-sm px-2 w-100 mb-1" />
    }
    <button type="button" class="btn btn-primary btn-sm px-1 w-100 mb-1" id="MiscExpenseModal" data-bs-toggle="modal" data-bs-target="#Expense">
        Header Misc.Expense
    </button>
</div>
