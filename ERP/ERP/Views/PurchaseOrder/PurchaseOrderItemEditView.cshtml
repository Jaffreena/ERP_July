<script>
    $(document).ready(function () {
        ExchangeVisibility();

        $("#POH_ImportOrder").change(function () {
            var isChecked = $(this).is(':checked');

            var resultsDiv = $(".vendor-search-results");
            resultsDiv.hide();

            if ($("#POH_VendorLocation").val() != "") {
                if (isChecked && $("#POH_VendorLocation").val() != "2") {
                    if (confirm("Do you want to change the status of the Import Order? This action will clear the already selected vendor.")) {
                        $("#POH_Vendor").val("");
                        $("#POH_Vendor_Number").val("");
                        $("#POH_Currency").val("");
                        $("#POH_Currency_Number").val("");
                        $("#POH_VendorLocation").val("");
                    }
                    else {
                        $(this).prop('checked', false);
                    }
                }
                else if (!isChecked && $("#POH_VendorLocation").val() != "1") {
                    if (confirm("Do you want to change the status of the Import Order? This action will clear the already selected vendor.")) {
                        $("#POH_Vendor").val("");
                        $("#POH_Vendor_Number").val("");
                        $("#POH_Currency").val("");
                        $("#POH_Currency_Number").val("");
                        $("#POH_VendorLocation").val("");
                    }
                    else {
                        $(this).prop('checked', true);
                    }
                }
            }
            ExchangeVisibility();
        });

        function ExchangeVisibility() {
            if ($('#POH_ImportOrder').is(':checked')) {
                $('#ExchangeRate').show();
            } else {
                $('#ExchangeRate').hide();
            }
        }

    });
</script>