<script>
    $('form').submit(function (event) {
        $("tr.ExNewRow").each(function () {
            var ExpenseCode = $(this).find("select.POH_EXP_Expense_Number").val();
            var Occurrence = $(this).find("select.POH_EXP_Occurrence_Number").val();
            var ChargeableMethod = $(this).find("select.POH_EXP_CM_Number").val();
            var ExpenseBase = removeCommas($(this).find("input.POH_EXP_ExpenseBase").val());
            var Allocate = $(this).find("select.POH_EXP_Allocate_Number").val();
            var LedgerAccount = $(this).find("select.POH_EXP_LA_Number").val();

            if (!ExpenseCode && !Occurrence && !ChargeableMethod && !Allocate && !LedgerAccount && !(ExpenseBase > 0)) {
                $(this).closest('tr').find("input.IsDeleted").val(true);
                $(this).closest('tr').hide();
            }
        });

        $("tr.NewRow").each(function () {
            var ItemNumber = $(this).find("input.POI_Item_Number").val();
            var Qty = removeCommas($(this).find("input.POI_Qty").val());
            var UnitPrice = removeCommas($(this).find("input.POI_UnitPrice").val());
            var UoMNumber = $(this).find("select.POI_UoM_Number").val();

            if (!ItemNumber && !UoMNumber && !(Qty > 0) && !(UnitPrice > 0)) {
                $(this).closest('tr').find("input.IsDeleted").val(true);
                $(this).closest('tr').hide();
            }
        });
    });

    $(".QtyNumbers").each(function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.POI_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(decimalPlaces)) decimalPlaces = 2;
        $(this).val(QtyDecimalRupees(value, decimalPlaces));
    });
    $(document).on("blur", ".QtyNumbers", function () {
        var value = $(this).val();
        var decimalPlaces = $(this).closest("tr").find("input.POI_DecimalPlaces").val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0");
        } else {
            $(this).val(QtyDecimalRupees(value, decimalPlaces));
        }
    });
    $(document).on("input", ".QtyNumbers", function () {
        var $this = $(this);
        var decimalPlaces = parseInt($this.closest("tr").find("input.POI_DecimalPlaces").val(), 10);
        if (isNaN(decimalPlaces)) decimalPlaces = 0;

        let clean = $this.val()
            .replace(/-/g, "")
            .replace(/[^0-9.]/g, "");

        const firstDot = clean.indexOf(".");
        if (firstDot !== -1) {
            clean =
                clean.substring(0, firstDot + 1) +
                clean.substring(firstDot + 1).replace(/\./g, "");
        }
        
        if (decimalPlaces === 0) {
            clean = clean.replace(/\./g, "");
        }
        else if (decimalPlaces > 0 && firstDot !== -1) {
            const parts = clean.split(".");
            if (parts[1].length > decimalPlaces) {
                parts[1] = parts[1].slice(0, decimalPlaces);
                clean = parts.join(".");
            }
        }

        $this.val(clean);
    });
    $(document).on("focus", ".QtyNumbers", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });


    $(".UnitDecimal").each(function () {
        var ValueResult = "0";
        var value = $(this).val();
        var decimalPlaces = $("#POH_DecimalPlaces").val();
        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }
        ValueResult = UnitDecimalRupees(removeCommas(value), decimalPlaces);
        $(this).val(ValueResult);
    });
    $(document).on("blur", ".UnitDecimal", function () {
        var ValueResult = "0";
        var value = $(this).val();

        var decimalPlaces = $("#POH_DecimalPlaces").val();

        if (decimalPlaces === "" || isNaN(value)) {
            decimalPlaces = 2;
        }

        if (value.trim() === "" || isNaN(value)) {
        } else {
            ValueResult = UnitDecimalRupees(value, decimalPlaces);
            $(this).val(ValueResult);
        }
    });
    $(document).on("focus", ".UnitDecimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });
    $(document).on("input", ".UnitDecimal", function () {
        var Value = $(this).val();
        var decimalPlaces = parseInt($("#POH_DecimalPlaces").val());
        if (isNaN(decimalPlaces)) decimalPlaces = 0;

        var UnitValue = Value.replace(/[^\d.]/g, '');
        var parts = UnitValue.split('.');

        if (parts.length > 2) {
            UnitValue = parts[0] + '.' + parts.slice(1).join('');
            parts = UnitValue.split('.');
        }

        if (decimalPlaces === 0) {
            UnitValue = parts[0];
        }
        else if (parts.length === 2 && parts[1].length > decimalPlaces) {
            UnitValue = parts[0] + '.' + parts[1].substring(0, decimalPlaces);
        }

        $(this).val(UnitValue);
    });


    function OnVendorInput(inputElement) {
        SearchVendor(inputElement);
    }
    function OnVendorFocus(inputElement) {
        var tax = inputElement.value;
        if (!tax) {
            SearchVendor(inputElement);
        }
        else {
            $(this).select();
        }
    }
    function SearchVendor(inputElement) {
        var vendor = inputElement.value;
        var resultsDiv = $(inputElement).next('.vendor-search-results');
        var Import;
        var isChecked = $("#POH_ImportOrder").prop("checked");

        if (isChecked) {
            Import = true;
        } else {
            Import = false;
        }

        $.ajax({
            url: 'vendor',
            data: { Vendor: vendor, Import: Import },
            type: 'GET',
            success: function (data) {
                resultsDiv.empty();
                if (data && data.length > 0) {
                    resultsDiv.show();
                    var table = $('<div class="card-body modal-content table-responsive p-0"><table class="table table-bordered table-grid table-body table-hover mb-0 table-fixed"><thead><tr class="table-info"><th class="table-col-xxl">Vendor Name</th><th class="table-width-lg text-center">Currency</th></tr></thead><tbody></tbody></table></div>');
                    data.forEach(function (ven) {
                        var row = $('<tr></tr>');
                        row.append('<td class="table-col-xxl">' + ven.vendorName + '</td>');
                        row.append('<td class="table-width-lg text-center">' + ven.currencyCode + '</td>');
                        table.find('tbody').append(row);

                        row.on('click', function () {
                            $(inputElement).val(ven.vendorName);
                            $("#POH_Vendor_Number").val(ven.vendorNumber)
                            $("#POH_Currency").val(ven.currencyCode)
                            $("#POH_Currency_Number").val(ven.currency)
                            $("#POH_VendorLocation").val(ven.vendorLocation)
                            $("#POH_DecimalPlaces").val(ven.decimalPlaces)

                            resultsDiv.hide();
                        });
                    });

                    var closeButton = $('<div class="card-header bg-primary py-1 px-1"><button type="button" class="p-0 float-end btn btn-sm btn-primary bg-opacity-10 d-flex"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-x-lg" viewBox="0 0 16 16"><path d = "M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8z"> </path></svg></button></div>');
                    closeButton.on('click', function () {
                        resultsDiv.hide();
                    });

                    resultsDiv.append(closeButton);
                    resultsDiv.append(table);
                } else {
                    resultsDiv.hide();
                    resultsDiv.append('<p>No results found</p>');
                }
            },
            error: function () {
                resultsDiv.text('Error loading data.');
                resultsDiv.show();
            }
        });
    }


    $(".decimal").each(function () {
        var value = $(this).val();
        $(this).val(DecimalIndianRupees(removeCommas(value)));
    });
    $(document).on("blur", ".decimal", function () {
        var value = $(this).val();
        if (value.trim() === "" || isNaN(value)) {
            $(this).val("0.00");
        } else {
            $(this).val(DecimalIndianRupees(removeCommas(value)));
        }
    });
    $(document).on("focus", ".decimal", function () {
        var value = $(this).val();
        $(this).val(removeCommas(value));
        $(this).select();
    });

    flatpickr(".datepicker", {
        dateFormat: "d-M-Y",
        altInput: false,
    });

    $(document).on('change', "#POH_Date", function () {
        var POHDate = $('#POH_Date').val();
        const date  = new Date(POHDate);

        const Year = date.getFullYear();
        const Month = date.getMonth() + 1;
        const Day = date.getDate();

        const ForMonth = String(Month).padStart(2, '0');
        const ForDay = String(Day).padStart(2, '0');

        const ForDate = `${Year}${ForMonth}${ForDay}`;
        console.log("ForDate", ForDate);
        $.ajax({
            url: 'numbering',
            data: { PODate: ForDate },
            type: 'GET',
            success: function (data) {
                if (data === "") {
                }
                else {
                    $('#POH_OrderNo').val(data);
                }
            },
            error: function () {
            }
        });

        var POHString = $(this).val();

        $(".POI_DeliveryDate").each(function() {
            var flatpickrInstance = $(this).flatpickr();

            var DeliveryString = $(this).val();
            var POHDate = flatpickrInstance.parseDate(POHString, "d-M-Y");
            var DeliveryDate = flatpickrInstance.parseDate(DeliveryString, "d-M-Y");

            $(this).flatpickr({
                dateFormat: "d-M-Y",
                altInput: false,
                minDate: $("#POH_Date").val()
            });

            if (DeliveryDate && DeliveryDate < POHDate) {
                $(this).val(POHString);
            }
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        const MainDiv = document.getElementById('BodyHeight');
        const HeadDiv = document.getElementById('BodyCardHeader');
        const BodyDiv = document.getElementById('BodyCardBody');
        const FootDiv = document.getElementById('BodyCardFooter');

        if (HeadDiv && BodyDiv) {
            const MainDivHeight = MainDiv.offsetHeight;
            const HeadDivHeight = HeadDiv.offsetHeight;
            const FootDivHeight = FootDiv.offsetHeight;
            BodyDiv.style.height = (MainDivHeight - HeadDivHeight -  FootDivHeight - 2) + 'px';
        }
    });
</script>